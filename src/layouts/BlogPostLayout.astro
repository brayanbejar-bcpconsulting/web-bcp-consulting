---
import MainLayout from "./MainLayout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { CATEGORY_LABELS, formatDate } from "@utils/blog";
import { getBreadcrumbSchema } from "@utils/seo";
import { SITE_INFO } from "@utils/site-config";

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  category?: string;
  author?: string;
  coverImage?: string;
}

const {
  title,
  description,
  date,
  updatedDate,
  category,
  author = "Equipo BCP Consulting",
  coverImage,
} = Astro.props;

// Detecta si coverImage es una URL externa o un filename local
const isExternalUrl = coverImage?.startsWith("http");

// Carga dinámica de imagen local para optimización con <Image>
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/blog/**/*"
);
const imgPath = !isExternalUrl && coverImage
  ? `/src/assets/images/blog/${coverImage}`
  : null;
const imgLoader = imgPath ? allImages[imgPath] : null;
const imgData = imgLoader ? (await imgLoader()).default : null;

const siteOrigin = Astro.url.origin;

// OG image: URL absoluta si la imagen local cargó, luego externa, luego fallback
const ogResolved = imgData
  ? `${siteOrigin}${imgData.src}`
  : (isExternalUrl ? coverImage : null) ?? "/og-image.webp";

const categoryLabel = category ? (CATEGORY_LABELS[category] ?? category) : null;

const dateFormatted = formatDate(date);
const updatedFormatted = updatedDate ? formatDate(updatedDate) : null;

// JSON-LD BlogPosting schema
const schemaImage = imgData
  ? `${siteOrigin}${imgData.src}`
  : isExternalUrl && coverImage
    ? coverImage
    : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  url: Astro.url.href,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": Astro.url.href,
  },
  ...(schemaImage ? { image: schemaImage } : {}),
  author: { "@type": "Person", name: author },
  datePublished: date.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  publisher: {
    "@type": "Organization",
    name: "BCP Consulting E.I.R.L.",
    url: siteOrigin,
    logo: {
      "@type": "ImageObject",
      url: `${siteOrigin}/favicon.svg`,
    },
  },
};

// BreadcrumbList JSON-LD
const bcItems: Array<{ name: string; url: string }> = [
  { name: "Inicio", url: SITE_INFO.url + "/" },
  { name: "Blog", url: SITE_INFO.url + "/blog/" },
];
if (categoryLabel && category) {
  bcItems.push({
    name: categoryLabel,
    url: `${SITE_INFO.url}/blog/categoria/${category}`,
  });
}
bcItems.push({ name: title, url: Astro.url.href });
const breadcrumbSchema = getBreadcrumbSchema(bcItems);
---

<MainLayout title={title} description={description} image={ogResolved} ogType="article">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <meta slot="head" property="article:published_time" content={date.toISOString()} />
  {updatedDate && <meta slot="head" property="article:modified_time" content={updatedDate.toISOString()} />}
  <meta slot="head" property="article:author" content={author} />
  {category && <meta slot="head" property="article:section" content={category} />}
  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="relative w-full overflow-hidden" aria-label="Portada del artículo" style="min-height: 520px;">
    {imgData ? (
      <Image
        src={imgData}
        alt={title}
        width={1200}
        height={630}
        loading="eager"
        draggable="false"
        class="absolute inset-0 w-full h-full object-cover select-none pointer-events-none"
      />
    ) : isExternalUrl && coverImage ? (
      <img
        src={coverImage}
        alt={title}
        width="1200"
        height="630"
        loading="eager"
        draggable="false"
        class="absolute inset-0 w-full h-full object-cover select-none pointer-events-none"
      />
    ) : (
      <div class="absolute inset-0 bg-primary-800"></div>
    )}
    <!-- Gradient overlay: funde imagen hacia primary-800 sólido en el fondo -->
    <div class="absolute inset-0 bg-linear-to-t from-primary-800 via-primary-900/70 to-primary-800/10 pointer-events-none"></div>
    <!-- Bridge final: garantiza transición perfecta al cuerpo -->
    <div class="absolute bottom-0 left-0 right-0 h-28 bg-linear-to-b from-transparent to-primary-800 pointer-events-none"></div>

    <!-- Title over image -->
    <div class="relative z-10 mx-auto max-w-4xl px-6 pt-28 pb-14 flex flex-col justify-end h-full" style="min-height: 520px;">
      <!-- Breadcrumb -->
      <nav class="mb-5 w-fit flex items-center gap-2 text-sm text-white/75 bg-black/25 backdrop-blur-sm rounded-full px-4 py-1.5 ring-1 ring-white/10" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span class="text-white/40">/</span>
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        {categoryLabel && category && (
          <>
            <span class="text-white/40">/</span>
            <a href={`/blog/categoria/${category}`} class="text-secondary-300 font-medium hover:text-secondary-200 transition-colors">
              {categoryLabel}
            </a>
          </>
        )}
      </nav>

      {categoryLabel && (
        <span class="mb-3 inline-flex w-fit items-center rounded-full border border-secondary-400/40 bg-secondary-500/20 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-secondary-200">
          {categoryLabel}
        </span>
      )}

      <h1 class="text-balance text-3xl font-extrabold leading-tight text-white md:text-4xl lg:text-5xl"
          style="color: white; font-size: clamp(1.6rem, 3.5vw + 0.5rem, 3rem);">
        {title}
      </h1>

      <p class="mt-4 max-w-2xl text-base text-white/75 md:text-lg">{description}</p>

      <!-- Meta row -->
      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm">
        <span class="flex items-center gap-1.5 bg-black/35 backdrop-blur-sm rounded-full px-3 py-1 text-white/85 ring-1 ring-white/10">
          <!-- calendar icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <time datetime={date.toISOString()}>{dateFormatted}</time>
        </span>
        {updatedDate && (
          <span class="flex items-center gap-1.5 bg-black/35 backdrop-blur-sm rounded-full px-3 py-1 text-white/85 ring-1 ring-white/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/>
            </svg>
            Actualizado: {updatedFormatted}
          </span>
        )}
        <span class="flex items-center gap-1.5 bg-black/35 backdrop-blur-sm rounded-full px-3 py-1 text-white/85 ring-1 ring-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
          {author}
        </span>
      </div>
    </div>
  </section>

  <!-- ── Article body ───────────────────────────────────────────── -->
  <div class="bg-theme-page py-20">
    <div class="mx-auto max-w-4xl px-6">

      <!-- Article card -->
      <article
        class="relative"
      >
        <div
          class="prose prose-lg max-w-none
            prose-headings:font-heading prose-headings:font-bold
            prose-headings:text-primary-900 dark:prose-headings:text-white
            prose-h2:mt-10 prose-h2:mb-4 prose-h2:text-2xl md:prose-h2:text-3xl
            prose-h3:mt-8 prose-h3:mb-3
            prose-p:text-neutral-700 dark:prose-p:text-slate-300 prose-p:leading-relaxed
            prose-a:text-secondary-600 dark:prose-a:text-secondary-400 prose-a:no-underline hover:prose-a:text-secondary-500 dark:hover:prose-a:text-secondary-300 hover:prose-a:underline
            prose-strong:text-primary-950 dark:prose-strong:text-slate-100
            prose-ul:text-neutral-700 dark:prose-ul:text-slate-300
            prose-ol:text-neutral-700 dark:prose-ol:text-slate-300
            prose-li:my-1
            prose-blockquote:border-l-secondary-500
            prose-blockquote:text-neutral-700 dark:prose-blockquote:text-slate-300
            prose-blockquote:bg-neutral-50 dark:prose-blockquote:bg-primary-900/60
            prose-blockquote:not-italic prose-blockquote:rounded-r-lg prose-blockquote:py-2 prose-blockquote:pr-4
            prose-code:text-secondary-600 dark:prose-code:text-secondary-300
            prose-code:bg-neutral-100 dark:prose-code:bg-primary-900
            prose-code:rounded prose-code:px-1 prose-code:text-sm prose-code:before:content-none prose-code:after:content-none
            prose-pre:bg-neutral-50 dark:prose-pre:bg-primary-950
            prose-pre:text-neutral-800 dark:prose-pre:text-slate-200
            prose-pre:ring-1 prose-pre:ring-black/10 dark:prose-pre:ring-white/10
            prose-img:rounded-xl prose-img:shadow-md prose-img:my-6
            prose-hr:border-neutral-200 dark:prose-hr:border-primary-700
            prose-table:text-neutral-700 dark:prose-table:text-slate-300
            prose-th:text-primary-900 dark:prose-th:text-slate-100
            prose-th:border-neutral-200 dark:prose-th:border-primary-700
            prose-td:border-neutral-200 dark:prose-td:border-primary-700"
        >
          <slot />
        </div>
      </article>

      <!-- After article: share, navigation, related -->
      <div class="mt-10 space-y-8">
        <slot name="after-article" />
      </div>

      <!-- Back link -->
      <div class="mt-10 flex justify-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 rounded-full border border-theme-border bg-theme-card px-6 py-2.5 text-sm font-medium text-theme-base shadow-sm transition-all hover:bg-theme-surface hover:text-theme-heading hover:border-secondary-500 hover:shadow-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
          </svg>
          Volver al Blog
        </a>
      </div>

    </div>
  </div>

</MainLayout>
