---
import BaseHead from "../components/shared/BaseHead.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  canonical?: string;
  ogImage?: string;
}

const { title, description, date, canonical, ogImage } = Astro.props;
const url = canonical ?? Astro.url.href;
---

<html lang="es">
  <head>
    <BaseHead
      title={title}
      description={description}
      canonical={url}
      image={ogImage ?? "/og-default.jpg"}
    />
  </head>

  <body>
    <main class="mx-auto w-full max-w-5xl px-4 py-10">
      <header class="mb-8">
        <p class="text-sm text-muted">
          {date.toLocaleDateString("es-PE", { year: "numeric", month: "long", day: "2-digit" })}
        </p>
        <h1 class="mt-2 text-balance">{title}</h1>
        <p class="mt-4 max-w-3xl text-lg text-muted">{description}</p>
      </header>

      <article class="prose prose-lg max-w-none">
        <slot />
      </article>
    </main>
  </body>
</html>
