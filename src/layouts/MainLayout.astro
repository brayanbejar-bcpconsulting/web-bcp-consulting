---
import '@styles/global.css';
import { Header, Footer, BaseHead } from '@components';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Override og:type (default: "website"). Use "article" for blog posts. */
  ogType?: string;
  /** Override robots meta (default: "index, follow"). Use "noindex, follow" for legal pages. */
  robots?: string;
}

const { title, description, image, ogType, robots } = Astro.props;
---

<!doctype html>
<html lang="es-PE">
  <head>
    <!-- Anti-FOUC: aplica clase 'dark' ANTES de que cargue el CSS -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored === 'dark' || stored === 'light' ? stored : (prefersDark ? 'dark' : 'light');
          if (theme === 'dark') document.documentElement.classList.add('dark');
          else document.documentElement.classList.remove('dark');
        } catch (e) {}
      })();
    </script>
    <BaseHead title={title} description={description} image={image} ogType={ogType} robots={robots} />
    <slot name="head" /> </head>
  <body>
    <Header />
    
    <main id="main-content">
      <slot /> </main>

    <Footer />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>