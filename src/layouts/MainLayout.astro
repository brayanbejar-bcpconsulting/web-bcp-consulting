---
import '@styles/global.css';
import { Header, Footer, BaseHead } from '@components';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <slot name="head" /> </head>
  <body>
    <Header />
    
    <main id="main-content">
      <slot /> </main>

    <Footer />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>