---
import { MainContainer, HeadingSection, FeatureList, Button } from "@components/ui";

const beneficios = [
  "Reducción de desviaciones presupuestales al detectar sobrecostos cuando aún son corregibles.",
  "Mayor transparencia financiera entre gerencia, accionistas y clientes con reportes auditables.",
  "Información estratégica en tiempo real: avance, costo y riesgo de cada proyecto al instante.",
  "Capacidad de escalar proyectos con control sin depender de más personal administrativo.",
  "Menos conflictos con subcontratistas al tener registros claros de entregables y pagos.",
];
---

<MainContainer id="beneficios" bgColor="bg-white">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
    <div>
      <HeadingSection
        tagline="Por qué elegirnos"
        title="Beneficios Estratégicos para tu Constructora"
        description="Más que software: una herramienta de control que protege el margen de cada proyecto y permite crecer con estructura."
        align="left"
      />

      <FeatureList features={beneficios} class="mb-8" />

      <Button href="#contacto" variant="primary" size="lg">
        Quiero Controlar mis Obras
      </Button>
    </div>

    <figure
      class="relative rounded-2xl overflow-hidden bg-gradient-to-br from-primary-700 to-primary-900 aspect-video flex items-center justify-center shadow-2xl"
      aria-label="Vista previa del panel de gestión de obras"
    >
      <div class="bg-white/10 border border-white/20 rounded-xl p-6 text-white text-center w-72">
        <p class="text-xs text-white/60 mb-1">Proyecto activo — Edificio Central</p>
        <p class="text-3xl font-extrabold">68<span class="text-lg font-normal text-white/50">% avance</span></p>
        <p class="text-xs text-yellow-300 mt-1">⚠ Presupuesto al 74% ejecutado</p>

        <dl class="mt-4 grid grid-cols-3 gap-2">
          <div class="bg-white/10 rounded-lg p-2">
            <dt class="text-xs text-white/60 leading-tight">Proyectos</dt>
            <dd class="text-lg font-bold">5</dd>
          </div>
          <div class="bg-white/10 rounded-lg p-2">
            <dt class="text-xs text-white/60 leading-tight">Presup.</dt>
            <dd class="text-sm font-bold">S/2.4M</dd>
          </div>
          <div class="bg-white/10 rounded-lg p-2">
            <dt class="text-xs text-white/60 leading-tight">Desvío</dt>
            <dd class="text-sm font-bold text-yellow-300">+6%</dd>
          </div>
        </dl>
      </div>
      <figcaption class="absolute bottom-3 right-4 text-xs text-white/30">
        Dashboard en tiempo real
      </figcaption>
    </figure>
  </div>
</MainContainer>
