---
import { MainContainer, HeadingSection, FeatureCard, Carousel } from "@components/ui";

const problemas = [
  {
    title: "Presupuestos que se Desbordan",
    description: "Sin una comparación constante entre lo presupuestado y lo ejecutado, los sobrecostos aparecen al final de la obra cuando ya no hay margen de maniobra.",
    icon: "alert-triangle",
  },
  {
    title: "Falta de Control en Materiales",
    description: "El consumo real de materiales raramente coincide con lo estimado. Sin registro en tiempo real, las diferencias se detectan tarde y generan compras de emergencia.",
    icon: "package",
  },
  {
    title: "Retrasos sin Indicadores Claros",
    description: "Cuando no existe un seguimiento por etapas, los retrasos se acumulan silenciosamente hasta convertirse en penalidades contractuales o pérdida del cliente.",
    icon: "clock-check",
  },
  {
    title: "Información Dispersa entre Oficina y Obra",
    description: "Reportes en papel, WhatsApp y Excel solapados impiden que la gerencia tome decisiones oportunas con información confiable y centralizada.",
    icon: "layers",
  },
];
---

<MainContainer id="problemas" bgColor="bg-theme-surface">
  <HeadingSection
    tagline="El Desafío"
    title="Problemas Comunes que Afectan la Rentabilidad en Obras"
    description="Si alguno de estos escenarios te resulta familiar, tu constructora está perdiendo dinero en cada proyecto sin que los números lo reflejen a tiempo."
    align="center"
  />

  <Carousel data={problemas} visibleDesktop={3}>
    {
      problemas.map((p) => (
        <FeatureCard title={p.title} description={p.description} icon={p.icon} />
      ))
    }
  </Carousel>

  <p class="mt-10 text-center">
    <a
      href="#funcionalidades"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary-600 text-white text-sm font-semibold hover:bg-primary-700 transition-colors duration-200 shadow"
    >
      Ver cómo lo resolvemos
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </p>
</MainContainer>
