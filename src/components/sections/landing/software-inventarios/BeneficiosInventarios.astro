---
import { MainContainer, HeadingSection, FeatureList, Button } from "@components/ui";

const beneficios = [
  "Reducción del capital inmovilizado al identificar productos sin rotación y optimizar las compras.",
  "Mayor precisión operativa: conteos más rápidos, menos diferencias y menos ajustes contables.",
  "Control financiero mejorado con el costo de inventario siempre actualizado y auditable.",
  "Visibilidad completa por almacén, categoría o producto desde cualquier dispositivo.",
  "Menos tiempo invertido en tareas manuales y más en decisiones de abastecimiento estratégico.",
];
---

<MainContainer id="beneficios" bgColor="bg-theme-page">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
    <div>
      <HeadingSection
        tagline="Por qué elegirnos"
        title="Beneficios Estratégicos para la Gestión de tu Inventario"
        description="Un inventario bien controlado no es solo orden. Es rentabilidad visible, decisiones más rápidas y operación sin fricciones."
        align="left"
      />

      <FeatureList features={beneficios} class="mb-8" />

      <Button href="#contacto" variant="primary" size="lg">
        Quiero Controlar mi Inventario
      </Button>
    </div>

    <figure
      class="relative rounded-2xl overflow-hidden bg-gradient-to-br from-primary-700 to-primary-900 aspect-video flex items-center justify-center shadow-2xl"
      aria-label="Vista previa del panel de control de inventarios"
    >
      <div class="bg-white/10 border border-white/20 rounded-xl p-6 text-white text-center w-72">
        <p class="text-xs text-white/60 mb-1">Stock total en sistema</p>
        <p class="text-3xl font-extrabold">4,832 <span class="text-base font-normal text-white/50">und.</span></p>
        <p class="text-xs text-yellow-300 mt-1">⚠ 3 productos bajo stock mínimo</p>

        <dl class="mt-4 grid grid-cols-3 gap-2">
          <div class="bg-white/10 rounded-lg p-2">
            <dt class="text-xs text-white/60 leading-tight">Almacenes</dt>
            <dd class="text-lg font-bold">4</dd>
          </div>
          <div class="bg-white/10 rounded-lg p-2">
            <dt class="text-xs text-white/60 leading-tight">SKUs</dt>
            <dd class="text-lg font-bold">218</dd>
          </div>
          <div class="bg-white/10 rounded-lg p-2">
            <dt class="text-xs text-white/60 leading-tight">Rotación</dt>
            <dd class="text-sm font-bold">92%</dd>
          </div>
        </dl>
      </div>
      <figcaption class="absolute bottom-3 right-4 text-xs text-white/30">
        Dashboard en tiempo real
      </figcaption>
    </figure>
  </div>
</MainContainer>
