---
import { MainContainer, HeadingSection, FeatureCard, Carousel } from "@components/ui";

const problemas = [
  {
    title: "Quiebres de Stock Inesperados",
    description: "Quedarse sin producto en el momento de venta genera pérdidas directas, clientes insatisfechos y urgencias de compra a precios desfavorables.",
    icon: "alert-triangle",
  },
  {
    title: "Exceso de Inventario sin Rotación",
    description: "Productos acumulados que no se venden inmovilizan capital, ocupan espacio y pueden generar mermas por vencimiento u obsolescencia.",
    icon: "package",
  },
  {
    title: "Errores en Conteos Manuales",
    description: "Los inventarios físicos en papel o Excel producen diferencias contables que distorsionan el costo de ventas y el valor real del stock.",
    icon: "search",
  },
  {
    title: "Falta de Visibilidad por Almacén",
    description: "Sin una vista centralizada de cada sede o bodega, es imposible trasladar stock eficientemente ni detectar dónde están los cuellos de botella.",
    icon: "warehouse",
  },
];
---

<MainContainer id="problemas" bgColor="bg-neutral-50">
  <HeadingSection
    tagline="El Desafío"
    title="Problemas Críticos que Afectan tus Almacenes Hoy"
    description="Cada uno de estos problemas se traduce en dinero perdido o capital paralizado. Si reconoces alguno, tu empresa necesita un sistema de inventarios."
    align="center"
  />

  <Carousel data={problemas} visibleDesktop={3}>
    {
      problemas.map((p) => (
        <FeatureCard title={p.title} description={p.description} icon={p.icon} />
      ))
    }
  </Carousel>

  <p class="mt-10 text-center">
    <a
      href="#funcionalidades"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary-600 text-white text-sm font-semibold hover:bg-primary-700 transition-colors duration-200 shadow"
    >
      Ver cómo lo resolvemos
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </p>
</MainContainer>
