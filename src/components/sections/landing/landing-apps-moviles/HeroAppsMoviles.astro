---
import { NAVIGATION } from "@utils/navigation";

const waPhone = NAVIGATION.contact.phone.replace(/\D/g, "");
const waMsg = encodeURIComponent(
  "Hola BCP Consulting, vengo desde https://bcpconsulting.pe/landing-apps-moviles/. Quiero asesorarme y solicitar una cotización para el desarrollo de una app móvil."
);

const proofChips = [
  { valor: "+10", label: "años de experiencia" },
  { valor: "+50", label: "proyectos entregados" },
  { valor: "8–14 sem", label: "tiempo típico MVP*" },
  { valor: "RUC", label: NAVIGATION.contact.ruc },
];

const takeaways = [
  "MVP típico: 8–14 semanas según funcionalidades, plataformas e integraciones definidas.",
  "Entregable inicial sin compromiso: alcance detallado, prototipo clickable y roadmap por fases.",
  "KPI objetivo: +25% conversión móvil, reducción de tiempos operativos, retención medible desde el primer mes.",
];
---

<section
  id="hero"
  aria-labelledby="hero-heading"
  class="relative py-20 lg:py-28 overflow-hidden bg-primary-600 text-white"
>
  <!-- Fondo decorativo -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-[520px] h-[520px] bg-complementary-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-72 h-72 bg-secondary-500/10 rounded-full blur-3xl"></div>
    <!-- Patrón grid sutil -->
    <svg class="absolute inset-0 w-full h-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)" />
    </svg>
  </div>

  <div class="relative z-10 max-w-350 mx-auto px-[5%]">
    <div class="flex flex-col lg:flex-row gap-10 xl:gap-16 items-start lg:items-center">

      <!-- Columna principal -->
      <div class="flex flex-col items-start gap-5 lg:w-[55%]">

        <span class="inline-block px-3 py-1 rounded-full bg-white/10 border border-white/20 text-xs font-semibold uppercase tracking-widest text-white/90">
          Desarrollo de Apps Móviles en Perú · RUC {NAVIGATION.contact.ruc}
        </span>

        <h1
          id="hero-heading"
          class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white text-balance leading-tight"
        >
          Desarrollo de apps móviles a medida{" "}
          <span class="text-complementary-300">(iOS/Android) para vender más, automatizar y fidelizar</span>
        </h1>

        <p class="text-sm md:text-base text-white/80 leading-relaxed max-w-xl">
          Diseñamos y desarrollamos aplicaciones nativas, híbridas o PWA adaptadas a tu modelo de negocio:
          canal de ventas móvil, delivery, reservas, fuerza comercial, fidelización y procesos internos.
          Arquitectura escalable, seguridad OWASP y soporte continuo desde Lima, Perú.
        </p>

        <!-- Key Takeaways / Veredicto del experto -->
        <div
          class="w-full rounded-2xl bg-white/10 border border-white/20 p-4 md:p-5"
          aria-label="Resumen del servicio – puntos clave"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-complementary-300 mb-3">
            Veredicto del experto — Lo que obtienes
          </p>
          <ul class="flex flex-col gap-2.5" role="list">
            {takeaways.map((t) => (
              <li class="flex items-start gap-2.5 text-sm text-white/85">
                <svg class="w-4 h-4 text-complementary-300 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {t}
              </li>
            ))}
          </ul>
        </div>

        <!-- CTAs principales -->
        <div class="flex flex-col sm:flex-row flex-wrap gap-3 w-full">
          <!-- CTA 1: WhatsApp (primario) -->
          <a
            href={`https://api.whatsapp.com/send/?phone=${waPhone}&text=${waMsg}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-green-500 hover:bg-green-400 text-white font-bold text-sm transition-colors duration-200 min-h-[44px]"
          >
            <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.115.554 4.103 1.523 5.83L.057 23.5l5.816-1.448A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.371l-.36-.214-3.726.927.972-3.618-.234-.371A9.818 9.818 0 1112 21.818z"/>
            </svg>
            Hablar por WhatsApp
            <span class="text-xs font-normal opacity-80">— Respuesta rápida</span>
          </a>

          <!-- CTA 2: Llamar -->
          <a
            href={`tel:${NAVIGATION.contact.phone.replace(/\s/g, "")}`}
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-white/10 border border-white/30 hover:bg-white/20 text-white font-bold text-sm transition-colors duration-200 min-h-[44px]"
          >
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Llamar ahora
          </a>

          <!-- CTA 3: Cotizar (abre modal) -->
          <button
            type="button"
            data-open-modal="cotizar-apps"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-complementary-500 hover:bg-complementary-400 text-white font-bold text-sm transition-colors duration-200 min-h-[44px]"
            aria-haspopup="dialog"
          >
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Cotizar con alcance
            <span class="text-xs font-normal opacity-80">— Sin compromiso</span>
          </button>
        </div>

        <!-- Proof chips -->
        <div class="flex flex-wrap gap-3 pt-2" role="list" aria-label="Credenciales y datos clave">
          {proofChips.map((chip) => (
            <div role="listitem" class="flex items-baseline gap-1.5 px-3 py-1.5 rounded-xl bg-white/10 border border-white/15">
              <span class="text-lg font-extrabold text-complementary-300 leading-none">{chip.valor}</span>
              <span class="text-xs text-white/65">{chip.label}</span>
            </div>
          ))}
        </div>

        <p class="text-xs text-white/35">
          * El tiempo de 8–14 semanas aplica a un MVP con funcionalidades definidas. Proyectos más complejos pueden requerir más fases.
          El descuento del 20% aplica al primer proyecto aprobado, sujeto a evaluación de alcance.
        </p>
      </div>

      <!-- Columna derecha: formulario rápido (visible solo en desktop) -->
      <aside
        class="hidden lg:flex flex-col lg:w-[42%] xl:w-[38%]"
        aria-label="Formulario de cotización rápida"
      >
        <div class="bg-white/10 border border-white/20 backdrop-blur-sm rounded-2xl p-6 md:p-8">
          <p class="text-xs font-semibold uppercase tracking-widest text-complementary-300 mb-1">¿Tienes una idea de app?</p>
          <h2 class="text-lg font-extrabold text-white mb-1">Cuéntanos y recibe tu alcance</h2>
          <p class="text-xs text-white/65 mb-5">Sin compromiso. Te enviamos una propuesta por fases en menos de 24 h.</p>

          <form id="hero-form-apps" class="flex flex-col gap-3" novalidate>
            <div class="flex flex-col gap-1">
              <label for="hf-nombre" class="text-xs font-medium text-white/80">
                Nombre completo <span aria-hidden="true">*</span>
              </label>
              <input
                id="hf-nombre" type="text" name="nombre"
                autocomplete="name" required aria-required="true"
                class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder:text-white/40 text-sm focus:outline-none focus:ring-2 focus:ring-complementary-400 focus:border-transparent transition"
              />
            </div>
            <div class="flex flex-col gap-1">
              <label for="hf-whatsapp" class="text-xs font-medium text-white/80">
                WhatsApp <span aria-hidden="true">*</span>
              </label>
              <input
                id="hf-whatsapp" type="tel" name="celular"
                autocomplete="tel" required aria-required="true"
                placeholder="+51 9XX XXX XXX"
                class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder:text-white/40 text-sm focus:outline-none focus:ring-2 focus:ring-complementary-400 focus:border-transparent transition"
              />
            </div>
            <div class="flex flex-col gap-1">
              <label for="hf-email" class="text-xs font-medium text-white/80">
                Correo <span class="text-white/40">(opcional)</span>
              </label>
              <input
                id="hf-email" type="email" name="email"
                autocomplete="email"
                class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder:text-white/40 text-sm focus:outline-none focus:ring-2 focus:ring-complementary-400 focus:border-transparent transition"
              />
            </div>
            <div class="flex flex-col gap-1">
              <label for="hf-proyecto" class="text-xs font-medium text-white/80">
                ¿Qué tipo de app necesitas?
              </label>
              <textarea
                id="hf-proyecto" name="mensaje" rows="3"
                placeholder="Ej: app de delivery, ventas en campo, fidelización de clientes…"
                class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder:text-white/40 text-sm focus:outline-none focus:ring-2 focus:ring-complementary-400 focus:border-transparent transition resize-none"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full mt-1 px-6 py-3.5 rounded-full bg-complementary-500 hover:bg-complementary-400 text-white font-bold text-sm transition-colors duration-200 min-h-[44px] flex items-center justify-center gap-2"
            >
              Enviar — Asesoría Gratis
            </button>
            <div id="hf-apps-status" role="status" aria-live="polite" class="hidden text-xs text-center text-complementary-300 font-medium pt-1"></div>
          </form>

          <p class="text-center text-xs text-white/35 mt-4">RUC: {NAVIGATION.contact.ruc} · {NAVIGATION.contact.email}</p>
        </div>
      </aside>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById("hero-form-apps") as HTMLFormElement | null;
  const status = document.getElementById("hf-apps-status");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (status) {
      status.classList.remove("hidden");
      status.textContent = "✓ Mensaje recibido. Te contactamos en menos de 24 h.";
    }
    setTimeout(() => form?.reset(), 800);
  });
</script>
