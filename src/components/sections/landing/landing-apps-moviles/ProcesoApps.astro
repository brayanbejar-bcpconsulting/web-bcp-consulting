---
const fases = [
  {
    numero: "01",
    titulo: "Descubrimiento",
    descripcion: "Comprendemos tus objetivos de negocio, usuarios reales, flujos de uso y riesgos técnicos antes de escribir una línea de código.",
    entregables: [
      "Brief de producto y objetivos medibles (KPIs)",
      "Mapa de usuarios y sus necesidades",
      "Inventario de integraciones necesarias",
      "Identificación de riesgos técnicos y legales",
    ],
    color: "bg-primary-600",
  },
  {
    numero: "02",
    titulo: "Alcance + Backlog (MVP vs fases)",
    descripcion: "Priorizamos funcionalidades por valor de negocio. Separamos lo que va al MVP de lo que puede esperar, reduciendo costo sin perder valor.",
    entregables: [
      "Documento de alcance funcional firmado",
      "Backlog priorizado (MVP vs roadmap futuro)",
      "Cronograma por sprints con hitos claros",
      "Presupuesto desagregado por fase",
    ],
    color: "bg-primary-700",
  },
  {
    numero: "03",
    titulo: "UX/UI + Prototipo clickable",
    descripcion: "Diseñamos los flujos de usuario y las pantallas antes de desarrollar. Apruebas el diseño antes de que se construya.",
    entregables: [
      "Wireframes de todos los flujos clave",
      "Diseño de pantallas (Figma, high-fidelity)",
      "Prototipo clickable para pruebas de usabilidad",
      "Guía de componentes y paleta de marca",
    ],
    color: "bg-secondary-600",
  },
  {
    numero: "04",
    titulo: "Desarrollo (sprints iterativos)",
    descripcion: "Desarrollamos en ciclos cortos de 2 semanas. Cada sprint entrega funcionalidades funcionando, no promesas.",
    entregables: [
      "Código versionado en Git (repositorio tuyo)",
      "Builds en TestFlight / Firebase App Distribution",
      "Demo funcional al final de cada sprint",
      "Logs de progreso y acceso al tablero del proyecto",
    ],
    color: "bg-secondary-700",
  },
  {
    numero: "05",
    titulo: "QA en dispositivos reales + performance",
    descripcion: "Probamos en dispositivos iOS y Android físicos, distintas versiones del OS y condiciones de red reales.",
    entregables: [
      "Checklist de casos de prueba por funcionalidad",
      "Pruebas en ≥5 dispositivos (real + emulador)",
      "Reporte de bugs resueltos por severidad",
      "Auditoría de performance y tamaño del APK/IPA",
    ],
    color: "bg-complementary-600",
  },
  {
    numero: "06",
    titulo: "Publicación (App Store / Play Store / enterprise)",
    descripcion: "Gestionamos la publicación en stores o distribución enterprise. Te orientamos con las cuentas de desarrollador si las necesitas.",
    entregables: [
      "Screenshots, descripciones y metadatos de store",
      "Build firmado y subido a App Store / Play Store",
      "Resolución de revisiones de Apple/Google",
      "Documento de credenciales y accesos (tuyo)",
    ],
    color: "bg-complementary-700",
  },
  {
    numero: "07",
    titulo: "Analítica + iteración post-lanzamiento",
    descripcion: "Configuramos Firebase Analytics, Crashlytics o GA4 para que midas lo que importa desde el día 1, no de oídas.",
    entregables: [
      "Dashboard de analítica configurado (Firebase/GA4)",
      "Alertas de crasheos y errores críticos",
      "Informe de primeras métricas (30 días)",
      "Plan de iteraciones v1.1 según datos reales",
    ],
    color: "bg-green-600",
  },
];
---

<section
  id="proceso"
  aria-labelledby="proceso-heading"
  class="py-16 lg:py-24 bg-neutral-50 dark:bg-neutral-900"
>
  <div class="max-w-350 mx-auto px-[5%]">

    <header class="mb-12 text-center">
      <span class="inline-block px-3 py-1 rounded-full bg-primary-100 dark:bg-primary-900/40 text-primary-700 dark:text-primary-300 text-xs font-semibold uppercase tracking-widest mb-3">
        Proceso real · EEAT
      </span>
      <h2 id="proceso-heading" class="text-2xl md:text-3xl font-extrabold text-neutral-900 dark:text-white leading-tight">
        Cómo construimos tu app (sin humo)
      </h2>
      <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto">
        7 fases probadas con +50 proyectos entregados. Cada fase tiene entregables concretos que puedes revisar y aprobar.
      </p>
    </header>

    <ol class="relative flex flex-col gap-0" aria-label="Fases del proceso de desarrollo">
      {fases.map((fase, i) => (
        <li class="relative flex gap-4 md:gap-6">
          <!-- Línea conectora -->
          {i < fases.length - 1 && (
            <div class="absolute left-6 top-14 bottom-0 w-0.5 bg-neutral-200 dark:bg-neutral-700 z-0" aria-hidden="true"></div>
          )}

          <!-- Número de fase -->
          <div class={`relative z-10 flex-shrink-0 w-12 h-12 rounded-full ${fase.color} text-white flex items-center justify-center font-extrabold text-sm shadow-md mt-1`}
            aria-hidden="true">
            {fase.numero}
          </div>

          <!-- Contenido -->
          <div class="flex flex-col gap-2 pb-10">
            <h3 class="text-base md:text-lg font-bold text-neutral-900 dark:text-white leading-tight">
              {fase.titulo}
            </h3>
            <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
              {fase.descripcion}
            </p>
            <!-- Checklist de entregables -->
            <div class="mt-2 bg-white dark:bg-neutral-800 rounded-xl border border-neutral-200 dark:border-neutral-700 p-4">
              <p class="text-xs font-semibold text-neutral-500 dark:text-neutral-400 uppercase tracking-wider mb-2">
                Entregables
              </p>
              <ul class="flex flex-col gap-1.5" role="list">
                {fase.entregables.map((e) => (
                  <li class="flex items-start gap-2 text-xs text-neutral-700 dark:text-neutral-300">
                    <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {e}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </li>
      ))}
    </ol>

  </div>
</section>
