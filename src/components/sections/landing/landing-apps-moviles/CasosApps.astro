---
const casos = [
  {
    industria: "Retail / Moda",
    problema: "Las ventas dependían 100% del punto de venta físico. Sin canal digital propio, perdían clientes a competidores con tienda online.",
    solucion: "App de e-commerce nativa iOS/Android con catálogo, carrito, pagos con Culqi y programa de puntos integrado.",
    tiempo: "12 semanas (MVP)",
    kpis: [
      { valor: "+38%", label: "ingresos canal digital en 90 días" },
      { valor: "4.6★", label: "calificación en Play Store" },
      { valor: "68%", label: "retención a 30 días" },
    ],
    stack: "React Native · Culqi · Firebase",
  },
  {
    industria: "Salud / Clínicas",
    problema: "Citas médicas se gestionaban por teléfono y WhatsApp manual. Alta tasa de no-shows y saturación del call center.",
    solucion: "App de reservas con disponibilidad en tiempo real, pagos anticipados opcionales, recordatorios push y SMS automáticos.",
    tiempo: "10 semanas (MVP)",
    kpis: [
      { valor: "-42%", label: "no-shows tras primer trimestre" },
      { valor: "+60%", label: "citas agendadas digitalmente vs. teléfono" },
      { valor: "3.2 min", label: "tiempo promedio de reserva" },
    ],
    stack: "Flutter · Firebase · Culqi · API Historia Clínica",
  },
  {
    industria: "Logística / Distribución",
    problema: "Fuerza de ventas y repartidores reportaban incidencias en papel. Datos llegaban al sistema central con 24–48 h de retraso.",
    solucion: "App interna Android con formularios offline-first, geolocalización, captura de firma y fotos, sincronización automática.",
    tiempo: "8 semanas (MVP)",
    kpis: [
      { valor: "100%", label: "reportes en tiempo real (vs. 24-48 h)" },
      { valor: "-70%", label: "errores de transcripción manual" },
      { valor: "14 min", label: "ahorro por visita de campo" },
    ],
    stack: "React Native · SQLite offline · Maps SDK · REST API interna",
  },
];
---

<section
  id="casos"
  aria-labelledby="casos-heading"
  class="py-16 lg:py-24 bg-white dark:bg-neutral-950"
>
  <div class="max-w-350 mx-auto px-[5%]">

    <header class="mb-12 text-center">
      <span class="inline-block px-3 py-1 rounded-full bg-primary-100 dark:bg-primary-900/40 text-primary-700 dark:text-primary-300 text-xs font-semibold uppercase tracking-widest mb-3">
        Evidencia · EEAT
      </span>
      <h2 id="casos-heading" class="text-2xl md:text-3xl font-extrabold text-neutral-900 dark:text-white leading-tight">
        Resultados reales de clientes reales
      </h2>
      <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto">
        Mini-casos representativos por industria. Cada cifra corresponde al primer ciclo de medición post-lanzamiento.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {casos.map((caso) => (
        <article
          class="flex flex-col rounded-2xl border border-neutral-200 dark:border-neutral-700 overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300"
          aria-label={`Caso: ${caso.industria}`}
        >
          <!-- Header del caso -->
          <header class="bg-primary-600 text-white px-5 py-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-primary-200 mb-1">{caso.industria}</p>
            <!-- KPIs destacados arriba -->
            <div class="flex flex-wrap gap-3 mt-2">
              {caso.kpis.map((kpi) => (
                <div class="flex flex-col items-start">
                  <span class="text-2xl font-extrabold text-complementary-300 leading-none">{kpi.valor}</span>
                  <span class="text-xs text-white/70 leading-tight mt-0.5">{kpi.label}</span>
                </div>
              ))}
            </div>
          </header>

          <!-- Cuerpo del caso -->
          <div class="flex flex-col gap-4 p-5 flex-1 bg-white dark:bg-neutral-900">
            <div>
              <p class="text-xs font-semibold text-red-600 dark:text-red-400 uppercase tracking-wider mb-1">Problema</p>
              <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">{caso.problema}</p>
            </div>
            <div>
              <p class="text-xs font-semibold text-green-600 dark:text-green-400 uppercase tracking-wider mb-1">Solución</p>
              <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">{caso.solucion}</p>
            </div>
            <div class="flex items-center gap-3 pt-1 border-t border-neutral-100 dark:border-neutral-800">
              <div>
                <p class="text-xs text-neutral-500">⏱ Tiempo</p>
                <p class="text-xs font-semibold text-neutral-700 dark:text-neutral-300">{caso.tiempo}</p>
              </div>
              <div class="border-l border-neutral-200 dark:border-neutral-700 pl-3">
                <p class="text-xs text-neutral-500">Stack</p>
                <p class="text-xs font-semibold text-neutral-700 dark:text-neutral-300">{caso.stack}</p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <p class="mt-6 text-xs text-neutral-400 dark:text-neutral-500 text-center">
      Los datos son representativos del primer ciclo post-lanzamiento. Identificación de clientes omitida por acuerdo de confidencialidad.
    </p>

  </div>
</section>
