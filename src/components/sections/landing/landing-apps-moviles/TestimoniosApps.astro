---
const testimonios = [
  {
    sector: "E-commerce / Retail",
    accion: "App de ventas iOS + Android con catálogo, carrito y pagos",
    resultado: "Pasamos de 0 ventas digitales a generar el 38% de ingresos totales en 3 meses.",
    kpi: "+38% ingresos canal digital",
    nombre: "Gerente Comercial",
    empresa: "Empresa retail de moda, Lima",
    rating: 5,
  },
  {
    sector: "Salud / Clínicas",
    accion: "App de reservas médicas con disponibilidad en tiempo real",
    resultado: "Se redujeron los no-shows en 42% y ahora más del 60% de citas se agenda digitalmente. El equipo de recepción quedó libre para atención de calidad.",
    kpi: "-42% no-shows",
    nombre: "Directora de Operaciones",
    empresa: "Clínica privada, Lima Norte",
    rating: 5,
  },
  {
    sector: "Logística / Distribución",
    accion: "App interna Android para fuerza de ventas y repartidores offline-first",
    resultado: "Eliminamos los reportes en papel. Ahora todo llega en tiempo real. Ahorramos 14 minutos por visita de campo, que se traduce en 2 visitas más por jornada.",
    kpi: "14 min/visita ahorrados",
    nombre: "Jefe de Operaciones",
    empresa: "Empresa de distribución, Arequipa",
    rating: 5,
  },
];
---

<section
  id="testimonios"
  aria-labelledby="testimonios-heading"
  class="py-16 lg:py-24 bg-neutral-50 dark:bg-neutral-900"
>
  <div class="max-w-350 mx-auto px-[5%]">

    <header class="mb-12 text-center">
      <span class="inline-block px-3 py-1 rounded-full bg-primary-100 dark:bg-primary-900/40 text-primary-700 dark:text-primary-300 text-xs font-semibold uppercase tracking-widest mb-3">
        Clientes reales · EEAT
      </span>
      <h2 id="testimonios-heading" class="text-2xl md:text-3xl font-extrabold text-neutral-900 dark:text-white leading-tight">
        Lo que dicen quienes ya lanzaron su app
      </h2>
      <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto">
        Testimonios con contexto real: qué se hizo, qué cambió y qué midieron.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonios.map((t) => (
        <figure
          class="flex flex-col bg-white dark:bg-neutral-800 rounded-2xl border border-neutral-200 dark:border-neutral-700 p-6 shadow-sm hover:shadow-md transition-shadow duration-300"
          aria-label={`Testimonio: ${t.sector}`}
        >
          <!-- Rating -->
          <div class="flex gap-1 mb-4" aria-label={`Calificación: ${t.rating} de 5 estrellas`}>
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- KPI destacado -->
          <div class="inline-block self-start px-3 py-1.5 rounded-xl bg-complementary-50 dark:bg-complementary-900/30 border border-complementary-100 dark:border-complementary-800/40 mb-4">
            <span class="text-sm font-extrabold text-complementary-700 dark:text-complementary-300">{t.kpi}</span>
          </div>

          <!-- Cita -->
          <blockquote class="flex-1">
            <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed italic">
              "{t.resultado}"
            </p>
          </blockquote>

          <!-- Footer del testimonio -->
          <figcaption class="mt-5 pt-4 border-t border-neutral-100 dark:border-neutral-700">
            <p class="text-xs font-semibold text-neutral-500 dark:text-neutral-400 uppercase tracking-wider mb-1">{t.sector}</p>
            <p class="text-xs text-neutral-500 dark:text-neutral-400 mb-1">
              <strong class="text-neutral-700 dark:text-neutral-300">Qué se hizo:</strong> {t.accion}
            </p>
            <p class="text-xs text-neutral-400 dark:text-neutral-500">— {t.nombre}, {t.empresa}</p>
          </figcaption>
        </figure>
      ))}
    </div>

  </div>
</section>
