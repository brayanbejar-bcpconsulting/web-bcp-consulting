---
const faqs = [
  {
    id: "faq-1",
    pregunta: "¿Quién publica la app? ¿Necesito cuentas de App Store y Play Store?",
    respuesta: "Nosotros gestionamos y te orientamos en la creación de las cuentas de desarrollador de Apple (USD 99/año) y Google (USD 25 pago único), que son de tu propiedad. Publicamos bajo tu cuenta. Tú eres el dueño de la app en los stores.",
  },
  {
    id: "faq-2",
    pregunta: "¿Soy dueño del código fuente?",
    respuesta: "Sí. Al completar el proyecto, te entregamos el repositorio Git con el código completo. Puedes llevarlo a cualquier equipo de desarrollo. No hay lock-in de plataforma ni de proveedor.",
  },
  {
    id: "faq-3",
    pregunta: "¿Ofrecen soporte y mantenimiento tras el lanzamiento? ¿Tienen SLA?",
    respuesta: "Sí. Ofrecemos planes de mantenimiento mensual que incluyen actualizaciones de compatibilidad (nuevas versiones de iOS/Android), corrección de bugs, mejoras menores y monitoreo de errores. El SLA estándar es resolución de bugs críticos en 24 h hábiles. Los planes se negocian según el nivel de soporte requerido.",
  },
  {
    id: "faq-4",
    pregunta: "¿Qué pasa si el alcance cambia durante el desarrollo?",
    respuesta: "Trabajamos con alcance firmado y backlogs en Notion/Jira. Los cambios de alcance se evalúan, se documentan como cambios de requerimiento (CR) y se presupuestan por separado. Nunca absorbimos cambios de alcance sin comunicación y aprobación previa del cliente.",
  },
  {
    id: "faq-5",
    pregunta: "¿Cómo manejan la seguridad de los datos?",
    respuesta: "Aplicamos cifrado TLS 1.3 en tránsito y AES-256 en reposo. Usamos autenticación OAuth 2.0/JWT, roles y permisos granulares, y seguimos el estándar OWASP MASVS como referencia de seguridad móvil. Los datos del cliente nunca se comparten con terceros. Podemos firmar NDAs y addendas de protección de datos.",
  },
  {
    id: "faq-6",
    pregunta: "¿Pueden integrar pagos, ERP, CRM, WhatsApp y otras APIs?",
    respuesta: "Sí. Tenemos experiencia integrando Culqi, Mercado Pago, Stripe, Yape/Plin; ERP como SAP, Odoo y sistemas propietarios; WhatsApp Business API; Google Maps y Firebase. Si tienes un sistema existente con API REST o SOAP, podemos conectarlo.",
  },
  {
    id: "faq-7",
    pregunta: "¿La analítica (Firebase/GA4) está incluida?",
    respuesta: "Sí, configuramos Firebase Analytics o GA4 como parte del proceso de desarrollo. Incluimos eventos clave, conversiones y un dashboard básico. Dashboards avanzados o integraciones con BI (Looker, Data Studio, etc.) son opcionales según el plan.",
  },
  {
    id: "faq-8",
    pregunta: "¿Desarrollan para iOS, Android o ambas plataformas?",
    respuesta: "Las tres opciones. Podemos desarrollar nativas (Swift/Kotlin), multiplataforma (React Native/Flutter) o PWA. Lo recomendado depende de tu presupuesto, audiencia y requerimientos de rendimiento. En la asesoría inicial te damos nuestra recomendación objetiva.",
  },
  {
    id: "faq-9",
    pregunta: "¿Cómo es el proceso de pago del proyecto?",
    respuesta: "Trabajamos con hitos de pago alineados a entregas concretas: usualmente 30% al inicio, 30% al entregar el prototipo aprobado, 30% al completar el desarrollo y 10% al publicar. Ofrecemos fraccionamiento según el alcance.",
  },
];
---

<section
  id="faq"
  aria-labelledby="faq-heading"
  class="py-16 lg:py-24 bg-white dark:bg-neutral-950"
>
  <div class="max-w-350 mx-auto px-[5%]">

    <header class="mb-12 text-center">
      <span class="inline-block px-3 py-1 rounded-full bg-primary-100 dark:bg-primary-900/40 text-primary-700 dark:text-primary-300 text-xs font-semibold uppercase tracking-widest mb-3">
        FAQ · AEO + Conversión
      </span>
      <h2 id="faq-heading" class="text-2xl md:text-3xl font-extrabold text-neutral-900 dark:text-white leading-tight">
        Preguntas frecuentes
      </h2>
      <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto">
        Respuestas directas a las dudas más comunes antes de contratar el desarrollo de una app.
      </p>
    </header>

    <div class="flex flex-col gap-2 max-w-3xl mx-auto" role="list">
      {faqs.map((faq, i) => (
        <div
          role="listitem"
          class="rounded-2xl border border-neutral-200 dark:border-neutral-700 overflow-hidden"
        >
          <button
            type="button"
            id={`${faq.id}-btn`}
            aria-expanded="false"
            aria-controls={`${faq.id}-panel`}
            class="w-full flex items-center justify-between gap-4 px-5 py-4 bg-white dark:bg-neutral-900 text-left hover:bg-neutral-50 dark:hover:bg-neutral-800/60 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-primary-500"
          >
            <span class="text-sm font-semibold text-neutral-900 dark:text-white leading-snug">
              {faq.pregunta}
            </span>
            <svg
              class={`faq-icon w-5 h-5 text-neutral-400 flex-shrink-0 transition-transform duration-200`}
              fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div
            id={`${faq.id}-panel`}
            role="region"
            aria-labelledby={`${faq.id}-btn`}
            hidden
            class="px-5 pb-5 bg-white dark:bg-neutral-900 border-t border-neutral-100 dark:border-neutral-800"
          >
            <p class="pt-4 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
              {faq.respuesta}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  // Patrón accesible de acordeón (ARIA APG)
  const faqButtons = document.querySelectorAll<HTMLButtonElement>('[id$="-btn"][aria-expanded]');

  faqButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const isExpanded = btn.getAttribute("aria-expanded") === "true";
      const panelId = btn.getAttribute("aria-controls");
      const panel = panelId ? document.getElementById(panelId) : null;
      const icon = btn.querySelector(".faq-icon");

      btn.setAttribute("aria-expanded", String(!isExpanded));

      if (isExpanded) {
        panel?.setAttribute("hidden", "");
        icon?.classList.remove("rotate-180");
      } else {
        panel?.removeAttribute("hidden");
        icon?.classList.add("rotate-180");
      }
    });

    // Soporte de teclado
    btn.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Escape") {
        btn.setAttribute("aria-expanded", "false");
        const panelId = btn.getAttribute("aria-controls");
        const panel = panelId ? document.getElementById(panelId) : null;
        const icon = btn.querySelector(".faq-icon");
        panel?.setAttribute("hidden", "");
        icon?.classList.remove("rotate-180");
      }
    });
  });
</script>
