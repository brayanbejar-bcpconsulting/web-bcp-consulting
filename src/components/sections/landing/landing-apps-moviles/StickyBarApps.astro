---
import { NAVIGATION } from "@utils/navigation";

const waPhone = NAVIGATION.contact.phone.replace(/\D/g, "");
const waMsg = encodeURIComponent(
  "Hola BCP Consulting, vengo desde https://bcpconsulting.pe/landing-apps-moviles/. Quiero consultar sobre el desarrollo de una app móvil."
);
---

<!-- Sticky Bottom Bar — solo visible en móvil (< md) -->
<nav
  id="sticky-bottom-bar"
  aria-label="Acciones principales"
  class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex items-stretch bg-white dark:bg-neutral-900 border-t border-neutral-200 dark:border-neutral-700 shadow-[0_-4px_24px_rgba(0,0,0,0.12)]"
  style="padding-bottom: env(safe-area-inset-bottom, 0px);"
>
  <!-- WhatsApp (primario) -->
  <a
    href={`https://api.whatsapp.com/send/?phone=${waPhone}&text=${waMsg}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex-1 flex flex-col items-center justify-center gap-1 py-3 min-h-[56px] bg-green-500 hover:bg-green-400 active:bg-green-600 text-white transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-green-300"
    aria-label="Hablar por WhatsApp – Respuesta rápida"
  >
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.115.554 4.103 1.523 5.83L.057 23.5l5.816-1.448A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.371l-.36-.214-3.726.927.972-3.618-.234-.371A9.818 9.818 0 1112 21.818z"/>
    </svg>
    <span class="text-[10px] font-semibold leading-none">WhatsApp</span>
    <span class="text-[9px] text-green-100 leading-none">Respuesta rápida</span>
  </a>

  <!-- Llamar -->
  <a
    href={`tel:${NAVIGATION.contact.phone.replace(/\s/g, "")}`}
    class="flex-1 flex flex-col items-center justify-center gap-1 py-3 min-h-[56px] bg-white dark:bg-neutral-900 hover:bg-neutral-50 dark:hover:bg-neutral-800 active:bg-neutral-100 dark:active:bg-neutral-700 text-neutral-700 dark:text-neutral-200 border-t-0 border-r border-l border-neutral-100 dark:border-neutral-700 transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-primary-500"
    aria-label="Llamar ahora"
  >
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    <span class="text-[10px] font-semibold leading-none">Llamar</span>
    <span class="text-[9px] text-neutral-400 leading-none">Ahora</span>
  </a>

  <!-- Cotizar (abre modal) -->
  <button
    type="button"
    data-open-modal="cotizar-apps"
    aria-haspopup="dialog"
    class="flex-1 flex flex-col items-center justify-center gap-1 py-3 min-h-[56px] bg-complementary-500 hover:bg-complementary-400 active:bg-complementary-600 text-white transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-complementary-300"
    aria-label="Cotizar con alcance – Sin compromiso"
  >
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    <span class="text-[10px] font-semibold leading-none">Cotizar</span>
    <span class="text-[9px] text-complementary-100 leading-none">Con alcance</span>
  </button>
</nav>

<!-- Espaciador para que el contenido no quede debajo de la barra en móvil -->
<div
  class="md:hidden h-16"
  style="height: calc(4rem + env(safe-area-inset-bottom, 0px));"
  aria-hidden="true"
></div>
