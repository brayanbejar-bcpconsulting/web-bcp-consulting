---
import { MainContainer, HeadingSection, FeatureCard, Carousel } from "@components/ui";

const opcionales = [
  {
    title: "Proyección de Demanda con IA",
    description: "Predicción de consumo según historial y estacionalidad para optimizar compras.",
    icon: "lightbulb"
  },
  {
    title: "Análisis de Rentabilidad Automático",
    description: "Identifica productos poco rentables y sugiere ajustes en recetas o precios.",
    icon: "search"
  },
  {
    title: "Integración Delivery y Facturación",
    description: "Centraliza pedidos externos y evita doble digitación con facturación electrónica.",
    icon: "smartphone"
  },
  {
    title: "Panel Multisede Corporativo",
    description: "Ideal para cadenas o franquicias. Controla todas tus sucursales desde un solo lugar.",
    icon: "globe"
  }
];
---

<MainContainer id="evolucion" bgColor="bg-neutral-50">
  <HeadingSection
    tagline="Crece con nosotros"
    title="Funcionalidades Opcionales y Evolución del Sistema"
    description="El sistema crece con tu negocio. Activa módulos avanzados cuando los necesites."
    align="center"
  />

  <Carousel data={opcionales} visibleDesktop={4}>
    {
      opcionales.map((opcional) => (
        <FeatureCard
          title={opcional.title}
          description={opcional.description}
          icon={opcional.icon}
        />
      ))
    }
  </Carousel>

  <!-- CTA intermedio -->
  <div class="mt-10 text-center">
    <a
      href="#beneficios"
      class="inline-flex items-center gap-2 text-sm text-primary-600 font-semibold hover:text-primary-800 transition-colors"
    >
      Ver beneficios estratégicos
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </a>
  </div>
</MainContainer>
