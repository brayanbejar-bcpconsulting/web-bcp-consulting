---
import { MainContainer, HeadingSection, FeatureCard, Carousel } from "@components/ui";

const funcionalidades = [
  {
    title: "Punto de Venta Inteligente (POS)",
    description: "Sistema ágil para salón, delivery y recojo en tienda. Permite controlar ventas por turno, por mozo y por caja.",
    icon: "smartphone"
  },
  {
    title: "Control de Inventarios por Receta",
    description: "Descuenta insumos automáticamente según cada plato vendido. Detecta diferencias entre consumo teórico y real.",
    icon: "layout"
  },
  {
    title: "Gestión Digital de Cocina (KDS)",
    description: "Visualización organizada de pedidos para reducir errores y tiempos muertos en la preparación.",
    icon: "code"
  },
  {
    title: "Reportes Gerenciales en Tiempo Real",
    description: "Ventas por hora, producto más rentable, margen bruto y desempeño por sede al instante.",
    icon: "search"
  },
  {
    title: "Control de Usuarios y Roles",
    description: "Define permisos por colaborador para evitar fraudes internos y mantener la seguridad de la información.",
    icon: "user"
  }
];
---

<MainContainer id="funcionalidades" bgColor="bg-theme-page">
  <HeadingSection
    tagline="Lo que incluye"
    title="Funcionalidades Principales del Sistema"
    description="Todo lo que necesitas para tomar el control de tu restaurante desde el primer día."
    align="center"
  />

  <Carousel data={funcionalidades} visibleDesktop={3}>
    {
      funcionalidades.map((func) => (
        <FeatureCard
          title={func.title}
          description={func.description}
          icon={func.icon}
        />
      ))
    }
  </Carousel>

  <!-- CTA intermedio -->
  <div class="mt-10 text-center">
    <a
      href="#contacto"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-secondary-500 text-white text-sm font-semibold hover:bg-secondary-600 transition-colors duration-200 shadow"
    >
      Quiero este sistema para mi restaurante
    </a>
  </div>
</MainContainer>
