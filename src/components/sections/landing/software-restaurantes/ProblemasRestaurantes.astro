---
import { MainContainer, HeadingSection, FeatureCard, Carousel } from "@components/ui";

const problemas = [
  {
    title: "Mermas Desconocidas",
    description: "No saber exactamente cuánto se pierde por mermas en la cocina o barra.",
    icon: "search"
  },
  {
    title: "Descuadres de Caja",
    description: "Descuadres de caja recurrentes al final del turno que generan desconfianza.",
    icon: "layout"
  },
  {
    title: "Rentabilidad Oculta",
    description: "Falta de claridad sobre qué productos realmente generan utilidad y cuáles no.",
    icon: "lightbulb"
  },
  {
    title: "Errores de Comunicación",
    description: "Errores constantes entre el salón, la caja y la cocina que retrasan pedidos.",
    icon: "smartphone"
  },
  {
    title: "Dependencia del Administrador",
    description: "Dependencia excesiva del administrador para resolver cualquier problema operativo.",
    icon: "user"
  },
  {
    title: "Información Dispersa",
    description: "Información financiera dispersa en Excel, cuadernos o sistemas obsoletos.",
    icon: "globe"
  },
  {
    title: "Desorden por Crecimiento",
    description: "Cuando la operación crece, el desorden también crece si no existe un sistema sólido.",
    icon: "rocket"
  }
];
---

<MainContainer id="problemas" bgColor="bg-theme-surface">
  <HeadingSection
    tagline="El Desafío"
    title="Problemas Reales que Enfrentan los Restaurantes Hoy"
    description="Si te identificas con más de uno, tu restaurante está perdiendo dinero todos los días sin que te des cuenta."
    align="center"
  />

  <Carousel data={problemas} visibleDesktop={3}>
    {
      problemas.map((problema) => (
        <FeatureCard
          title={problema.title}
          description={problema.description}
          icon={problema.icon}
        />
      ))
    }
  </Carousel>

  <!-- CTA intermedio -->
  <div class="mt-10 text-center">
    <a
      href="#funcionalidades"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary-600 text-white text-sm font-semibold hover:bg-primary-700 transition-colors duration-200 shadow"
    >
      Ver cómo lo resolvemos
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </a>
  </div>
</MainContainer>
