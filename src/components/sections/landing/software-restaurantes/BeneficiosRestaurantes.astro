---
import { MainContainer, HeadingSection, FeatureList, Button } from "@components/ui";

const beneficios = [
  "Reducción real de pérdidas operativas y mermas.",
  "Mayor control sin necesidad de supervisión constante.",
  "Información clara y precisa para planes de expansión.",
  "Mayor estabilidad financiera y flujo de caja predecible.",
  "No es solo un sistema, es una herramienta de control empresarial."
];
---

<MainContainer id="beneficios" bgColor="bg-white">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
    <div>
      <HeadingSection
        tagline="Por qué elegirnos"
        title="Beneficios Estratégicos para tu Restaurante"
        description="No es solo un sistema. Es una herramienta de control empresarial que cambia la forma en que gestionas tu negocio."
        align="left"
      />
      
      <FeatureList features={beneficios} class="mb-8" />
      
      <Button href="#contacto" variant="primary" size="lg">
        Quiero Transformar mi Restaurante
      </Button>
    </div>
    
    <!-- Visual de dashboard simulado -->
    <div class="relative rounded-2xl overflow-hidden bg-gradient-to-br from-primary-700 to-primary-900 aspect-video flex items-center justify-center shadow-2xl">
      <div class="bg-white/10 border border-white/20 rounded-xl p-6 text-white text-center w-64">
        <p class="text-xs text-white/60 mb-1">Ventas hoy</p>
        <p class="text-3xl font-extrabold">S/ 4,280</p>
        <p class="text-xs text-green-300 mt-1">↑ 12% vs ayer</p>
        <div class="mt-4 grid grid-cols-2 gap-3">
          <div class="bg-white/10 rounded-lg p-2">
            <p class="text-xs text-white/60">Tickets</p>
            <p class="text-lg font-bold">142</p>
          </div>
          <div class="bg-white/10 rounded-lg p-2">
            <p class="text-xs text-white/60">Margen</p>
            <p class="text-lg font-bold">34%</p>
          </div>
        </div>
      </div>
      <div class="absolute bottom-3 right-4">
        <span class="text-xs text-white/30">Dashboard en tiempo real</span>
      </div>
    </div>
  </div>
</MainContainer>
