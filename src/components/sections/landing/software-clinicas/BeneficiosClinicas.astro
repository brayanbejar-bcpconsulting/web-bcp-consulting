---
import { MainContainer, HeadingSection, FeatureList, Button } from "@components/ui";

const beneficios = [
  "Reducción hasta un 60% del tiempo administrativo por paciente.",
  "Menos errores de citas y cero doble programación en consultorios.",
  "Datos de pacientes protegidos, respaldados y accesibles solo por personal autorizado.",
  "Control financiero real: ingresos por especialidad, médico y convenio en tiempo real.",
  "Escalabilidad garantizada: el sistema crece contigo, desde un consultorio hasta una clínica multisede.",
];
---

<MainContainer id="beneficios" bgColor="bg-theme-page">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
    <div>
      <HeadingSection
        tagline="Por qué elegirnos"
        title="Beneficios Estratégicos para tu Centro Médico"
        description="No es solo digitalizar procesos. Es transformar la forma en que tu clínica opera, atiende y crece."
        align="left"
      />

      <FeatureList features={beneficios} class="mb-8" />

      <Button href="#contacto" variant="primary" size="lg">
        Quiero Transformar mi Clínica
      </Button>
    </div>

    <!-- Dashboard simulado de clínica -->
    <div class="relative rounded-2xl overflow-hidden bg-gradient-to-br from-primary-700 to-primary-900 aspect-video flex items-center justify-center shadow-2xl">
      <div class="bg-white/10 border border-white/20 rounded-xl p-6 text-white text-center w-72">
        <p class="text-xs text-white/60 mb-1">Citas programadas hoy</p>
        <p class="text-3xl font-extrabold">48</p>
        <p class="text-xs text-green-300 mt-1">↑ 8 más que ayer</p>
        <div class="mt-4 grid grid-cols-3 gap-2">
          <div class="bg-white/10 rounded-lg p-2">
            <p class="text-xs text-white/60 leading-tight">Atendidos</p>
            <p class="text-lg font-bold">31</p>
          </div>
          <div class="bg-white/10 rounded-lg p-2">
            <p class="text-xs text-white/60 leading-tight">Facturado</p>
            <p class="text-base font-bold">S/6.4k</p>
          </div>
          <div class="bg-white/10 rounded-lg p-2">
            <p class="text-xs text-white/60 leading-tight">Ocupación</p>
            <p class="text-lg font-bold">91%</p>
          </div>
        </div>
      </div>
      <div class="absolute bottom-3 right-4">
        <span class="text-xs text-white/30">Dashboard en tiempo real</span>
      </div>
    </div>
  </div>
</MainContainer>
