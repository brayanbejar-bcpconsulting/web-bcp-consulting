---
import { MainContainer, HeadingSection, FeatureCard, Carousel } from "@components/ui";

const problemas = [
  {
    title: "Historias Clínicas en Papel",
    description: "Expedientes físicos difíciles de ubicar, susceptibles a daño o pérdida y sin respaldo ante auditorías del MINSA.",
    icon: "clipboard-medical",
  },
  {
    title: "Errores en Programación de Citas",
    description: "Citas duplicadas, olvidos de confirmación y tiempos muertos entre consultas que reducen la capacidad real de atención.",
    icon: "calendar-check",
  },
  {
    title: "Facturación Lenta y Manual",
    description: "Procesos de cobranza lentos que generan colas, errores de cobro y dificultades para cumplir con la facturación electrónica de SUNAT.",
    icon: "credit-card",
  },
  {
    title: "Poca Visibilidad Financiera",
    description: "Sin reportes en tiempo real, es imposible saber qué especialidades son rentables, cuánto se factura por día o cuál es el margen real del centro.",
    icon: "search",
  },
  {
    title: "Riesgo de Pérdida de Datos Sensibles",
    description: "Información de pacientes en hojas de cálculo o sistemas obsoletos sin respaldo, expone la clínica a sanciones y pérdida de confianza.",
    icon: "shield-check",
  },
];
---

<MainContainer id="problemas" bgColor="bg-neutral-50">
  <HeadingSection
    tagline="El Desafío"
    title="Dolencias Administrativas que Afectan tu Clínica Hoy"
    description="Si reconoces alguno de estos problemas, tu centro de salud está perdiendo eficiencia y dinero sin que lo notes."
    align="center"
  />

  <Carousel data={problemas} visibleDesktop={3}>
    {
      problemas.map((problema) => (
        <FeatureCard
          title={problema.title}
          description={problema.description}
          icon={problema.icon}
        />
      ))
    }
  </Carousel>

  <!-- CTA intermedio -->
  <div class="mt-10 text-center">
    <a
      href="#funcionalidades"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary-600 text-white text-sm font-semibold hover:bg-primary-700 transition-colors duration-200 shadow"
    >
      Ver cómo lo resolvemos
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </div>
</MainContainer>
