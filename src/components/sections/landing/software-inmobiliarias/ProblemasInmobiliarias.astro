---
import { MainContainer, HeadingSection, FeatureCard, Carousel } from "@components/ui";

const problemas = [
  {
    title: "Leads sin Seguimiento Oportuno",
    description: "Un prospecto que no recibe respuesta en las primeras horas reduce drásticamente su probabilidad de cierre. Sin un sistema centralizado, los leads caen en el olvido.",
    icon: "funnel",
  },
  {
    title: "Información Dispersa entre Asesores",
    description: "Cuando cada asesor gestiona sus contactos en el celular o en Excel personal, la empresa pierde el control del pipeline y queda rehén de la permanencia de cada vendedor.",
    icon: "users-group",
  },
  {
    title: "Sin Visibilidad del Pipeline de Ventas",
    description: "Sin un embudo de ventas actualizado en tiempo real, la gerencia toma decisiones sobre proyecciones inexactas y no puede intervenir a tiempo cuando un proyecto se estanca.",
    icon: "search",
  },
  {
    title: "Imposible Medir Desempeño por Proyecto",
    description: "¿Qué proyecto convierte más? ¿Qué asesor cierra mejor? Sin métricas por campaña o unidad, es imposible optimizar el esfuerzo comercial.",
    icon: "chart-bar",
  },
  {
    title: "Reservas y Separaciones Manuales",
    description: "Gestionar reservas en hojas de cálculo genera doble venta de unidades, conflictos con clientes y pérdida de credibilidad en el mercado.",
    icon: "file-text",
  },
];
---

<MainContainer id="problemas" bgColor="bg-theme-surface">
  <HeadingSection
    tagline="El Desafío"
    title="Problemas Comunes en Empresas Inmobiliarias"
    description="En el sector inmobiliario, cada lead mal gestionado es una venta perdida. Si reconoces alguno de estos escenarios, tu operación comercial tiene margen de mejora significativo."
    align="center"
  />

  <Carousel data={problemas} visibleDesktop={3}>
    {
      problemas.map((p) => (
        <FeatureCard title={p.title} description={p.description} icon={p.icon} />
      ))
    }
  </Carousel>

  <p class="mt-10 text-center">
    <a
      href="#funcionalidades"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary-600 text-white text-sm font-semibold hover:bg-primary-700 transition-colors duration-200 shadow"
    >
      Ver cómo lo resolvemos
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </p>
</MainContainer>
