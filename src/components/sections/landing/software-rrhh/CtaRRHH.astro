---
import { MainContainer } from "@components/ui";
import { NAVIGATION } from "@utils/navigation";

const waPhone = NAVIGATION.contact.phone.replace(/\D/g, "");
const waMsg = encodeURIComponent(
  "Hola, quiero una demo del software de gestión de RRHH"
);
---

<MainContainer id="contacto" bgColor="bg-primary-700" class="relative overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
  >
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-3xl mx-auto text-center flex flex-col items-center gap-5">
    <span
      class="inline-block px-3 py-1 rounded-full bg-white/10 border border-white/20 text-xs font-semibold uppercase tracking-wide text-white/90"
    >
      Da el siguiente paso
    </span>

    <h2 class="text-2xl md:text-3xl font-extrabold text-white leading-tight">
      ¿Listo para Transformar el Área de Recursos Humanos de tu Empresa?
    </h2>

    <p class="text-sm md:text-base text-white/80 leading-relaxed max-w-xl">
      Agenda una demo gratuita y descubre cómo nuestro sistema automatiza planillas, asistencia, contratos y evaluaciones para que tu equipo de RRHH se enfoque en lo que realmente importa: las personas.
    </p>

    <!--
      address: elemento semántico correcto para información de contacto.
      not-italic neutraliza el estilo por defecto del navegador.
    -->
    <address class="not-italic grid grid-cols-1 sm:grid-cols-2 gap-4 w-full max-w-lg mt-2">
      <a
        href={`https://api.whatsapp.com/send/?phone=${waPhone}&text=${waMsg}`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 p-4 rounded-2xl bg-green-500 hover:bg-green-400 transition-colors duration-200 shadow-lg"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-7 w-7 flex-shrink-0 text-white"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.115.554 4.103 1.523 5.83L.057 23.5l5.816-1.448A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.371l-.36-.214-3.726.927.972-3.618-.234-.371A9.818 9.818 0 1112 21.818z" />
        </svg>
        <p class="text-left">
          <span class="block text-xs text-white/80">Escríbenos por</span>
          <span class="text-sm font-bold text-white">WhatsApp</span>
        </p>
      </a>

      <a
        href={`mailto:${NAVIGATION.contact.email}?subject=Demo Software de Gestión de RRHH`}
        class="flex items-center gap-3 p-4 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/20 transition-colors duration-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-7 w-7 flex-shrink-0 text-white"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          />
        </svg>
        <p class="text-left">
          <span class="block text-xs text-white/80">Envíanos un</span>
          <span class="text-sm font-bold text-white">Correo electrónico</span>
        </p>
      </a>
    </address>

    <!-- Trust signals — ul para lista de garantías, no divs genéricos -->
    <ul
      role="list"
      class="flex flex-wrap items-center justify-center gap-5 pt-4 border-t border-white/20 w-full"
      aria-label="Garantías del servicio"
    >
      {
        [
          { icon: "💼", label: "Especialistas en RRHH corporativo" },
          { icon: "⚖️", label: "Cumplimiento normativo MINTRA" },
          { icon: "🇵🇪", label: "Soporte en Perú" },
        ].map((t) => (
          <li class="flex items-center gap-1.5 text-xs text-white/60">
            <span aria-hidden="true">{t.icon}</span>
            <span>{t.label}</span>
          </li>
        ))
      }
    </ul>
  </div>
</MainContainer>
