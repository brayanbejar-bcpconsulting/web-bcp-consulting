---
// Sección G: Estimación orientativa de costos — landing conversion-first

const rangos = [
  {
    tipo: "MVP / Módulo base",
    descripcion: "Sistema funcional con los módulos esenciales para validar el negocio o resolver el problema principal.",
    alcance: "1–3 módulos, 1 flujo principal, roles básicos",
    tiempo: "4–8 semanas",
    desde: "S/. 8,000",
    rango: "S/. 8,000 – S/. 25,000",
    ideal: "Startups, validación de concepto, módulo de un área puntual",
    color: "border-blue-500/30 bg-blue-500/5",
    numColor: "text-blue-400",
  },
  {
    tipo: "Sistema completo",
    descripcion: "Plataforma multi-módulo con flujos integrados, roles avanzados, reportes y panel de administración.",
    alcance: "4–8 módulos, dashboards, integraciones básicas",
    tiempo: "2–4 meses",
    desde: "S/. 25,000",
    rango: "S/. 25,000 – S/. 70,000",
    ideal: "PYMES, sistemas de gestión interna, CRM/ERP sin personalización extrema",
    color: "border-complementary-500/30 bg-complementary-500/5",
    numColor: "text-complementary-400",
  },
  {
    tipo: "Plataforma / SaaS avanzado",
    descripcion: "Producto digital multi-tenant con alta disponibilidad, escalabilidad y funcionalidades complejas de negocio.",
    alcance: "Multi-tenant, pagos, onboarding, analíticas, API pública",
    tiempo: "3–6 meses",
    desde: "S/. 70,000",
    rango: "S/. 70,000+",
    ideal: "SaaS, fintech, plataformas educativas, sistemas sectoriales completos",
    color: "border-green-500/30 bg-green-500/5",
    numColor: "text-green-400",
  },
];

const factores = [
  "Número de módulos y pantallas",
  "Integraciones con sistemas externos (SUNAT, pagos, APIs)",
  "Complejidad de reglas de negocio y flujos",
  "Nivel de personalización del diseño UX/UI",
  "Migración de datos desde sistemas anteriores",
  "Requisitos de rendimiento y escalabilidad",
  "Soporte y mantenimiento post-lanzamiento",
];
---

<section
  id="estimacion"
  aria-labelledby="estimacion-heading"
  class="py-16 lg:py-20 bg-theme-page"
  style="scroll-margin-top: 5rem"
>
  <div class="max-w-350 mx-auto px-[5%]">
    <header class="max-w-2xl mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-secondary-500 dark:text-secondary-400 mb-2">
        Inversión orientativa
      </p>
      <h2 id="estimacion-heading" class="text-2xl md:text-3xl font-extrabold text-theme-heading leading-tight">
        ¿Cuánto cuesta desarrollar software a medida?
      </h2>
      <p class="mt-3 text-sm text-theme-muted leading-relaxed">
        No existe un precio fijo porque cada proyecto es diferente. Pero podemos orientarte
        con rangos reales según el tipo de solución. La propuesta detallada la enviamos tras
        la asesoría gratuita.
      </p>
    </header>

    <!-- Definición AEO para IA -->
    <div class="mb-8 p-4 rounded-xl bg-secondary-50 dark:bg-white/5 border border-secondary-200 dark:border-white/10">
      <p class="text-xs font-semibold uppercase tracking-wide text-secondary-600 dark:text-secondary-400 mb-1">Definición</p>
      <p class="text-sm text-theme-muted leading-relaxed">
        <strong class="text-theme-heading">Software a medida</strong> es un sistema desarrollado específicamente para los flujos y requerimientos
        de una organización, a diferencia del software empaquetado (como SAP o Salesforce genérico).
        Su costo refleja el alcance funcional, no un precio de catálogo.
      </p>
    </div>

    <!-- Tarjetas: solo "desde" visible -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
      {rangos.map((r) => (
        <div class={`flex flex-col gap-3 p-5 rounded-2xl border ${r.color}`}>
          <h3 class="text-sm font-bold text-theme-heading">{r.tipo}</h3>
          <p class="text-xs text-theme-muted leading-relaxed flex-1">{r.descripcion}</p>
          <div class="flex flex-col gap-1">
            <span class="text-[10px] font-semibold text-theme-muted/70 uppercase tracking-wide">Desde</span>
            <span class={`font-bold text-2xl leading-none ${r.numColor}`}>{r.desde}</span>
            <span class="text-xs text-theme-muted/60">{r.tiempo} estimado</span>
          </div>
          <p class="text-xs text-theme-muted/60 italic border-t border-theme-border pt-2">Ideal para: {r.ideal}</p>
        </div>
      ))}
    </div>

    <!-- Acordeón: rango completo + factores -->
    <details class="rounded-2xl border border-theme-border bg-theme-surface overflow-hidden">
      <summary class="flex items-center justify-between gap-3 cursor-pointer px-5 py-4 text-sm font-semibold text-theme-heading list-none select-none group hover:bg-theme-page transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-secondary-500">
        <span>Ver rangos completos y factores que afectan el precio</span>
        <svg class="w-4 h-4 shrink-0 transition-transform group-open:rotate-180 text-theme-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      <div class="px-5 pb-5 pt-3 border-t border-theme-border flex flex-col gap-5">
        <!-- Rangos detallados -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {rangos.map((r) => (
            <dl class={`flex flex-col gap-2 p-4 rounded-xl border ${r.color} text-xs`}>
              <div class="font-bold text-theme-heading text-sm mb-1">{r.tipo}</div>
              <div><dt class="font-semibold text-theme-muted/70 uppercase tracking-wide text-[10px]">Rango de inversión</dt><dd class={`font-bold text-base ${r.numColor}`}>{r.rango}</dd></div>
              <div><dt class="font-semibold text-theme-muted/70 uppercase tracking-wide text-[10px]">Alcance típico</dt><dd class="text-theme-muted">{r.alcance}</dd></div>
            </dl>
          ))}
        </div>
        <!-- Factores -->
        <div>
          <p class="text-xs font-semibold text-theme-heading mb-3">Factores que afectan el precio final</p>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2" role="list">
            {factores.map((f) => (
              <li class="flex items-start gap-2 text-sm text-theme-muted">
                <svg class="w-4 h-4 text-secondary-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </details>

    <p class="mt-5 text-xs text-theme-muted/60 text-center">
      * Rangos expresados en soles peruanos (PEN). Incluyen diseño UX/UI, desarrollo, pruebas y deploy inicial.
      No incluyen dominio, hosting mensual, ni mantenimiento post-entrega (cotizados por separado según plan).
    </p>

    <!-- Navegación sección siguiente -->
    <div class="mt-8 text-center">
      <a
        href="#faq"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-secondary-100 dark:bg-secondary-900/30 border border-secondary-300 dark:border-secondary-700 text-secondary-700 dark:text-secondary-300 text-sm font-semibold hover:bg-secondary-200 dark:hover:bg-secondary-900/50 transition-colors min-h-11"
      >
        Resolver dudas en FAQ ↓
      </a>
    </div>
  </div>
</section>
