---
import { NAVIGATION } from "@utils/navigation";
const waPhone = NAVIGATION.contact.phone.replace(/\D/g, "");
const waMsg = encodeURIComponent(
  "Hola BCP Consulting, me gustaría recibir una asesoría gratuita sobre software a medida para mi empresa."
);
const waUrl = `https://api.whatsapp.com/send/?phone=${waPhone}&text=${waMsg}`;
---

<!-- ===== STICKY BOTTOM BAR (mobile only) ===== -->
<div
  id="sticky-bar"
  class="fixed bottom-0 inset-x-0 z-50 md:hidden bg-white border-t border-gray-200 shadow-2xl"
  style="padding-bottom: env(safe-area-inset-bottom);"
  role="navigation"
  aria-label="Acciones de contacto rápido"
>
  <div class="flex items-stretch divide-x divide-gray-200">
    <!-- WhatsApp -->
    <a
      href={waUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex flex-col items-center justify-center gap-1 flex-1 min-h-14 px-2 py-3 text-green-600 hover:bg-green-50 active:bg-green-100 transition-colors duration-150 font-semibold"
      aria-label="Contactar por WhatsApp"
    >
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.115.554 4.103 1.523 5.83L.057 23.5l5.816-1.448A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.371l-.36-.214-3.726.927.972-3.618-.234-.371A9.818 9.818 0 1112 21.818z" />
      </svg>
      <span class="text-[11px] leading-none">WhatsApp</span>
    </a>

    <!-- Llamar -->
    <a
      href={`tel:${NAVIGATION.contact.phone}`}
      class="flex flex-col items-center justify-center gap-1 flex-1 min-h-14 px-2 py-3 text-primary-600 hover:bg-primary-50 active:bg-primary-100 transition-colors duration-150 font-semibold"
      aria-label={`Llamar al ${NAVIGATION.contact.phone}`}
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      <span class="text-[11px] leading-none">Llamar</span>
    </a>

    <!-- Cotizar (abre modal) -->
    <button
      type="button"
      id="sticky-cotizar-btn"
      data-open-modal="cotizar"
      class="flex flex-col items-center justify-center gap-1 flex-1 min-h-14 px-2 py-3 bg-primary-600 text-white hover:bg-primary-700 active:bg-primary-800 transition-colors duration-150 font-bold"
      aria-haspopup="dialog"
      aria-controls="modal-cotizar"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <span class="text-[11px] leading-none">Cotizar</span>
    </button>
  </div>
</div>

<!-- ===== MODAL COTIZAR ===== -->
<div
  id="modal-cotizar"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-cotizar-title"
  class="fixed inset-0 z-60 hidden items-end sm:items-center justify-center"
>
  <!-- Backdrop -->
  <div
    id="modal-backdrop"
    class="absolute inset-0 bg-black/60 backdrop-blur-sm"
    aria-hidden="true"
  ></div>

  <!-- Panel -->
  <div
    id="modal-panel"
    class="relative w-full sm:max-w-md bg-white rounded-t-3xl sm:rounded-2xl shadow-2xl overflow-hidden"
  >
    <!-- Header -->
    <div class="flex items-center justify-between px-6 pt-5 pb-3 bg-primary-700">
      <h2 id="modal-cotizar-title" class="text-lg font-bold text-white">
        Solicitar cotización gratuita
      </h2>
      <button
        type="button"
        id="modal-close-btn"
        class="p-2 rounded-full text-white/70 hover:text-white hover:bg-white/20 transition-colors focus-visible:ring-2 focus-visible:ring-white"
        aria-label="Cerrar modal"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Body -->
    <div class="px-6 py-5">
      <p class="text-sm text-gray-500 mb-5">
        Cuéntanos tu proyecto y te respondemos en menos de 24 horas hábiles.
      </p>

      <!-- Status message -->
      <div
        id="modal-status"
        role="status"
        aria-live="polite"
        aria-atomic="true"
        class="hidden mb-4 p-3 rounded-lg text-sm font-medium"
      ></div>

      <form id="modal-cotizar-form" novalidate class="flex flex-col gap-4">
        <!-- Nombre -->
        <div class="flex flex-col gap-1">
          <label for="modal-nombre" class="text-xs font-semibold text-gray-700">
            Nombre y apellido <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            id="modal-nombre"
            name="nombre"
            autocomplete="name"
            required
            aria-required="true"
            placeholder="Ej: Juan García"
            class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition"
          />
        </div>

        <!-- WhatsApp -->
        <div class="flex flex-col gap-1">
          <label for="modal-whatsapp" class="text-xs font-semibold text-gray-700">
            WhatsApp / Celular <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            type="tel"
            id="modal-whatsapp"
            name="whatsapp"
            autocomplete="tel"
            required
            aria-required="true"
            placeholder="Ej: 999 888 777"
            class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition"
          />
        </div>

        <!-- Email (opcional) -->
        <div class="flex flex-col gap-1">
          <label for="modal-email" class="text-xs font-semibold text-gray-700">
            Correo electrónico
            <span class="text-gray-400 font-normal">(opcional)</span>
          </label>
          <input
            type="email"
            id="modal-email"
            name="email"
            autocomplete="email"
            placeholder="empresa@ejemplo.com"
            class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition"
          />
        </div>

        <!-- Descripción -->
        <div class="flex flex-col gap-1">
          <label for="modal-proyecto" class="text-xs font-semibold text-gray-700">
            Describe brevemente tu proyecto <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <textarea
            id="modal-proyecto"
            name="proyecto"
            rows="3"
            required
            aria-required="true"
            placeholder="Ej: Necesito un sistema de inventarios para 3 almacenes con reportes en tiempo real."
            class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          id="modal-submit-btn"
          class="w-full py-3 rounded-xl bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold text-sm transition-colors focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 disabled:opacity-60 disabled:cursor-not-allowed"
        >
          Enviar solicitud
        </button>
      </form>

      <p class="mt-3 text-[11px] text-gray-400 text-center">
        Asesoría 100 % gratuita · Sin compromiso · RUC {NAVIGATION.contact.ruc}
      </p>
    </div>
  </div>
</div>

<script>
  // ===== Helpers =====
  function getFocusableElements(container: HTMLElement) {
    return Array.from(
      container.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
      )
    ).filter((el) => !el.hasAttribute("hidden") && el.offsetParent !== null);
  }

  // ===== Modal state =====
  const modal = document.getElementById("modal-cotizar") as HTMLElement;
  const backdrop = document.getElementById("modal-backdrop") as HTMLElement;
  const closeBtn = document.getElementById("modal-close-btn") as HTMLElement;
  let lastFocusedEl: HTMLElement | null = null;

  function openModal() {
    lastFocusedEl = document.activeElement as HTMLElement;
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    document.body.style.overflow = "hidden";
    // Focus first focusable element
    requestAnimationFrame(() => {
      const focusable = getFocusableElements(modal);
      if (focusable.length) focusable[0].focus();
    });
  }

  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.style.overflow = "";
    lastFocusedEl?.focus();
    // Reset form
    const form = document.getElementById("modal-cotizar-form") as HTMLFormElement | null;
    form?.reset();
    const status = document.getElementById("modal-status") as HTMLElement | null;
    if (status) { status.classList.add("hidden"); status.textContent = ""; }
  }

  // Open triggers: sticky bar btn + any [data-open-modal="cotizar"]
  document.querySelectorAll('[data-open-modal="cotizar"]').forEach((btn) => {
    btn.addEventListener("click", openModal);
  });

  // Close triggers
  closeBtn?.addEventListener("click", closeModal);
  backdrop?.addEventListener("click", closeModal);

  // ESC key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) {
      closeModal();
    }
  });

  // Focus trap
  modal?.addEventListener("keydown", (e) => {
    if (e.key !== "Tab") return;
    const focusable = getFocusableElements(modal);
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  });

  // ===== Form submission =====
  const form = document.getElementById("modal-cotizar-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("modal-submit-btn") as HTMLButtonElement | null;
  const statusEl = document.getElementById("modal-status") as HTMLElement | null;

  function showStatus(message: string, isError = false) {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.classList.remove("hidden", "bg-green-50", "text-green-700", "bg-red-50", "text-red-700");
    if (isError) {
      statusEl.classList.add("bg-red-50", "text-red-700");
    } else {
      statusEl.classList.add("bg-green-50", "text-green-700");
    }
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const nombre = (data.get("nombre") as string)?.trim();
    const whatsapp = (data.get("whatsapp") as string)?.trim();
    const proyecto = (data.get("proyecto") as string)?.trim();

    if (!nombre || !whatsapp || !proyecto) {
      showStatus("Por favor completa los campos obligatorios.", true);
      return;
    }

    submitBtn!.disabled = true;
    submitBtn!.textContent = "Enviando…";

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ nombre, whatsapp, email: data.get("email"), proyecto, origen: "landing-software-modal" }),
      });
      if (res.ok) {
        showStatus("¡Solicitud enviada! Te contactaremos en menos de 24 h hábiles.");
        form.reset();
      } else {
        throw new Error("server");
      }
    } catch {
      showStatus("Ocurrió un error al enviar. Por favor escríbenos por WhatsApp.", true);
    } finally {
      submitBtn!.disabled = false;
      submitBtn!.textContent = "Enviar solicitud";
    }
  });
</script>
