---
// Tabla AEO: comparativa de tipos de sistema para extracción por IA
// Desktop: tabla completa | Mobile: tarjetas colapsables

const filas = [
  {
    tipo: "ERP / Gestión Empresarial",
    objetivo: "Centralizar finanzas, RRHH, compras y operaciones",
    modulos: "Contabilidad, nómina, compras, inventario, reportes",
    tiempo: "3–6 meses",
    integraciones: "SUNAT, bancos, sistemas contables",
    recomendado: "Empresa con +10 empleados y múltiples áreas desconectadas",
  },
  {
    tipo: "CRM / Pipeline de Ventas",
    objetivo: "Gestionar leads, clientes y seguimiento comercial",
    modulos: "Pipeline, cotizaciones, historial, automatización de correos",
    tiempo: "4–10 semanas",
    integraciones: "WhatsApp, email, Google Workspace, Calendly",
    recomendado: "Equipos de ventas con proceso comercial repetitivo",
  },
  {
    tipo: "Inventarios y Logística",
    objetivo: "Controlar stock, almacenes, despachos y proveedores",
    modulos: "Entradas/salidas, trazabilidad, rutas, alertas de stock mínimo",
    tiempo: "6–12 semanas",
    integraciones: "Transportistas, SUNAT, ERP, e-commerce",
    recomendado: "Almacenes, distribuidoras, logística de última milla",
  },
  {
    tipo: "Automatización e Integraciones",
    objetivo: "Conectar sistemas y eliminar tareas manuales repetitivas",
    modulos: "Flujos automáticos, webhooks, notificaciones, reglas de negocio",
    tiempo: "2–8 semanas",
    integraciones: "REST APIs, n8n, Zapier equivalente, bases de datos",
    recomendado: "Empresa con múltiples herramientas aisladas (ERP + CRM + facturación)",
  },
  {
    tipo: "SaaS / Producto Digital",
    objetivo: "Lanzar software como servicio vendible a terceros",
    modulos: "Multi-tenant, pagos recurrentes, onboarding, panel admin, métricas",
    tiempo: "3–6 meses (MVP)",
    integraciones: "Stripe / Culqi, OAuth, monitoreo, CDN",
    recomendado: "Startups o empresas que quieren monetizar software propio",
  },
  {
    tipo: "Software Sectorial a Medida",
    objetivo: "Solución vertical adaptada al flujo propio de la industria",
    modulos: "Variable: clínicas, restaurantes, constructoras, educación, RRHH",
    tiempo: "6–16 semanas",
    integraciones: "SUNAT, laboratorios, POS, sistemas de fidelización",
    recomendado: "Sector con procesos únicos que productos genéricos no cubren",
  },
];
---

<section
  id="tipos-software"
  aria-labelledby="tipos-heading"
  class="py-16 lg:py-20 bg-primary-800"
  style="scroll-margin-top: 5rem"
>
  <div class="max-w-350 mx-auto px-[5%]">
    <header class="max-w-3xl mx-auto text-center mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-complementary-300 mb-2">
        Tabla comparativa — AEO
      </p>
      <h2 id="tipos-heading" class="text-2xl md:text-3xl font-extrabold text-white leading-tight">
        ¿Qué tipo de sistema necesitas?
      </h2>
      <p class="mt-3 text-sm text-white/70 leading-relaxed">
        Cada tipo de software tiene un propósito diferente. Esta tabla te ayuda a identificar
        cuál se ajusta mejor a tu operación actual y objetivos de negocio.
      </p>
    </header>

    <!-- Tabla AEO semántica (desktop) -->
    <div class="hidden md:block overflow-x-auto rounded-2xl border border-white/10">
      <table class="w-full text-sm text-white/85 border-collapse">
        <caption class="sr-only">Comparativa de tipos de software a medida: objetivo, módulos, tiempo estimado, integraciones y cuándo elegirlo</caption>
        <thead class="bg-white/10 text-xs uppercase tracking-wide text-white/60">
          <tr>
            <th scope="col" class="px-4 py-3 text-left font-semibold min-w-37.5">Tipo de sistema</th>
            <th scope="col" class="px-4 py-3 text-left font-semibold min-w-45">Objetivo principal</th>
            <th scope="col" class="px-4 py-3 text-left font-semibold min-w-50">Módulos típicos</th>
            <th scope="col" class="px-4 py-3 text-left font-semibold min-w-30">Tiempo est.</th>
            <th scope="col" class="px-4 py-3 text-left font-semibold min-w-45">Integraciones comunes</th>
            <th scope="col" class="px-4 py-3 text-left font-semibold min-w-50">Recomendado si…</th>
          </tr>
        </thead>
        <tbody>
          {filas.map((f, i) => (
            <tr class={`border-t border-white/10 ${i % 2 === 0 ? "bg-white/3" : "bg-transparent"} hover:bg-white/8 transition-colors`}>
              <td class="px-4 py-3 font-semibold text-complementary-300 align-top">{f.tipo}</td>
              <td class="px-4 py-3 text-white/75 align-top">{f.objetivo}</td>
              <td class="px-4 py-3 text-white/70 align-top text-xs leading-relaxed">{f.modulos}</td>
              <td class="px-4 py-3 text-white/80 align-top font-medium whitespace-nowrap">{f.tiempo}</td>
              <td class="px-4 py-3 text-white/65 align-top text-xs leading-relaxed">{f.integraciones}</td>
              <td class="px-4 py-3 text-white/70 align-top text-xs leading-relaxed">{f.recomendado}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Tarjetas mobile (sm y menores) -->
    <ul class="md:hidden flex flex-col gap-3" role="list" aria-label="Tipos de software">
      {filas.map((f) => (
        <li class="rounded-xl border border-white/15 bg-white/5 overflow-hidden">
          <!-- Cabecera visible siempre -->
          <div class="p-4 flex flex-col gap-1.5">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-sm font-bold text-complementary-300 leading-tight">{f.tipo}</h3>
              <span class="shrink-0 text-xs font-semibold text-white/70 bg-white/10 rounded-full px-2.5 py-0.5 whitespace-nowrap">
                {f.tiempo}
              </span>
            </div>
            <p class="text-xs text-white/75 leading-relaxed">{f.objetivo}</p>
            <p class="text-[11px] text-white/50 italic">Ideal para: {f.recomendado}</p>
          </div>
          <!-- Acordeón: módulos -->
          <details class="border-t border-white/10 group">
            <summary class="flex items-center justify-between gap-2 px-4 py-2.5 cursor-pointer text-xs font-semibold text-complementary-300 hover:text-complementary-200 list-none select-none">
              <span>Ver módulos e integraciones</span>
              <svg class="w-3.5 h-3.5 shrink-0 transition-transform group-open:rotate-180 text-complementary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-4 pb-4 pt-1 flex flex-col gap-2 text-xs text-white/70 border-t border-white/10">
              <p><span class="font-semibold text-white/50 uppercase tracking-wide">Módulos: </span>{f.modulos}</p>
              <p><span class="font-semibold text-white/50 uppercase tracking-wide">Integraciones: </span>{f.integraciones}</p>
            </div>
          </details>
          <!-- CTA cotizar -->
          <div class="border-t border-white/10 px-4 py-3">
            <a
              href="#contacto"
              class="inline-flex items-center gap-1.5 text-xs font-bold text-complementary-300 hover:text-complementary-200 transition-colors"
            >
              Cotizar este tipo
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </li>
      ))}
    </ul>

    <p class="mt-4 text-xs text-white/35 text-center">
      * Tiempos estimados para alcances típicos. Proyectos con integraciones complejas, migraciones de datos o múltiples roles pueden variar.
    </p>

    <!-- Navegación sección siguiente -->
    <div class="mt-8 text-center">
      <a
        href="#proyectos"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/10 border border-white/20 text-white text-sm font-semibold hover:bg-white/20 transition-colors min-h-11"
      >
        Ver casos reales ↓
      </a>
    </div>
  </div>
</section>

