---
import { NAVIGATION } from "@utils/navigation";

const waPhone = NAVIGATION.contact.phone.replace(/\D/g, "");
const waMsg = encodeURIComponent(
  "Hola BCP Consulting, vengo desde https://bcpconsulting.pe/landing-software/. Quiero asesorarme y solicitar una cotización para un proyecto de software a medida."
);

const incluyeAsesoria = [
  "Análisis de tus procesos actuales y necesidades",
  "Recomendación del tipo de software más adecuado",
  "Estimado de tiempos y presupuesto sin compromiso",
  "Evaluación de integraciones con sistemas existentes",
  "Roadmap de desarrollo por fases",
];
---

<section
  id="contacto"
  aria-labelledby="contacto-heading"
  class="relative py-16 lg:py-20 bg-primary-700 text-white overflow-hidden"
  style="scroll-margin-top: 5rem"
>
  <!-- Decoración de fondo -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[250px] bg-complementary-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-56 h-56 bg-secondary-500/10 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-350 mx-auto px-[5%]">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

      <!-- Columna izquierda: contacto + confianza -->
      <div class="flex flex-col gap-6">
        <header>
          <span class="inline-block px-3 py-1 rounded-full bg-white/10 border border-white/20 text-xs font-semibold uppercase tracking-widest text-white/90 mb-3">
            Da el siguiente paso
          </span>
          <h2 id="contacto-heading" class="text-2xl md:text-3xl font-extrabold text-white leading-tight">
            Hablemos de tu proyecto
          </h2>
          <p class="mt-3 text-sm text-white/75 leading-relaxed">
            Una asesoría gratuita de 30 min para entender tu caso y enviarte un
            alcance por fases sin compromiso. Respondemos en menos de 24 h.
          </p>
        </header>

        <!-- Botones de contacto directo -->
        <div class="flex flex-col gap-3">
          <a
            href={`https://api.whatsapp.com/send/?phone=${waPhone}&text=${waMsg}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-4 rounded-2xl bg-green-500 hover:bg-green-400 transition-colors shadow-md group"
          >
            <svg class="h-7 w-7 shrink-0 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.115.554 4.103 1.523 5.83L.057 23.5l5.816-1.448A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.371l-.36-.214-3.726.927.972-3.618-.234-.371A9.818 9.818 0 1112 21.818z" />
            </svg>
            <div class="text-left">
              <p class="text-xs text-white/75">Escríbenos directo</p>
              <p class="text-sm font-bold text-white">Hablar por WhatsApp — Respuesta rápida</p>
            </div>
            <svg class="ml-auto w-4 h-4 text-white/60 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>

          <div class="grid grid-cols-2 gap-3">
            <a
              href={`tel:${NAVIGATION.contact.phone}`}
              class="flex items-center gap-3 p-4 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/20 transition-colors group"
            >
              <svg class="h-5 w-5 shrink-0 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <div>
                <p class="text-[10px] text-white/60">Llamar ahora</p>
                <p class="text-xs font-bold text-white">{NAVIGATION.contact.phone}</p>
              </div>
            </a>
            <a
              href={`mailto:${NAVIGATION.contact.email}?subject=Cotización Software a Medida`}
              class="flex items-center gap-3 p-4 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/20 transition-colors group"
            >
              <svg class="h-5 w-5 shrink-0 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="text-[10px] text-white/60">Correo</p>
                <p class="text-xs font-bold text-white truncate">{NAVIGATION.contact.email}</p>
              </div>
            </a>
          </div>
        </div>

        <!-- ¿Qué incluye la asesoría? -->
        <div class="p-5 rounded-2xl bg-white/5 border border-white/10">
          <p class="text-xs font-semibold uppercase tracking-widest text-complementary-300 mb-3">¿Qué incluye la asesoría gratuita?</p>
          <ul class="flex flex-col gap-2" role="list">
            {incluyeAsesoria.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-white/75">
                <svg class="w-4 h-4 text-complementary-300 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Datos de confianza -->
        <div class="text-xs text-white/35 leading-relaxed">
          <p><strong class="text-white/60">BCP Consulting SAC</strong> · RUC: {NAVIGATION.contact.ruc}</p>
          <p>Lima, Perú · Atención Lun–Vie 9 am–6 pm PET</p>
          <p class="mt-1"><a href={`mailto:${NAVIGATION.contact.email}`} class="text-white/50 hover:text-white/80 transition-colors">{NAVIGATION.contact.email}</a></p>
        </div>
      </div>

      <!-- Columna derecha: formulario -->
      <div>
        <div class="bg-white/10 border border-white/20 backdrop-blur-sm rounded-2xl p-6 md:p-8">
          <h3 class="text-base font-bold text-white mb-1">Cotiza tu proyecto</h3>
          <p class="text-xs text-white/65 mb-5">Sin compromiso. Te enviamos alcance por fases en menos de 24 h.</p>

          <form
            id="cta-form"
            class="flex flex-col gap-3"
            action="#"
            method="post"
            novalidate
            aria-label="Formulario de cotización de software a medida"
          >
            <div class="flex flex-col gap-1">
              <label for="cta-nombre" class="text-xs font-medium text-white/80">
                Nombre <span aria-hidden="true" class="text-red-400">*</span>
              </label>
              <input
                id="cta-nombre"
                type="text"
                name="nombre"
                autocomplete="name"
                required
                aria-required="true"
                class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder:text-white/35 text-sm focus:outline-none focus:ring-2 focus:ring-complementary-400 focus:border-transparent transition"
              />
              <span id="cta-nombre-error" role="alert" class="hidden text-xs text-red-400"></span>
            </div>

            <div class="flex flex-col gap-1">
              <label for="cta-whatsapp" class="text-xs font-medium text-white/80">
                WhatsApp <span aria-hidden="true" class="text-red-400">*</span>
              </label>
              <input
                id="cta-whatsapp"
                type="tel"
                name="celular"
                autocomplete="tel"
                required
                aria-required="true"
                placeholder="+51 9XX XXX XXX"
                class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder:text-white/35 text-sm focus:outline-none focus:ring-2 focus:ring-complementary-400 focus:border-transparent transition"
              />
              <span id="cta-whatsapp-error" role="alert" class="hidden text-xs text-red-400"></span>
            </div>

            <div class="flex flex-col gap-1">
              <label for="cta-email" class="text-xs font-medium text-white/80">
                Correo <span class="text-white/40">(opcional)</span>
              </label>
              <input
                id="cta-email"
                type="email"
                name="email"
                autocomplete="email"
                class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder:text-white/35 text-sm focus:outline-none focus:ring-2 focus:ring-complementary-400 focus:border-transparent transition"
              />
            </div>

            <div class="flex flex-col gap-1">
              <label for="cta-proyecto" class="text-xs font-medium text-white/80">¿Qué necesitas desarrollar?</label>
              <textarea
                id="cta-proyecto"
                name="mensaje"
                rows="3"
                placeholder="Ej: sistema de inventarios para empresa con 3 almacenes, CRM para equipo de 10 vendedores…"
                class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder:text-white/35 text-sm focus:outline-none focus:ring-2 focus:ring-complementary-400 focus:border-transparent transition resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              id="cta-submit"
              class="w-full mt-1 px-6 py-3.5 rounded-full bg-complementary-500 hover:bg-complementary-400 text-white font-bold text-sm transition-colors duration-200 min-h-11 flex items-center justify-center gap-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-complementary-300"
            >
              <span id="cta-submit-text">Enviar — Asesoría Gratis</span>
              <svg id="cta-loading" class="hidden animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </button>

            <div id="cta-form-status" role="status" aria-live="polite" class="hidden text-xs text-center text-complementary-300 font-medium pt-1 bg-white/5 rounded-lg p-3"></div>
          </form>

          <p class="text-center text-[10px] text-white/30 mt-4 leading-tight">
            Al enviar este formulario aceptas que nos contactemos contigo.<br />
            Sin spam. Sin ventas forzadas.
          </p>
        </div>
      </div>
    </div>

    <!-- Back to top -->
    <div class="mt-12 text-center">
      <a
        href="#hero"
        class="inline-flex items-center gap-1.5 text-xs text-white/35 hover:text-white/60 transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
        </svg>
        Volver al inicio
      </a>
    </div>
  </div>
</section>

<script>
  const ctaForm = document.getElementById("cta-form") as HTMLFormElement | null;
  const ctaStatus = document.getElementById("cta-form-status");
  const ctaSubmitText = document.getElementById("cta-submit-text");
  const ctaLoading = document.getElementById("cta-loading");

  ctaForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!ctaForm.checkValidity()) {
      ctaForm.reportValidity();
      return;
    }

    if (ctaLoading) ctaLoading.classList.remove("hidden");
    if (ctaSubmitText) ctaSubmitText.textContent = "Enviando…";

    // Simular envío (reemplazar con integración real)
    await new Promise((r) => setTimeout(r, 1200));

    if (ctaLoading) ctaLoading.classList.add("hidden");
    if (ctaSubmitText) ctaSubmitText.textContent = "Enviar — Asesoría Gratis";
    if (ctaStatus) {
      ctaStatus.classList.remove("hidden");
      ctaStatus.textContent = "✓ Mensaje recibido. Te contactamos en menos de 24 h hábiles.";
    }
    ctaForm.reset();
  });
</script>
