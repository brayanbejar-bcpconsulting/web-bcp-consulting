---
// Sección H: Testimonios estructurados

const testimonios = [
  {
    nombre: "Carlos Meléndez",
    rol: "Gerente de Operaciones",
    empresa: "Empresa del sector logístico",
    sector: "Logística",
    implementacion: "Sistema de gestión de inventario y control de almacenes a medida",
    resultado: "Reducción del 40% en tiempo de gestión de inventario y control en tiempo real de stock",
    quote:
      "El sistema que nos desarrolló BCP Consulting redujo en un 40% los tiempos de gestión de inventario. Ahora tenemos control en tiempo real y menos errores en las entregas.",
    verificado: true,
  },
  {
    nombre: "Javier López",
    rol: "Director Académico",
    empresa: "Plataforma de educación en línea",
    sector: "Educación",
    implementacion: "Plataforma educativa con aulas virtuales y gestión de inscripciones",
    resultado: "Aumento del 30% en inscripciones gracias a la accesibilidad multi-dispositivo",
    quote:
      "Nos diseñaron una plataforma educativa con aulas virtuales. Lo mejor es que los alumnos pueden conectarse desde cualquier dispositivo y nuestras inscripciones aumentaron un 30%.",
    verificado: true,
  },
  {
    nombre: "Ana Rodríguez",
    rol: "Fundadora",
    empresa: "E-commerce B2C",
    sector: "Comercio electrónico",
    implementacion: "Tienda en línea con pasarela de pagos integrada y panel de pedidos",
    resultado: "Incremento en ventas online con pagos seguros integrados desde el primer mes",
    quote:
      "Necesitábamos una tienda en línea profesional y segura. El equipo entendió nuestras necesidades y en pocas semanas ya estábamos vendiendo más y con pagos totalmente integrados.",
    verificado: true,
  },
];
---

<section
  id="testimonios"
  aria-labelledby="testimonios-heading"
  class="py-16 lg:py-20 bg-theme-surface"
  style="scroll-margin-top: 5rem"
>
  <div class="max-w-350 mx-auto px-[5%]">
    <header class="max-w-2xl mx-auto text-center mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-secondary-500 dark:text-secondary-400 mb-2">
        Lo que dicen nuestros clientes
      </p>
      <h2 id="testimonios-heading" class="text-2xl md:text-3xl font-extrabold text-theme-heading leading-tight">
        Resultados reales de nuestros clientes
      </h2>
      <p class="mt-3 text-sm text-theme-muted leading-relaxed">
        No solo ejecutamos proyectos: ayudamos a resolver problemas reales de negocio.
      </p>
    </header>

    <!-- Testimonios principales (2 visibles) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {testimonios.slice(0, 2).map((t) => (
        <article
          class="flex flex-col gap-4 p-5 rounded-2xl border border-theme-border bg-theme-page hover:border-secondary-300 dark:hover:border-secondary-700 transition-colors"
          aria-label={`Testimonio de ${t.nombre}`}
        >
          <blockquote class="flex-1">
            <p class="text-sm text-theme-muted leading-relaxed italic">"{t.quote}"</p>
          </blockquote>
          <div class="flex flex-col gap-1.5 text-xs border-t border-theme-border pt-3">
            <div>
              <span class="font-semibold text-theme-muted/60 uppercase tracking-wide">Implementación:</span>
              <span class="text-theme-muted ml-1">{t.implementacion}</span>
            </div>
            <div>
              <span class="font-semibold text-secondary-600 dark:text-secondary-400 uppercase tracking-wide">Resultado:</span>
              <span class="text-theme-muted ml-1 font-medium">{t.resultado}</span>
            </div>
          </div>
          <footer class="flex items-center gap-3 border-t border-theme-border pt-3">
            <div
              class="w-9 h-9 rounded-full bg-secondary-100 dark:bg-secondary-900/40 border border-secondary-200 dark:border-secondary-800 flex items-center justify-center text-sm font-bold text-secondary-700 dark:text-secondary-300 shrink-0"
              aria-hidden="true"
            >
              {t.nombre.charAt(0)}
            </div>
            <div>
              <p class="text-xs font-bold text-theme-heading">{t.nombre}</p>
              <p class="text-[10px] text-theme-muted">{t.rol} · {t.empresa}</p>
            </div>
            {t.verificado && (
              <span class="ml-auto text-[10px] px-1.5 py-0.5 rounded bg-green-500/10 text-green-600 dark:text-green-400 font-semibold border border-green-500/20">
                Verificado
              </span>
            )}
          </footer>
        </article>
      ))}
    </div>

    <!-- Acordeón: ver testimonio adicional -->
    {testimonios.length > 2 && (
      <details class="mt-4 group rounded-2xl border border-theme-border bg-theme-page overflow-hidden">
        <summary class="flex items-center justify-between gap-3 cursor-pointer px-5 py-4 text-sm font-semibold text-theme-heading list-none select-none hover:bg-theme-surface transition-colors">
          <span>Ver {testimonios.length - 2} testimonio{testimonios.length - 2 > 1 ? "s" : ""} más</span>
          <svg class="w-4 h-4 shrink-0 transition-transform group-open:rotate-180 text-theme-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-4 pb-4 pt-2 border-t border-theme-border grid grid-cols-1 md:grid-cols-2 gap-4">
          {testimonios.slice(2).map((t) => (
            <article
              class="flex flex-col gap-4 p-4 rounded-xl border border-theme-border bg-theme-surface hover:border-secondary-300 dark:hover:border-secondary-700 transition-colors"
              aria-label={`Testimonio de ${t.nombre}`}
            >
              <blockquote class="flex-1">
                <p class="text-sm text-theme-muted leading-relaxed italic">"{t.quote}"</p>
              </blockquote>
              <div class="flex flex-col gap-1.5 text-xs border-t border-theme-border pt-3">
                <div>
                  <span class="font-semibold text-theme-muted/60 uppercase tracking-wide">Implementación:</span>
                  <span class="text-theme-muted ml-1">{t.implementacion}</span>
                </div>
                <div>
                  <span class="font-semibold text-secondary-600 dark:text-secondary-400 uppercase tracking-wide">Resultado:</span>
                  <span class="text-theme-muted ml-1 font-medium">{t.resultado}</span>
                </div>
              </div>
              <footer class="flex items-center gap-3 border-t border-theme-border pt-3">
                <div class="w-9 h-9 rounded-full bg-secondary-100 dark:bg-secondary-900/40 border border-secondary-200 dark:border-secondary-800 flex items-center justify-center text-sm font-bold text-secondary-700 dark:text-secondary-300 shrink-0" aria-hidden="true">
                  {t.nombre.charAt(0)}
                </div>
                <div>
                  <p class="text-xs font-bold text-theme-heading">{t.nombre}</p>
                  <p class="text-[10px] text-theme-muted">{t.rol} · {t.empresa}</p>
                </div>
                {t.verificado && (
                  <span class="ml-auto text-[10px] px-1.5 py-0.5 rounded bg-green-500/10 text-green-600 dark:text-green-400 font-semibold border border-green-500/20">Verificado</span>
                )}
              </footer>
            </article>
          ))}
        </div>
      </details>
    )}

    <p class="mt-5 text-xs text-theme-muted/50 text-center">
      * Testimonios recopilados directamente de nuestros clientes con su consentimiento.
      Los resultados pueden variar según el alcance y contexto de cada proyecto.
    </p>

    <!-- Navegación sección siguiente -->
    <div class="mt-8 text-center">
      <a
        href="#faq"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-secondary-100 dark:bg-secondary-900/30 border border-secondary-300 dark:border-secondary-700 text-secondary-700 dark:text-secondary-300 text-sm font-semibold hover:bg-secondary-200 dark:hover:bg-secondary-900/50 transition-colors min-h-11"
      >
        Preguntas frecuentes ↓
      </a>
    </div>
  </div>
</section>

