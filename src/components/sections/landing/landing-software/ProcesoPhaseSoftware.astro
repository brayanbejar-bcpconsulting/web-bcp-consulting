---
const fases = [
  {
    numero: "01",
    nombre: "Descubrimiento",
    duracion: "1–2 semanas",
    descripcion: "Entendemos tu operación, objetivos y usuarios. Documentamos requerimientos funcionales y no funcionales.",
    entregables: [
      "Documento de requerimientos (BRD)",
      "Mapa de procesos actuales",
      "Análisis de stakeholders",
      "Informe de factibilidad técnica",
    ],
    color: "border-blue-500/40 bg-blue-500/5",
    numColor: "text-blue-400",
  },
  {
    numero: "02",
    nombre: "Alcance y Backlog",
    duracion: "1 semana",
    descripcion: "Priorizamos funcionalidades con criterios de valor y esfuerzo. Definimos el MVP y las fases de entrega.",
    entregables: [
      "Product backlog priorizado",
      "Roadmap por fases (MVP → Completo)",
      "Estimación de tiempos y costos por módulo",
      "Propuesta formal de desarrollo",
    ],
    color: "border-purple-500/40 bg-purple-500/5",
    numColor: "text-purple-400",
  },
  {
    numero: "03",
    nombre: "Diseño UX/UI",
    duracion: "1–3 semanas",
    descripcion: "Diseñamos flujos de usuario, wireframes de baja fidelidad y prototipos interactivos antes de codificar.",
    entregables: [
      "Wireframes de pantallas principales",
      "Prototipo interactivo en Figma",
      "Design system / guía de estilo",
      "Validación con usuario final",
    ],
    color: "border-complementary-500/40 bg-complementary-500/5",
    numColor: "text-complementary-400",
  },
  {
    numero: "04",
    nombre: "Desarrollo",
    duracion: "Variable según módulos",
    descripcion: "Desarrollo iterativo en sprints de 1–2 semanas. Acceso a demo en tiempo real con cada entrega.",
    entregables: [
      "Código fuente con control de versiones (Git)",
      "Demo funcional por sprint",
      "Documentación técnica de APIs",
      "Acceso al entorno de staging",
    ],
    color: "border-green-500/40 bg-green-500/5",
    numColor: "text-green-400",
  },
  {
    numero: "05",
    nombre: "QA y Pruebas",
    duracion: "1–2 semanas",
    descripcion: "Pruebas funcionales, de carga, seguridad y usabilidad. Corrección de bugs antes del lanzamiento.",
    entregables: [
      "Reporte de pruebas funcionales",
      "Pruebas de regresión automatizadas",
      "Informe de seguridad básico",
      "Lista de bugs resueltos",
    ],
    color: "border-orange-500/40 bg-orange-500/5",
    numColor: "text-orange-400",
  },
  {
    numero: "06",
    nombre: "Despliegue (Deploy)",
    duracion: "2–5 días",
    descripcion: "Publicamos en producción con pipeline CI/CD, configuración de dominio, HTTPS y monitoreo activo.",
    entregables: [
      "Sistema en producción (URL final)",
      "Configuración de backups automáticos",
      "Panel de monitoreo configurado",
      "Manual de administrador",
    ],
    color: "border-teal-500/40 bg-teal-500/5",
    numColor: "text-teal-400",
  },
  {
    numero: "07",
    nombre: "Soporte y Evolución",
    duracion: "Continuo (plan mensual)",
    descripcion: "Soporte post-lanzamiento, correcciones, mejoras y evolución del sistema según el crecimiento del negocio.",
    entregables: [
      "SLA de respuesta definido (según plan)",
      "Actualizaciones de seguridad",
      "Nuevas funcionalidades por sprint",
      "Reportes mensuales de rendimiento",
    ],
    color: "border-rose-500/40 bg-rose-500/5",
    numColor: "text-rose-400",
  },
];
---

<section
  id="proceso"
  aria-labelledby="proceso-heading"
  class="py-16 lg:py-20 bg-theme-surface"
  style="scroll-margin-top: 5rem"
>
  <div class="max-w-350 mx-auto px-[5%]">
    <header class="max-w-2xl mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-secondary-500 dark:text-secondary-400 mb-2">
        Proceso de trabajo
      </p>
      <h2 id="proceso-heading" class="text-2xl md:text-3xl font-extrabold text-theme-heading leading-tight">
        Proceso real y entregables por fase
      </h2>
      <p class="mt-3 text-sm text-theme-muted leading-relaxed">
        No trabajamos en caja negra. Cada fase tiene objetivos claros, entregables concretos
        y puntos de revisión con el cliente antes de avanzar.
      </p>
    </header>

    <!-- Fases principales visibles (Descubrimiento, Desarrollo, Deploy) -->
    <ol class="relative flex flex-col gap-0" aria-label="Fases principales del proceso">
      {[fases[0], fases[3], fases[5]].map((fase, i) => (
        <li class={`relative flex gap-4 md:gap-6 pb-8 last:pb-0`}>
          {i < 2 && (
            <div class="absolute left-6 md:left-7 top-14 bottom-0 w-px bg-white/10 dark:bg-white/10" aria-hidden="true"></div>
          )}
          <div class={`shrink-0 w-12 h-12 md:w-14 md:h-14 rounded-2xl border-2 ${fase.color} flex items-center justify-center z-10`}>
            <span class={`text-xs font-mono font-bold ${fase.numColor}`}>{fase.numero}</span>
          </div>
          <div class={`flex-1 p-4 md:p-5 rounded-2xl border ${fase.color}`}>
            <div class="flex flex-wrap items-start gap-2 mb-2">
              <h3 class="text-sm md:text-base font-bold text-theme-heading leading-snug">{fase.nombre}</h3>
              <span class="ml-auto text-xs text-theme-muted bg-theme-page px-2 py-0.5 rounded-full border border-theme-border whitespace-nowrap">
                {fase.duracion}
              </span>
            </div>
            <p class="text-sm text-theme-muted leading-relaxed mb-3">{fase.descripcion}</p>
            <details class="group">
              <summary class="cursor-pointer text-xs font-semibold text-secondary-600 dark:text-secondary-400 hover:underline list-none flex items-center gap-1">
                <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                Ver entregables ({fase.entregables.length})
              </summary>
              <ul class="mt-2 flex flex-col gap-1.5 pl-2" role="list">
                {fase.entregables.map((e) => (
                  <li class="flex items-start gap-2 text-xs text-theme-muted">
                    <svg class="w-3.5 h-3.5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {e}
                  </li>
                ))}
              </ul>
            </details>
          </div>
        </li>
      ))}
    </ol>

    <!-- Acordeón: ver proceso completo (pasos 02, 03, 04, 05, 07) -->
    <details
      id="proceso-completo-details"
      class="mt-6 group rounded-2xl border border-theme-border bg-theme-page overflow-hidden"
    >
      <summary
        class="flex items-center justify-between gap-3 cursor-pointer px-5 py-4 text-sm font-semibold text-theme-heading list-none select-none hover:bg-theme-surface transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-secondary-500"
        aria-expanded="false"
      >
        <span>Ver proceso completo — 7 fases y todos los entregables</span>
        <svg class="w-4 h-4 shrink-0 transition-transform group-open:rotate-180 text-theme-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      <div class="px-5 pb-5 pt-3 border-t border-theme-border">
        <ol class="relative flex flex-col gap-0" aria-label="Fases completas del proceso">
          {[fases[1], fases[2], fases[4], fases[6]].map((fase, i, arr) => (
            <li class="relative flex gap-4 md:gap-6 pb-6 last:pb-0">
              {i < arr.length - 1 && (
                <div class="absolute left-6 md:left-7 top-14 bottom-0 w-px bg-theme-border" aria-hidden="true"></div>
              )}
              <div class={`shrink-0 w-12 h-12 md:w-14 md:h-14 rounded-2xl border-2 ${fase.color} flex items-center justify-center z-10`}>
                <span class={`text-xs font-mono font-bold ${fase.numColor}`}>{fase.numero}</span>
              </div>
              <div class={`flex-1 p-4 md:p-5 rounded-2xl border ${fase.color}`}>
                <div class="flex flex-wrap items-start gap-2 mb-2">
                  <h4 class="text-sm md:text-base font-bold text-theme-heading leading-snug">{fase.nombre}</h4>
                  <span class="ml-auto text-xs text-theme-muted bg-theme-page px-2 py-0.5 rounded-full border border-theme-border whitespace-nowrap">{fase.duracion}</span>
                </div>
                <p class="text-sm text-theme-muted leading-relaxed mb-3">{fase.descripcion}</p>
                <details class="group">
                  <summary class="cursor-pointer text-xs font-semibold text-secondary-600 dark:text-secondary-400 hover:underline list-none flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                    Ver entregables ({fase.entregables.length})
                  </summary>
                  <ul class="mt-2 flex flex-col gap-1.5 pl-2" role="list">
                    {fase.entregables.map((e) => (
                      <li class="flex items-start gap-2 text-xs text-theme-muted">
                        <svg class="w-3.5 h-3.5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                        {e}
                      </li>
                    ))}
                  </ul>
                </details>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </details>

    <!-- Nota de propiedad -->
    <div class="mt-8 p-4 rounded-xl bg-primary-50 dark:bg-white/5 border border-primary-200 dark:border-white/10">
      <p class="text-xs text-theme-muted leading-relaxed">
        <strong class="text-theme-heading">Propiedad del código:</strong> una vez entregado el proyecto y completado el pago,
        el código fuente y todos los activos digitales son 100% de tu empresa. Sin licencias adicionales ni dependencia de BCP Consulting para operar.
      </p>
    </div>

    <!-- Navegación sección siguiente -->
    <div class="mt-8 text-center">
      <a
        href="#proyectos"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-secondary-100 dark:bg-secondary-900/30 border border-secondary-300 dark:border-secondary-700 text-secondary-700 dark:text-secondary-300 text-sm font-semibold hover:bg-secondary-200 dark:hover:bg-secondary-900/50 transition-colors min-h-11"
      >
        Ver proyectos reales ↓
      </a>
    </div>
  </div>
</section>
