---
// Sección E: Mini casos — evidencia EEAT

const casos = [
  {
    cliente: "Izajes Massimo",
    sector: "Industrial · Logística de izajes",
    contexto: "Empresa de operaciones con izajes y maniobras pesadas en Lima, con gestión dispersa en hojas de cálculo y WhatsApp.",
    problema: "Sin visibilidad en tiempo real del estado de equipos, personal en campo y proyectos activos. Reportes tardaban días.",
    solucion: "Plataforma web de gestión operativa: control de equipos, asignación de personal, seguimiento de proyectos y generación automática de reportes.",
    stack: "React · Node.js · PostgreSQL · AWS",
    tiempo: "12 semanas",
    kpi: [
      "Reportes de estado generados al instante (antes: 2–3 días)",
      "Reducción del 60% en llamadas de coordinación interna",
      "Control centralizado de +40 equipos activos",
    ],
    url: "https://izajesmassimo.com/",
    esReal: true,
  },
  {
    cliente: "Aquaia SAC",
    sector: "Servicios acuáticos · RRHH",
    contexto: "Empresa de soluciones acuáticas con múltiples proyectos simultáneos, clientes corporativos y administración en Excel.",
    problema: "Dificultad para hacer seguimiento de proyectos, historial de clientes y estados de cotización sin una herramienta unificada.",
    solucion: "Sistema integral con CRM, gestión de proyectos, panel administrativo y reportes por cliente con acceso por roles.",
    stack: "Vue.js · NestJS · MongoDB · Firebase",
    tiempo: "10 semanas",
    kpi: [
      "Visibilidad completa del pipeline de proyectos",
      "Historial de cliente accesible en segundos",
      "Eliminación total de hojas de cálculo para gestión de proyectos",
    ],
    url: "https://aquaiasac.com/",
    esReal: true,
  },
  {
    cliente: "Market Dollar",
    sector: "Fintech · Casa de cambio digital",
    contexto: "Startup peruana que operaba como casa de cambio con procesos manuales y sin panel de control en tiempo real.",
    problema: "Riesgo operativo por falta de trazabilidad en transacciones y ausencia de controles por rol de usuario.",
    solucion: "Plataforma fintech con panel de transacciones en tiempo real, gestión de tipo de cambio, roles de acceso y reportes financieros.",
    stack: "Next.js · Spring Boot · PostgreSQL · Cloudflare",
    tiempo: "14 semanas",
    kpi: [
      "Trazabilidad del 100% de transacciones desde el primer día",
      "Tiempo de cierre diario reducido de 2 h a 15 min",
      "Cumplimiento de controles internos para auditoría",
    ],
    url: null,
    esReal: true,
  },
];
---

<section
  id="proyectos"
  aria-labelledby="proyectos-heading"
  class="py-16 lg:py-20 bg-primary-800"
  style="scroll-margin-top: 5rem"
>
  <div class="max-w-350 mx-auto px-[5%]">
    <header class="max-w-2xl mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-complementary-300 mb-2">
        Evidencia — Casos reales
      </p>
      <h2 id="proyectos-heading" class="text-2xl md:text-3xl font-extrabold text-white leading-tight">
        Proyectos entregados y sus resultados
      </h2>
      <p class="mt-3 text-sm text-white/70 leading-relaxed">
        Cada proyecto parte de un problema real. Aquí mostramos el contexto, la solución técnica
        y los KPIs medibles obtenidos.
      </p>
    </header>

    <!-- Caso principal (siempre visible) -->
    {(() => {
      const c = casos[0];
      return (
        <article
          class="rounded-2xl border border-white/15 bg-white/5 overflow-hidden"
          aria-label={`Caso de estudio: ${c.cliente}`}
        >
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-0">
            <div class="lg:col-span-2 p-5 md:p-6 flex flex-col gap-4">
              <header>
                <div class="flex flex-wrap items-center gap-2 mb-1">
                  <h3 class="text-base font-bold text-white">{c.cliente}</h3>
                  {c.esReal && (
                    <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-green-500/15 text-green-400 border border-green-500/20">
                      Caso real
                    </span>
                  )}
                </div>
                <p class="text-xs text-white/50 uppercase tracking-wide">{c.sector}</p>
              </header>
              <dl class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs">
                <div><dt class="font-semibold text-white/50 uppercase tracking-wide mb-0.5">Contexto</dt><dd class="text-white/75 leading-relaxed">{c.contexto}</dd></div>
                <div><dt class="font-semibold text-white/50 uppercase tracking-wide mb-0.5">Problema</dt><dd class="text-white/75 leading-relaxed">{c.problema}</dd></div>
                <div><dt class="font-semibold text-white/50 uppercase tracking-wide mb-0.5">Solución</dt><dd class="text-white/75 leading-relaxed">{c.solucion}</dd></div>
              </dl>
              <div class="flex flex-wrap items-center gap-4 pt-3 border-t border-white/10">
                <div><p class="text-[10px] text-white/40 uppercase tracking-wide mb-0.5">Stack</p><p class="text-xs font-mono text-complementary-300">{c.stack}</p></div>
                <div><p class="text-[10px] text-white/40 uppercase tracking-wide mb-0.5">Tiempo</p><p class="text-xs font-semibold text-white">{c.tiempo}</p></div>
                {c.url && <a href={c.url} target="_blank" rel="noopener noreferrer" class="ml-auto text-xs font-semibold text-complementary-300 hover:underline transition-colors">Ver proyecto →</a>}
              </div>
              <!-- CTA caso principal -->
              <div class="pt-1">
                <button
                  type="button"
                  data-open-modal="cotizar"
                  aria-haspopup="dialog"
                  aria-controls="modal-cotizar"
                  class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-complementary-500 hover:bg-complementary-400 text-white font-bold text-sm transition-colors min-h-11"
                >
                  Quiero algo similar
                </button>
              </div>
            </div>
            <div class="lg:border-l border-t lg:border-t-0 border-white/10 p-5 md:p-6 bg-white/3 flex flex-col gap-3">
              <p class="text-[10px] font-semibold uppercase tracking-widest text-complementary-300 mb-1">Resultados medibles</p>
              <ul class="flex flex-col gap-2.5" role="list">
                {c.kpi.map((k) => (
                  <li class="flex items-start gap-2 text-xs text-white/75 leading-relaxed">
                    <svg class="w-3.5 h-3.5 text-complementary-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {k}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </article>
      );
    })()}

    <!-- Acordeón: ver 2 casos más -->
    <details class="mt-4 group rounded-2xl border border-white/15 bg-white/5 overflow-hidden">
      <summary class="flex items-center justify-between gap-3 cursor-pointer px-5 py-4 text-sm font-semibold text-white/80 hover:text-white list-none select-none">
        <span>Ver 2 casos más</span>
        <svg class="w-4 h-4 shrink-0 transition-transform group-open:rotate-180 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      <div class="px-3 pb-4 pt-2 border-t border-white/10 flex flex-col gap-4">
        {casos.slice(1).map((c) => (
          <article
            class="rounded-xl border border-white/10 bg-white/3 overflow-hidden"
            aria-label={`Caso de estudio: ${c.cliente}`}
          >
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-0">
              <div class="lg:col-span-2 p-4 md:p-5 flex flex-col gap-3">
                <header>
                  <div class="flex flex-wrap items-center gap-2 mb-0.5">
                    <h3 class="text-sm font-bold text-white">{c.cliente}</h3>
                    {c.esReal && (
                      <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-green-500/15 text-green-400 border border-green-500/20">Caso real</span>
                    )}
                  </div>
                  <p class="text-xs text-white/50 uppercase tracking-wide">{c.sector}</p>
                </header>
                <dl class="grid grid-cols-1 sm:grid-cols-3 gap-2 text-xs">
                  <div><dt class="font-semibold text-white/50 uppercase tracking-wide mb-0.5">Contexto</dt><dd class="text-white/70 leading-relaxed">{c.contexto}</dd></div>
                  <div><dt class="font-semibold text-white/50 uppercase tracking-wide mb-0.5">Problema</dt><dd class="text-white/70 leading-relaxed">{c.problema}</dd></div>
                  <div><dt class="font-semibold text-white/50 uppercase tracking-wide mb-0.5">Solución</dt><dd class="text-white/70 leading-relaxed">{c.solucion}</dd></div>
                </dl>
                <div class="flex flex-wrap items-center gap-4 pt-3 border-t border-white/10">
                  <div><p class="text-[10px] text-white/40 uppercase tracking-wide mb-0.5">Stack</p><p class="text-xs font-mono text-complementary-300">{c.stack}</p></div>
                  <div><p class="text-[10px] text-white/40 uppercase tracking-wide mb-0.5">Tiempo</p><p class="text-xs font-semibold text-white">{c.tiempo}</p></div>
                  {c.url && <a href={c.url} target="_blank" rel="noopener noreferrer" class="ml-auto text-xs font-semibold text-complementary-300 hover:underline transition-colors">Ver proyecto →</a>}
                </div>
                <button
                  type="button"
                  data-open-modal="cotizar"
                  aria-haspopup="dialog"
                  aria-controls="modal-cotizar"
                  class="mt-1 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-complementary-500/20 hover:bg-complementary-500/30 text-complementary-300 border border-complementary-500/30 font-semibold text-xs transition-colors min-h-10"
                >
                  Quiero algo similar
                </button>
              </div>
              <div class="lg:border-l border-t lg:border-t-0 border-white/10 p-4 md:p-5 bg-white/3 flex flex-col gap-2">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-complementary-300 mb-0.5">Resultados medibles</p>
                <ul class="flex flex-col gap-2" role="list">
                  {c.kpi.map((k) => (
                    <li class="flex items-start gap-2 text-xs text-white/70 leading-relaxed">
                      <svg class="w-3.5 h-3.5 text-complementary-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                      {k}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </details>

    <p class="mt-6 text-xs text-white/30 text-center">
      * Los KPIs presentados corresponden a resultados reales reportados por los clientes
      o medidos durante el período de entrega. Resultados pueden variar según el alcance de cada proyecto.
    </p>

    <!-- Navegación sección siguiente -->
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a
        href="#estimacion"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/10 border border-white/20 text-white text-sm font-semibold hover:bg-white/20 transition-colors min-h-11"
      >
        Ver precios ↓
      </a>
      <button
        type="button"
        data-open-modal="cotizar"
        aria-haspopup="dialog"
        aria-controls="modal-cotizar"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-complementary-500 hover:bg-complementary-400 text-white text-sm font-bold transition-colors min-h-11"
      >
        Ir a cotizar ↓
      </button>
    </div>
  </div>
</section>
