---
import { CLIENTS } from "@data/clients";
---

<section class="logo-slider bg-primary-600" aria-label="Nuestros clientes">
  <div class="logo-slide-track">
    {/* Primera lista */}
    {
      CLIENTS.map((client) => (
        <a
          href={client.url !== "#" ? client.url : undefined}
          target={client.url !== "#" ? "_blank" : undefined}
          rel={client.url !== "#" ? "noopener noreferrer" : undefined}
          class="logo-item"
          aria-label={
            client.url !== "#" ? `Visitar ${client.name}` : client.name
          }
        >
          <img
            src={client.image}
            alt={client.name}
            loading="lazy"
            width="180"
            height="90"
          />
        </a>
      ))
    }
    {/* Segunda lista (duplicada para el efecto infinito sin cortes) */}
    {
      CLIENTS.map((client) => (
        <a
          href={client.url !== "#" ? client.url : undefined}
          target={client.url !== "#" ? "_blank" : undefined}
          rel={client.url !== "#" ? "noopener noreferrer" : undefined}
          class="logo-item"
          aria-label={
            client.url !== "#" ? `Visitar ${client.name}` : client.name
          }
          aria-hidden="true"
        >
          <img
            src={client.image}
            alt={client.name}
            loading="lazy"
            width="180"
            height="90"
          />
        </a>
      ))
    }
  </div>
</section>

<style>
  @reference "../../../styles/global.css";

  .logo-slider {
    @apply py-8 lg:py-12 overflow-hidden w-full;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
  }

  .logo-slide-track {
    @apply flex w-max gap-4 md:gap-8;
    animation: scrollInfinite 40s linear infinite;
  }

  .logo-slider:hover .logo-slide-track {
    animation-play-state: paused;
  }

  .logo-item {
    @apply shrink-0 w-[140px] h-[70px] md:w-[180px] md:h-[90px] flex items-center justify-center p-3 md:p-5;
    @apply border border-white/5 rounded-xl bg-white/5;
    @apply transition-all duration-300 ease-out;
  }

  .logo-item img {
    @apply max-w-full max-h-full object-contain;
    filter: grayscale(100%) opacity(0.7);
    transition: all 0.3s ease;
  }

  /* Usando hover para interactividad */
  .logo-item:hover {
    @apply border-secondary-500/50 bg-secondary-500/5 -translate-y-1;
  }

  .logo-item:hover img {
    filter: grayscale(0%) opacity(1);
    transform: scale(1.1);
  }

  @keyframes scrollInfinite {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Se desplaza exactamente a la mitad porque hay 2 listas idénticas unidas, cada una ocupa 50% del total de .logo-slide-track */
      transform: translateX(-50%);
    }
  }
</style>
