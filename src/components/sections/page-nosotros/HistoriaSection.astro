---
import { MainContainer, StatCounter } from "@components";
import { COMPANY_INFO, COMPANY_STATS } from "@data/team";
---

<MainContainer
  id="historia"
  bgColor="bg-theme-surface"
  ariaLabelledby="historia-titulo"
>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="flex flex-col gap-6">
      <h2 id="historia-titulo" class="text-theme-heading">Quiénes Somos</h2>
      <p class="text-theme-base text-lg leading-relaxed">
        {COMPANY_INFO.about}
      </p>
      <p class="text-theme-muted leading-relaxed">
        Entendemos que cada organización tiene procesos únicos, y por ello
        ofrecemos soluciones digitales personalizadas que ayudan a mejorar la
        productividad, optimizar recursos y generar más ventas.
      </p>
      <p class="text-theme-muted leading-relaxed">
        Trabajamos con empresas pequeñas, medianas y startups en sectores como
        salud, finanzas, educación, logística, retail y más.
      </p>
    </div>
    <div class="grid grid-cols-2 gap-8">
      {
        COMPANY_STATS.map((stat) => (
          <StatCounter
            value={stat.value}
            label={stat.label}
            suffix={stat.suffix}
          />
        ))
      }
    </div>
  </div>
</MainContainer>
