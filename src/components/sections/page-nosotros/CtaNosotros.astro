---
import { Button } from "@components";
---

<section class="cta-nosotros" aria-label="Llamada a la acción nosotros">
  <div class="cta-nosotros__container">
    <h2 class="cta-nosotros__title">Conéctate con Nosotros</h2>
    <p class="cta-nosotros__desc">
      Estamos listos para escucharte. Cuéntanos sobre tu negocio y juntos
      encontraremos la solución tecnológica que necesitas.
    </p>
    <div class="flex flex-col sm:flex-row items-center gap-4 mt-2">
      <Button href="/contacto" variant="secondary" size="lg">
        Ir a Contacto
      </Button>
      <Button
        href="https://api.whatsapp.com/send/?phone=51929772711&text=Hola%2C%20quiero%20conocer%20m%C3%A1s%20sobre%20BCP%20Consulting"
        target="_blank"
        variant="whatsapp"
        size="lg"
        icon="whatsapp"
      >
        WhatsApp
      </Button>
    </div>
  </div>
</section>

<style>
  @reference "../../../styles/global.css";

  .cta-nosotros {
    @apply py-20 lg:py-28 px-[5%];
    background: linear-gradient(
      135deg,
      var(--color-primary-950),
      var(--color-complementary-900)
    );
  }

  .cta-nosotros__container {
    @apply max-w-200 mx-auto text-center flex flex-col items-center gap-6;
  }

  .cta-nosotros__title {
    @apply text-white font-extrabold text-balance;
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.8rem);
  }

  .cta-nosotros__desc {
    @apply text-white/80 text-lg max-w-xl leading-relaxed;
  }
</style>
