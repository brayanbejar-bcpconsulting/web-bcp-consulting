---
import Icon from "@components/ui/Icon.astro";

interface Props {
  problemTitle?: string;
  solutionTitle?: string;
}

const {
  problemTitle = "El Reto",
  solutionTitle = "Nuestra Solución",
} = Astro.props;
---

<section class="problem-solution" aria-label="Problema y solución del proyecto">
  <!-- Columna Problema -->
  <article class="ps-col ps-col--problem">
    <header class="ps-col__header">
      <div class="ps-col__icon" aria-hidden="true">
        <Icon name="alert-triangle" size={22} />
      </div>
      <h3 class="ps-col__heading">{problemTitle}</h3>
    </header>
    <div class="ps-col__content">
      <slot name="problem" />
    </div>
  </article>

  <!-- Columna Solución -->
  <article class="ps-col ps-col--solution">
    <header class="ps-col__header">
      <div class="ps-col__icon" aria-hidden="true">
        <Icon name="check-circle" size={22} />
      </div>
      <h3 class="ps-col__heading">{solutionTitle}</h3>
    </header>
    <div class="ps-col__content">
      <slot name="solution" />
    </div>
  </article>
</section>

<style>
  @reference "../../../styles/global.css";

  .problem-solution {
    @apply grid grid-cols-1 md:grid-cols-2 gap-8 my-12;
  }

  .ps-col {
    @apply p-6 lg:p-8 rounded-2xl border-2;
  }

  /* Problema */
  .ps-col--problem {
    @apply bg-red-50/50 border-red-100 dark:bg-red-950/20 dark:border-red-900/40;
  }
  .ps-col--problem .ps-col__icon {
    @apply bg-red-100 text-red-600 dark:bg-red-900/40 dark:text-red-400;
  }
  .ps-col--problem .ps-col__heading {
    @apply text-red-900 dark:text-red-300;
  }

  /* Solución */
  .ps-col--solution {
    @apply bg-success-50/50 border-success-100 dark:bg-success-950/20 dark:border-success-900/40;
  }
  .ps-col--solution .ps-col__icon {
    @apply bg-success-100 text-success-600 dark:bg-success-900/40 dark:text-success-400;
  }
  .ps-col--solution .ps-col__heading {
    @apply text-success-900 dark:text-success-300;
  }

  .ps-col__header {
    @apply flex items-center gap-4 mb-4;
  }

  .ps-col__icon {
    @apply w-11 h-11 rounded-xl flex items-center justify-center shrink-0;
  }

  .ps-col__heading {
    @apply font-bold text-xl m-0;
  }

  .ps-col__content {
    @apply text-theme-muted leading-relaxed space-y-4;
  }
</style>
