---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Icon } from "@components";
import { CATEGORY_LABELS, TYPE_LABELS, formatDate } from "@utils/blog";

interface Props {
  title: string;
  description: string;
  category: string;
  type: string;
  date: Date;
  author: string;
  coverImage?: string;
  slug: string;
  class?: string;
  priority?: boolean;
}

const {
  title,
  description,
  category,
  type,
  date,
  author,
  coverImage,
  slug,
  class: className,
  priority = false,
} = Astro.props;

const formattedDate = formatDate(date);

const isExternalUrl = coverImage?.startsWith("http");

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/blog/**/*"
);

let imgData: ImageMetadata | null = null;
if (!isExternalUrl && coverImage) {
  const loader = allImages[`/src/assets/images/blog/${coverImage}`];
  if (loader) imgData = (await loader()).default;
}
---

<a
  href={`/blog/${slug}`}
  class:list={["blog-card group block", className]}
  data-blog-card
  data-title={title.toLowerCase()}
  data-desc={description.toLowerCase()}
  data-date={date.getTime()}
>
  <div class="blog-card__image-wrapper">
    {imgData ? (
      <Image
        src={imgData}
        alt={title}
        width={640}
        height={360}
        class="blog-card__image"
        loading={priority ? "eager" : "lazy"}
        fetchpriority={priority ? "high" : "auto"}
      />
    ) : isExternalUrl && coverImage ? (
      <img src={coverImage} alt={title} class="blog-card__image" loading={priority ? "eager" : "lazy"} fetchpriority={priority ? "high" : "auto"} />
    ) : (
      <div class="blog-card__image bg-gradient-to-br from-primary-800 to-primary-950" aria-hidden="true" />
    )}
    <span class="blog-card__type">
      {TYPE_LABELS[type] ?? type}
    </span>
  </div>
  <div class="blog-card__content">
    <div class="blog-card__meta">
      <span
        class="blog-card__category text-secondary-400 font-bold text-xs uppercase tracking-wider"
        >{CATEGORY_LABELS[category] ?? category}</span
      >
      <span class="blog-card__date text-primary-400 text-sm"
        >{formattedDate}</span
      >
    </div>
    <h3 class="blog-card__title">{title}</h3>
    <p class="blog-card__desc">{description}</p>
    <div class="blog-card__footer">
      <span
        class="blog-card__author flex items-center gap-2 text-sm font-medium text-primary-200"
      >
        <div
          class="w-6 h-6 rounded-full bg-primary-700 flex items-center justify-center text-primary-200 font-bold text-xs"
        >
          {author.charAt(0)}
        </div>
        {author}
      </span>
      <span class="blog-card__read-more">
        Leer más <Icon name="arrow-right" size="16" />
      </span>
    </div>
  </div>
</a>

<style>
  @reference "../../styles/global.css";

  .blog-card {
    @apply relative flex flex-col bg-primary-900/60 rounded-2xl overflow-hidden border border-primary-700 transition-all duration-300;
  }

  @media (hover: hover) {
    .blog-card:hover {
      @apply shadow-xl shadow-black/30 -translate-y-1 border-secondary-500;
    }
  }

  .blog-card__image-wrapper {
    @apply relative aspect-video overflow-hidden;
  }

  .blog-card__image {
    @apply w-full h-full object-cover transition-transform duration-500;
  }

  @media (hover: hover) {
    .blog-card:hover .blog-card__image {
      @apply scale-105;
    }
  }

  .blog-card__type {
    @apply absolute top-4 left-4 bg-primary-950/80 backdrop-blur text-white font-bold text-xs px-2.5 py-1 rounded-md shadow-sm;
  }

  .blog-card__content {
    @apply p-6 flex flex-col flex-1;
  }

  .blog-card__meta {
    @apply flex justify-between items-center mb-3;
  }

  .blog-card__title {
    @apply text-xl font-bold text-primary-100 mb-2 leading-tight transition-colors;
  }

  @media (hover: hover) {
    .blog-card:hover .blog-card__title {
      @apply text-white;
    }
  }

  .blog-card__desc {
    @apply text-slate-400 text-sm leading-relaxed mb-6 flex-1 line-clamp-3;
  }

  .blog-card__footer {
    @apply flex justify-between items-center pt-4 border-t border-primary-700 mt-auto;
  }

  .blog-card__read-more {
    @apply inline-flex items-center gap-1 text-sm font-bold text-secondary-400 transition-colors;
  }

  @media (hover: hover) {
    .blog-card:hover .blog-card__read-more {
      @apply text-secondary-300 gap-2;
    }
  }
</style>
