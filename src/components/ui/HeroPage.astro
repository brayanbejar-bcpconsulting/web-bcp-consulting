---
import { Image } from "astro:assets";
import Breadcrumbs from "./Breadcrumbs.astro";

/**
 * Hero interno para páginas internas.
 * Soporta fondo degradado (bgClass) o imagen de fondo optimizada (image).
 * Cuando se pasa `image`, se renderiza sobre un overlay oscuro para
 * mantener la legibilidad del texto.
 */
interface Props {
  title: string;
  description: string;
  /** Clase de variante de degradado. Se ignora si se pasa `image`. */
  bgClass?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  /** Imagen de fondo opcional. Acepta import estático o URL string. */
  image?: ImageMetadata | string;
  /** Alt descriptivo de la imagen para SEO/accesibilidad. */
  imageAlt?: string;
  /**
   * Intensidad del overlay oscuro sobre la imagen.
   * Por defecto: 'medium' (bg-black/60).
   */
  imageOverlay?: 'light' | 'medium' | 'dark';
}

const {
  title,
  description,
  bgClass = "hero-page--primary",
  breadcrumbs,
  image,
  imageAlt = title,
  imageOverlay = 'medium',
} = Astro.props;

const overlayMap = {
  light:  'bg-black/40',
  medium: 'bg-black/60',
  dark:   'bg-black/80',
} as const;
---

<section class:list={["hero-page", !image && bgClass]}>

  {/* Imagen de fondo optimizada — solo cuando se pasa `image` */}
  {image && (
    <div class="hero-page__bg-media" aria-hidden="true">
      {typeof image === 'string' ? (
        <img
          src={image}
          alt=""
          class="hero-page__bg-img"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      ) : (
        <Image
          src={image}
          alt=""
          class="hero-page__bg-img"
          widths={[768, 1280, 1920]}
          sizes="100vw"
          format="webp"
          quality={85}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      )}
      {/* Overlay sobre la imagen */}
      <div class:list={["hero-page__bg-overlay", overlayMap[imageOverlay]]} />
    </div>
  )}

  <div class="hero-page__container">
    <div class="flex justify-center animate-fade-in-up">
      {breadcrumbs && <Breadcrumbs items={breadcrumbs} />}
    </div>
    <h1 class="hero-page__title animate-fade-in-up animate-duration-700">
      {title}
    </h1>
    <p
      class="hero-page__desc animate-fade-in-up animate-delay-200 animate-duration-700"
    >
      {description}
    </p>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .hero-page {
    @apply relative pt-32 pb-20 lg:pt-40 lg:pb-28 px-[5%] overflow-hidden;
  }

  /* ── Variantes de degradado (solo cuando no hay imagen) ── */
  .hero-page--primary {
    background: linear-gradient(
      135deg,
      var(--color-primary-950),
      var(--color-primary-700)
    );
  }

  .hero-page--secondary {
    background: linear-gradient(
      135deg,
      var(--color-primary-950),
      var(--color-secondary-800)
    );
  }

  .hero-page--complementary {
    background: linear-gradient(
      135deg,
      var(--color-primary-800),
      var(--color-complementary-900)
    );
  }

  /* Patrón de puntos decorativo */
  .hero-page::before {
    content: "";
    @apply absolute inset-0 opacity-5 pointer-events-none z-1;
    background-image: radial-gradient(
      circle at 30% 40%,
      white 1px,
      transparent 1px
    );
    background-size: 30px 30px;
  }

  /* ── Imagen de fondo ── */
  .hero-page__bg-media {
    @apply absolute inset-0 z-0;
  }

  .hero-page__bg-img {
    @apply w-full h-full object-cover object-center;
    /*
      image-rendering crisp + will-change para que el browser
      evite recompresión y mantenga calidad WebP.
    */
    will-change: transform;
    image-rendering: high-quality;
  }

  .hero-page__bg-overlay {
    @apply absolute inset-0;
    /* Degradado descendente sutil + color sólido para profundidad */
    background-image: linear-gradient(
      to bottom,
      transparent 30%,
      rgb(0 0 0 / 0.3) 100%
    );
  }

  /* ── Contenedor de texto ── */
  .hero-page__container {
    @apply max-w-200 mx-auto text-center relative z-10;
  }

  .hero-page__title {
    @apply text-white font-extrabold mb-6 text-balance;
  }

  .hero-page__desc {
    @apply text-neutral-300 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed;
  }
</style>
