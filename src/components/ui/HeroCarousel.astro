---
export interface HeroSlide {
  title: string;
  description: string;
  image: ImageMetadata | string;
  imageAlt?: string;
  config?: {
    /** Alineación horizontal del contenido. Por defecto: 'left' */
    align?: 'left' | 'center' | 'right';
    /** Tipo de capa sobre la imagen. Por defecto: 'gradient-right' */
    overlay?: 'none' | 'light' | 'medium' | 'dark' | 'gradient-right' | 'gradient-left';
  };
  cta?: {
    label: string;
    href: string;
    variant?: "primary" | "secondary";
  }[];
}

interface Props {
  slides: readonly HeroSlide[];
  headlineIndex?: number;
}

import { Image } from "astro:assets";

const { slides, headlineIndex = 0 } = Astro.props;
const hasMultiple = slides.length > 1;

/** Mapeo de clases para alineación */
const alignClasses = {
  left: "items-start text-left",
  center: "items-center text-center",
  right: "items-end text-right",
};

/** Mapeo de estilos para el overlay */
const overlayClasses = {
  'none': "hidden",
  'light': "bg-black/20",
  'medium': "bg-black/50",
  'dark': "bg-black/80",
  'gradient-right': "bg-gradient-to-r from-black/90 via-black/40 to-transparent",
  'gradient-left': "bg-gradient-to-l from-black/90 via-black/40 to-transparent",
};
---

<section
  class="hero-carousel"
  aria-label="Hero principal"
  data-hero-carousel
>
  <div class="hero-track" data-hero-track>
    {
      slides.map((slide, i) => {
        const isHeadline = i === headlineIndex;
        const { align = 'left', overlay = 'gradient-right' } = slide.config || {};

        return (
          <article
            class="hero-slide"
            aria-hidden={i !== 0 ? "true" : "false"}
            data-slide
          >
            {/* CAPA 0: Imagen optimizada */}
            <div class="hero-media">
              {typeof slide.image === "string" ? (
                <img
                  src={slide.image}
                  alt={slide.imageAlt ?? slide.title}
                  class="hero-img"
                  loading={i === 0 ? "eager" : "lazy"}
                />
              ) : (
                <Image
                  src={slide.image}
                  alt={slide.imageAlt ?? slide.title}
                  class="hero-img"
                  widths={[640, 1024, 1920]}
                  sizes="100vw"
                  loading={i === 0 ? "eager" : "lazy"}
                  fetchpriority={i === 0 ? "high" : "low"}
                />
              )}
            </div>

            {/* CAPA 1: Overlay Personalizable */}
            <div class:list={["hero-overlay", overlayClasses[overlay]]} aria-hidden="true" />

            {/* CAPA 2: Contenido con Posicionamiento */}
            <div class:list={["hero-content", alignClasses[align]]}>
              <div class="hero-text-wrapper">
                {isHeadline ? (
                  <h1 class="hero-title animate-fade-in-up animate-duration-700">
                    {slide.title}
                  </h1>
                ) : (
                  <h2 class="hero-title animate-fade-in-up animate-duration-700">
                    {slide.title}
                  </h2>
                )}

                <p class="hero-description animate-fade-in-up animate-delay-300 animate-duration-700">
                  {slide.description}
                </p>

                {slide.cta && slide.cta.length > 0 && (
                  <div class="hero-cta-group animate-fade-in-up animate-delay-500 animate-duration-700">
                    {slide.cta.map((btn) => (
                      <a
                        href={btn.href}
                        class:list={[
                          "hero-cta-btn",
                          btn.variant === "secondary" ? "btn-secondary" : "btn-primary",
                        ]}
                      >
                        {btn.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </article>
        );
      })
    }
  </div>

  {hasMultiple && (
    <>
      <button data-hero-prev class="hero-nav-btn hero-nav-prev" aria-label="Anterior" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
      </button>

      <button data-hero-next class="hero-nav-btn hero-nav-next" aria-label="Siguiente" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
      </button>

      <div class="hero-dots" role="tablist">
        {slides.map((_, i) => (
          <button role="tab" aria-selected={i === 0 ? "true" : "false"} data-hero-dot data-index={i} class:list={["hero-dot", i === 0 && "active"]} type="button" />
        ))}
      </div>
    </>
  )}
</section>

<style>
  @reference "../../styles/global.css";

  .hero-carousel {
    @apply relative w-full overflow-hidden bg-black;
    height: clamp(500px, 85vh, 900px);
  }

  .hero-track {
    @apply flex h-full w-full;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .hero-track {
    @apply flex h-full w-full;
    /* Añadimos estas 3 líneas clave */
    overflow-x: hidden; 
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .hero-slide {
    @apply relative flex-none w-full h-full overflow-hidden;
    /* Aseguramos que el slide se alinee correctamente */
    scroll-snap-align: start;
  }

  /* Capas */
  .hero-media { @apply absolute inset-0 z-0; }
  
  /* Corregido duration-[3000ms] por duration-3000 */
  .hero-img { 
    @apply w-full h-full object-cover transition-transform duration-3000 ease-out; 
  }
  
  .hero-overlay { @apply absolute inset-0 z-10 pointer-events-none; }
  
  .hero-content {
    @apply absolute inset-0 z-20 flex flex-col justify-center px-8 md:px-20 lg:px-32;
  }

  .hero-text-wrapper { @apply max-w-[750px]; }

  /* Efecto Zoom Activo */
  .hero-slide[aria-hidden="false"] .hero-img { transform: scale(1.1); }

  /* Reinicio de Animaciones */
  .hero-slide[aria-hidden="true"] .hero-content { display: none; }
  .hero-slide[aria-hidden="false"] .hero-content { display: flex; }

  /* Tipografía y Botones */
  .hero-title {
    @apply text-white font-bold leading-[1.1] mb-6;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
  }
  .hero-description {
    @apply text-white/90 text-lg md:text-xl leading-relaxed mb-10 max-w-2xl;
  }
  .hero-cta-group { @apply flex flex-wrap gap-4; }
  .hero-cta-btn { @apply px-8 py-4 rounded-full font-bold transition-all duration-300 text-base md:text-lg; }
  .btn-primary { @apply bg-primary-600 text-white hover:bg-primary-700 shadow-xl hover:scale-105; }
  .btn-secondary { @apply bg-transparent border-2 border-white text-white hover:bg-white hover:text-black; }

  /* Navegación */
  .hero-nav-btn { @apply absolute top-1/2 -translate-y-1/2 z-30 p-4 text-white hover:scale-110 transition-all opacity-50 hover:opacity-100; }
  .hero-nav-btn:disabled { @apply opacity-0 pointer-events-none; }
  .hero-nav-prev { @apply left-4; }
  .hero-nav-next { @apply right-4; }
  .hero-dots { @apply absolute bottom-10 left-1/2 -translate-x-1/2 flex gap-3 z-30; }
  .hero-dot { @apply w-3 h-3 rounded-full bg-white/30 transition-all cursor-pointer border-none; }
  .hero-dot.active { @apply bg-white w-10; }
</style>

<script>
  const init = () => {
    document.querySelectorAll<HTMLElement>("[data-hero-carousel]").forEach((carousel) => {
      const track = carousel.querySelector<HTMLElement>("[data-hero-track]");
      const slides = Array.from(carousel.querySelectorAll<HTMLElement>("[data-slide]"));
      const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-hero-dot]"));
      const prev = carousel.querySelector<HTMLButtonElement>("[data-hero-prev]");
      const next = carousel.querySelector<HTMLButtonElement>("[data-hero-next]");

      if (!track || slides.length === 0) return;

      let current = 0;

      const update = (index: number) => {
        current = index;
        slides.forEach((s, i) => {
          const isActive = i === index;
          s.setAttribute("aria-hidden", isActive ? "false" : "true");
        });
        
        dots.forEach((d, i) => {
          d.classList.toggle("active", i === index);
          d.setAttribute("aria-selected", i === index ? "true" : "false");
        });

        if (prev) prev.disabled = index === 0;
        if (next) next.disabled = index === slides.length - 1;
      };

      const goTo = (i: number) => {
        if (!track || !slides[i]) return;
        // Método ultra-preciso para carruseles
        const targetX = slides[i].offsetLeft;
        track.scrollTo({ left: targetX, behavior: "smooth" });
      };

      // El Observer detecta cuando el slide cambia para actualizar los dots
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const index = slides.indexOf(e.target as HTMLElement);
            if (index !== -1) update(index);
          }
        });
      }, { root: track, threshold: 0.6 });

      slides.forEach(s => obs.observe(s));
      
      prev?.addEventListener("click", () => {
        if (current > 0) goTo(current - 1);
      });

      next?.addEventListener("click", () => {
        if (current < slides.length - 1) goTo(current + 1);
      });
      
      dots.forEach(d => {
        d.addEventListener("click", () => {
          const index = Number(d.getAttribute('data-index'));
          goTo(index);
        });
      });
    });
  };

  // Ejecución inicial
  init();
  // Reiniciar tras navegación en Astro (View Transitions)
  document.addEventListener("astro:after-swap", init);
</script>