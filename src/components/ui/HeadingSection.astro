---
import Badge from "./Badge.astro";

interface Props {
  /** Tagline / badge sobre el título (ej: "Nuestros Servicios") */
  tagline?: string;
  /** Título principal (H2 semántico por defecto) */
  title: string;
  /** Descripción debajo del título */
  description?: string;
  /** Alineación del bloque */
  align?: "left" | "center";
  /** id para aria-labelledby */
  id?: string;
  /** Variante del badge */
  badgeVariant?: "primary" | "secondary" | "complementary" | "muted";
  /** Color del título */
  titleColor?: string;
  /** Color de la descripción */
  descColor?: string;
  class?: string;
}

const {
  tagline,
  title,
  description,
  align = "center",
  id,
  badgeVariant = "secondary",
  titleColor = "text-theme-heading",
  descColor = "text-theme-muted",
  class: className,
} = Astro.props;

const alignClass =
  align === "center" ? "text-center items-center" : "text-left items-start";
---

<div class:list={["flex flex-col gap-4 mb-10 lg:mb-14", alignClass, className]}>
  {tagline && <Badge variant={badgeVariant}>{tagline}</Badge>}
  <h2 id={id} class:list={["text-balance", titleColor]}>
    {title}
  </h2>
  {
    description && (
      <p
        class:list={[
          "max-w-2xl text-lg leading-relaxed",
          descColor,
          align === "center" && "mx-auto",
        ]}
      >
        {description}
      </p>
    )
  }
</div>
