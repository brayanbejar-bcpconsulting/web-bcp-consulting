---
import type { HTMLAttributes } from 'astro/types';
import Icon from './Icon.astro';

interface Props extends HTMLAttributes<'button'> {
  variant?: 'primary' | 'secondary' | 'outline' | 'complementary' | 'whatsapp' | 'ghost' | 'underline';
  size?: 'sm' | 'md' | 'lg' | 'none';
  href?: string;
  target?: '_blank' | '_self';
  /** Sobrescribe o complementa el atributo rel del enlace */
  rel?: string;
  /** Activa descarga del recurso (solo aplica en enlaces) */
  download?: string | boolean;
  /** Tipo del elemento button cuando no es enlace */
  type?: 'button' | 'submit' | 'reset';
  /** Abre en nueva pestaña con rel="noopener noreferrer" automático */
  external?: boolean;
  /** Añade nofollow al rel (útil para enlaces patrocinados o no confiables) */
  nofollow?: boolean;
  /** Desactiva el botón/enlace */
  disabled?: boolean;
  class?: string;
  withGlow?: boolean;
  icon?: string;
  iconSide?: 'left' | 'right';
}

const { 
  variant = 'primary', 
  size = 'md', 
  href,
  target,
  rel,
  download,
  type,
  external = false,
  nofollow = false,
  disabled = false,
  class: className,
  withGlow = false,
  icon,
  iconSide = 'left',
  ...rest 
} = Astro.props;

// Diccionario de estilos usando tus variables OKLCH
const variants = {
  primary: `
    bg-linear-to-r from-primary-600 to-primary-700 text-white
    shadow-lg shadow-primary-500/30 hover:shadow-primary-500/40
    hover:from-primary-500 hover:to-primary-600
    border border-primary-400/20
  `,
  secondary: `
    bg-linear-to-r from-secondary-500 to-secondary-600 text-white
    shadow-lg shadow-secondary-500/30 hover:shadow-secondary-500/40
    hover:from-secondary-400 hover:to-secondary-500
    border border-secondary-400/20
  `,
  complementary: `
    bg-linear-to-r from-complementary-500 to-complementary-600 text-primary-950
    shadow-lg shadow-complementary-500/30 hover:shadow-complementary-500/40
    hover:from-complementary-400 hover:to-complementary-500
    border border-complementary-400/20
  `,
  outline: `
    bg-white/90 backdrop-blur-sm border-2 border-primary-600 text-primary-600
    hover:bg-primary-50 hover:border-primary-500
  `,
  whatsapp: `
    bg-linear-to-r from-success-500 to-success-600 text-neutral-50
    shadow-lg shadow-success-500/30 hover:shadow-success-500/40
    border border-success-400/20 text-shadow-lg
  `,
  ghost: `
    bg-transparent text-primary-700 hover:bg-primary-50
  `,
  underline: `
    bg-transparent text-neutral-300 hover:text-neutral-100 transition-all duration-300 hover:underline hover:underline-offset-4
  `,
};

const sizes = {
  sm: "px-4 py-1.5 text-sm font-semibold gap-1.5",
  md: "px-6 py-2.5 text-base font-semibold gap-2",
  lg: "px-8 py-3.5 text-lg font-bold gap-2.5",
  none: "px-2 py-1 text-base font-medium gap-2"
};

const Tag = href ? 'a' : 'button';

// target resuelto: external fuerza _blank
const resolvedTarget = href ? (external ? '_blank' : target) : undefined;

// rel compuesto: noopener/noreferrer en nueva pestaña + nofollow opcional + override explícito
const computedRel = (() => {
  const parts: string[] = [];
  if (external || resolvedTarget === '_blank') parts.push('noopener', 'noreferrer');
  if (nofollow) parts.push('nofollow');
  return rel ?? (parts.length ? parts.join(' ') : undefined);
})();

// Efecto "Shine" (brillo que recorre el botón) para variantes con fondo
const hasShine = ['primary', 'secondary', 'complementary', 'whatsapp'].includes(variant);
---

<Tag
  href={disabled ? undefined : href}
  target={resolvedTarget}
  rel={computedRel}
  download={href ? download : undefined}
  type={!href ? (type ?? 'button') : undefined}
  disabled={!href ? disabled : undefined}
  aria-disabled={href && disabled ? 'true' : undefined}
  class:list={[
    "relative inline-flex items-center justify-center rounded-full overflow-hidden transition-all duration-300 ease-out active:scale-95 cursor-pointer font-heading disabled:opacity-50 disabled:pointer-events-none",
    variants[variant],
    sizes[size],
    { "animate-pulse-glow": withGlow },
    { "opacity-50 pointer-events-none": href && disabled },
    className
  ]}
  {...rest}
>
  {hasShine && (
    <span class="absolute inset-0 pointer-events-none overflow-hidden">
      <span class="shine-element absolute inset-0 bg-linear-to-r from-transparent via-white/25 to-transparent -translate-x-full transition-transform duration-700"></span>
    </span>
  )}

  <span class="relative z-10 flex items-center gap-[inherit]">
    {icon && iconSide === "left" && <Icon name={icon} size="1.2em" />}
    <slot />
    {icon && iconSide === "right" && <Icon name={icon} size="1.2em" />}
  </span>

  <span class="ripple-area absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true"></span>
</Tag>

<style>
  /* Animación de brillo pulsante */
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 15px var(--color-primary-500); }
    50% { box-shadow: 0 0 25px var(--color-primary-400); }
  }

  .animate-pulse-glow {
    animation: pulse-glow 2s ease-in-out infinite;
  }

  /* Efecto Shine al hacer Hover */
  [data-astro-cid-xxxxxx]:hover .shine-element {
    transform: translateX(200%);
  }

  /* Efecto Hover general */
  a:hover, button:hover {
    transform: translateY(-2px);
  }

  /* Efecto Click / Active */
  a:active, button:active {
    transform: translateY(0) scale(0.95);
  }

  /* Ripple CSS simple */
  .ripple-area::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: width 0.4s, height 0.4s, opacity 0.8s;
  }

  button:active .ripple-area::after, 
  a:active .ripple-area::after {
    width: 300px;
    height: 300px;
    opacity: 1;
    transition: 0s;
  }
</style>