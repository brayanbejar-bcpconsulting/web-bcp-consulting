---
interface Props {
  url: string;
  title: string;
  description?: string;
}

const { url, title, description = "" } = Astro.props;

const encoded = {
  url: encodeURIComponent(url),
  title: encodeURIComponent(title),
  desc: encodeURIComponent(description),
};

const shares = [
  {
    label: "Facebook",
    href: `https://www.facebook.com/sharer/sharer.php?u=${encoded.url}`,
    color: "hover:bg-[#1877F2] hover:border-[#1877F2] hover:text-white",
