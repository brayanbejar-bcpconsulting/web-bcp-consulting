---

<div class="rounded-2xl border border-theme-border bg-theme-card p-6">
  <h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-theme-muted">
    Compartir este artículo
  </h3>
  <div class="flex flex-wrap items-center gap-3">
    {shares.map((s) => (
      <a
        href={s.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Compartir en ${s.label}`}
        class:list={[
          "group flex items-center gap-2 rounded-full border border-theme-border bg-theme-surface px-4 py-2 text-sm font-medium text-theme-base transition-all duration-200",
          s.color,
        ]}
      >
        <Fragment set:html={s.icon} />
        <span class="hidden sm:inline">{s.label}</span>
      </a>
    ))}

    <!-- Copy link button -->
    <button
      id="copy-link-btn"
      data-url={url}
      aria-label="Copiar enlace"
      class="group flex items-center gap-2 rounded-full border border-theme-border bg-theme-surface px-4 py-2 text-sm font-medium text-theme-base transition-all duration-200 hover:border-secondary-500 hover:bg-secondary-50 hover:text-secondary-600"
    >
      <svg id="copy-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <span id="copy-text" class="hidden sm:inline">Copiar enlace</span>
    </button>
  </div>
</div>

<script>
  const btn = document.getElementById("copy-link-btn") as HTMLButtonElement | null;
  const text = document.getElementById("copy-text");
  const icon = document.getElementById("copy-icon");

  btn?.addEventListener("click", async () => {
    const url = btn.dataset.url ?? window.location.href;
    try {
      await navigator.clipboard.writeText(url);
      if (text) text.textContent = "¡Copiado!";
      if (icon) icon.innerHTML = `<polyline points="20 6 9 17 4 12"></polyline>`;
      btn.classList.add("border-green-400", "bg-green-50", "text-green-700");
      setTimeout(() => {
        if (text) text.textContent = "Copiar enlace";
        if (icon) icon.innerHTML = `<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>`;
        btn.classList.remove("border-green-400", "bg-green-50", "text-green-700");
      }, 2000);
    } catch {}
  });
</script>
