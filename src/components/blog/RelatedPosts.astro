---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { CATEGORY_LABELS } from "@utils/blog";

interface RelatedPost {
  slug: string;
  title: string;
  description: string;
  coverImage?: string;
  category?: string;
  date: Date;
}

interface Props {
  posts: RelatedPost[];
}

const { posts } = Astro.props;
if (posts.length === 0) return;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/blog/**/*"
);

async function loadImg(cover?: string) {
  if (!cover) return null;
  const loader = allImages[`/src/assets/images/blog/${cover}`];
  return loader ? (await loader()).default : null;
}

const postImages = await Promise.all(posts.map((p) => loadImg(p.coverImage)));
---

<section aria-label="Artículos relacionados">
  <h2 class="mb-6 text-xl font-bold text-primary-100 md:text-2xl">
    Artículos relacionados
  </h2>

  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map((post, i) => {
      const img = postImages[i];
      const catLabel = post.category ? (CATEGORY_LABELS[post.category] ?? post.category) : null;
      const dateStr = post.date.toLocaleDateString("es-PE", { year: "numeric", month: "short", day: "2-digit" });

      return (
        <a
          href={`/blog/${post.slug}`}
          class="group flex flex-col overflow-hidden rounded-2xl border border-primary-700 bg-primary-900/60 transition-all duration-200 hover:-translate-y-1 hover:border-primary-600 hover:bg-primary-900"
        >
          <!-- Cover -->
          <div class="relative h-44 overflow-hidden bg-primary-900">
            {img ? (
              <Image
                src={img}
                alt={post.title}
                width={500}
                height={280}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            ) : (
              <div class="flex h-full items-center justify-center bg-gradient-to-br from-primary-800 to-primary-950">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-primary-600/40" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M4 4h16a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2zm0 2v8l4-2 4 4 3-3 5 3V6H4z"/>
                </svg>
              </div>
            )}
            {catLabel && (
              <span class="absolute left-3 top-3 rounded-full border border-white/20 bg-black/40 px-2.5 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                {catLabel}
              </span>
            )}
          </div>

          <!-- Body -->
          <div class="flex flex-1 flex-col p-5">
            <p class="mb-2 text-xs text-primary-500">{dateStr}</p>
            <h3 class="mb-2 line-clamp-2 text-sm font-bold leading-snug text-primary-100 transition-colors group-hover:text-secondary-300">
              {post.title}
            </h3>
            <p class="line-clamp-2 flex-1 text-xs leading-relaxed text-primary-400">
              {post.description}
            </p>
            <span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-secondary-400 transition-all group-hover:gap-2">
              Leer artículo
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </span>
          </div>
        </a>
      );
    })}
  </div>
</section>
