---
import { Logotipo } from "@components";
import { NAVIGATION } from "@utils/navigation";

export interface LandingNavItem {
  label: string;
  href: string;
}

interface Props {
  navItems: LandingNavItem[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  navItems,
  ctaLabel = "Solicitar Demo",
  ctaHref = "#contacto",
} = Astro.props;

const waPhone = NAVIGATION.contact.phone.replace(/\D/g, "");
const waMsg = encodeURIComponent(
  "Hola BCP Consulting, me comunico desde la landing page. Quisiera asesorarme sobre un proyecto."
);
---

<header class="landing-header" data-landing-header>
  <div class="landing-header__container">

    <!-- Logo -->
    <div class="scale-75 origin-left sm:scale-90 flex-shrink-0">
      <Logotipo />
    </div>

    <!-- Acciones derechas -->
    <div class="flex items-center gap-2 ml-auto">

      <!-- CTA: Llamar -->
      <a
        href={`tel:${NAVIGATION.contact.phone}`}
        class="landing-cta-btn landing-cta-btn--outline"
        aria-label="Llamar ahora"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span class="hidden sm:inline">Llamar</span>
      </a>

      <!-- CTA: WhatsApp -->
      <a
        href={`https://wa.me/${waPhone}?text=${waMsg}`}
        target="_blank"
        rel="noopener noreferrer"
        class="landing-cta-btn landing-cta-btn--whatsapp"
        aria-label="Escribir por WhatsApp"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.115.554 4.103 1.523 5.83L.057 23.5l5.816-1.448A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.371l-.36-.214-3.726.927.972-3.618-.234-.371A9.818 9.818 0 1112 21.818z"/>
        </svg>
        <span class="hidden sm:inline">WhatsApp</span>
      </a>

      <!-- Separador -->
      <span class="w-px h-6 bg-white/20 mx-1" aria-hidden="true"></span>

      <!-- Toggle tema -->
      <button
        id="landing-theme-toggle"
        type="button"
        aria-label="Cambiar tema"
        class="landing-icon-btn"
      >
        <!-- Sol: visible en modo oscuro -->
        <svg class="icon-sun w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <!-- Luna: visible en modo claro -->
        <svg class="icon-moon w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Botón menú lateral -->
      <button
        id="landing-panel-btn"
        type="button"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="landing-side-panel"
        class="landing-icon-btn"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

    </div>
  </div>
</header>

<!-- ── Portal: Backdrop + Panel off-canvas ── -->
<div id="landing-portal">

  <!-- Backdrop -->
  <div
    id="landing-backdrop"
    class="landing-backdrop"
    aria-hidden="true"
  ></div>

  <!-- Panel lateral -->
  <nav
    id="landing-side-panel"
    class="landing-panel"
    aria-label="Menú de la página"
    aria-hidden="true"
  >
    <!-- Cabecera del panel -->
    <div class="landing-panel__header">
      <div class="scale-75 origin-left">
        <Logotipo />
      </div>
      <button
        id="landing-panel-close"
        type="button"
        aria-label="Cerrar menú"
        class="landing-icon-btn"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Links de sección -->
    <ul class="landing-panel__links" role="list">
      {
        navItems.map((item) => (
          <li>
            <a href={item.href} class="landing-panel__link">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTAs en el pie del panel -->
    <div class="landing-panel__footer">
      <a
        href={`tel:${NAVIGATION.contact.phone}`}
        class="landing-cta-btn landing-cta-btn--outline w-full justify-center"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Llamar ahora
      </a>
      <a
        href={`https://wa.me/${waPhone}?text=${waMsg}`}
        target="_blank"
        rel="noopener noreferrer"
        class="landing-cta-btn landing-cta-btn--whatsapp w-full justify-center"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.115.554 4.103 1.523 5.83L.057 23.5l5.816-1.448A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.371l-.36-.214-3.726.927.972-3.618-.234-.371A9.818 9.818 0 1112 21.818z"/>
        </svg>
        WhatsApp
      </a>
    </div>

  </nav>
</div>

<style>
  @reference "../../styles/global.css";

  /* ── Header bar ── */
  .landing-header {
    @apply sticky top-0 z-50 w-full bg-primary-600 shadow-md;
  }

  .landing-header__container {
    @apply flex items-center gap-3 px-4 md:px-8 py-3 max-w-350 mx-auto;
  }

  /* ── CTAs ── */
  .landing-cta-btn {
    @apply inline-flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-semibold
           transition-all duration-200 whitespace-nowrap;
  }

  .landing-cta-btn--outline {
    @apply border border-white/40 text-white hover:bg-white/10 hover:border-white/70;
  }

  .landing-cta-btn--whatsapp {
    @apply bg-green-500 text-white hover:bg-green-400;
  }

  /* ── Botón icono (toggle tema + hamburger) ── */
  .landing-icon-btn {
    @apply flex items-center justify-center w-9 h-9 rounded-lg
           text-white/80 hover:text-white hover:bg-white/10
           transition-colors duration-200 cursor-pointer flex-shrink-0;
  }

  /* ── Sol/Luna: estados según tema ── */
  :root:not(.dark) .icon-sun  { display: none; }
  :root:not(.dark) .icon-moon { display: block; }
  html.dark .icon-sun         { display: block; }
  html.dark .icon-moon        { display: none; }

  /* ── Backdrop ── */
  .landing-backdrop {
    @apply fixed inset-0 bg-black/50 backdrop-blur-sm z-[199]
           opacity-0 pointer-events-none;
    transition: opacity 0.3s ease;
  }

  .landing-backdrop.is-open {
    @apply opacity-100 pointer-events-auto;
  }

  /* ── Panel off-canvas ── */
  .landing-panel {
    @apply fixed top-0 right-0 h-full w-72 z-[200]
           bg-primary-700 flex flex-col shadow-2xl;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .landing-panel.is-open {
    transform: translateX(0);
  }

  .landing-panel__header {
    @apply flex items-center justify-between px-5 py-4
           border-b border-white/10;
  }

  .landing-panel__links {
    @apply flex flex-col gap-1 px-4 py-4 flex-1 overflow-y-auto;
  }

  .landing-panel__link {
    @apply block px-4 py-3 rounded-xl text-white/80 hover:text-white
           font-medium text-sm hover:bg-white/10 transition-colors duration-200;
  }

  .landing-panel__footer {
    @apply flex flex-col gap-3 px-5 py-5 border-t border-white/10;
  }
</style>

<script>
  const initLandingHeader = () => {
    // ── Panel off-canvas ──
    const panelBtn   = document.getElementById("landing-panel-btn");
    const closeBtn   = document.getElementById("landing-panel-close");
    const panel      = document.getElementById("landing-side-panel");
    const backdrop   = document.getElementById("landing-backdrop");

    const openPanel = () => {
      panel?.classList.add("is-open");
      backdrop?.classList.add("is-open");
      panel?.setAttribute("aria-hidden", "false");
      panelBtn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    };

    const closePanel = () => {
      panel?.classList.remove("is-open");
      backdrop?.classList.remove("is-open");
      panel?.setAttribute("aria-hidden", "true");
      panelBtn?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    };

    panelBtn?.addEventListener("click", openPanel);
    closeBtn?.addEventListener("click", closePanel);
    backdrop?.addEventListener("click", closePanel);

    // Cierra al hacer click en cualquier enlace del panel
    panel?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closePanel);
    });

    // ── Toggle de tema ──
    const applyTheme = (theme: "dark" | "light") => {
      if (theme === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
      try { localStorage.setItem("theme", theme); } catch (_) {}
    };

    const themeBtn = document.getElementById("landing-theme-toggle");
    themeBtn?.addEventListener("click", () => {
      const isDark = document.documentElement.classList.contains("dark");
      applyTheme(isDark ? "light" : "dark");
    });
  };

  initLandingHeader();
  document.addEventListener("astro:after-swap", initLandingHeader);
</script>
