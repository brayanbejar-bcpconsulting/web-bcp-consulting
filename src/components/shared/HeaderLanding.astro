---
import { Logotipo, Button } from "@components";

export interface LandingNavItem {
  label: string;
  href: string;
}

interface Props {
  navItems: LandingNavItem[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  navItems,
  ctaLabel = "Solicitar Demo",
  ctaHref = "#contacto",
} = Astro.props;
---

<header class="landing-header" data-landing-header>
  <div class="landing-header__container">
    <!-- Logo -->
    <div class="scale-75 origin-left md:scale-90">
      <Logotipo />
    </div>

    <!-- Nav desktop -->
    <nav
      class="hidden lg:flex items-center gap-1"
      aria-label="Secciones de la página"
    >
      {
        navItems.map((item) => (
          <a href={item.href} class="landing-nav-link">
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- CTA + Hamburger -->
    <div class="flex items-center gap-3 ml-auto lg:ml-0">
      <Button href={ctaHref} variant="complementary" size="sm" class="hidden sm:inline-flex whitespace-nowrap">
        {ctaLabel}
      </Button>

      <!-- Hamburger móvil -->
      <button
        id="landing-menu-btn"
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="landing-mobile-menu"
        class="lg:hidden inline-flex items-center justify-center p-2 rounded-lg text-white hover:bg-white/10 transition-colors"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="landing-mobile-menu"
    class="lg:hidden hidden bg-primary-600 border-t border-primary-400"
  >
    <nav class="flex flex-col px-4 py-3 gap-1">
      {
        navItems.map((item) => (
          <a href={item.href} class="landing-nav-link--mobile">
            {item.label}
          </a>
        ))
      }
      <div class="pt-2 pb-1">
        <Button href={ctaHref} variant="complementary" size="sm" class="w-full justify-center">
          {ctaLabel}
        </Button>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("landing-menu-btn");
  const menu = document.getElementById("landing-mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  function toggleMenu(force?: boolean) {
    const isHidden = menu?.classList.contains("hidden");
    const open = force !== undefined ? force : isHidden;
    menu?.classList.toggle("hidden", !open);
    iconOpen?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
    btn?.setAttribute("aria-expanded", String(open));
  }

  btn?.addEventListener("click", () => toggleMenu());

  document.querySelectorAll(".landing-nav-link--mobile").forEach((link) => {
    link.addEventListener("click", () => toggleMenu(false));
  });
</script>

<style>
  @reference "../../styles/global.css";

  .landing-header {
    @apply sticky top-0 z-50 w-full bg-primary-500 shadow-md;
  }

  .landing-header__container {
    @apply flex items-center gap-4 px-4 md:px-8 lg:px-12 py-3 max-w-350 mx-auto;
  }

  .landing-nav-link {
    @apply text-white/80 hover:text-white text-xs font-medium px-3 py-2 rounded-lg
           hover:bg-white/10 transition-colors duration-200 whitespace-nowrap;
  }

  .landing-nav-link--mobile {
    @apply text-white/80 hover:text-white text-sm font-medium px-3 py-2 rounded-lg
           hover:bg-white/10 transition-colors duration-200 block;
  }
</style>
