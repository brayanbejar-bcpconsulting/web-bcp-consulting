---
import { Logotipo, Icon } from "@components";
import { NAVIGATION } from "@utils/navigation";
import SocialFooter from "./SocialFooter.astro";

export interface LandingNavItem {
  label: string;
  href: string;
}

export interface LandingPageInteres {
  title: string;
  href: string;
  tagline?: string;
}

interface Props {
  navItems: LandingNavItem[];
  pagesInteres?: LandingPageInteres[];
}

const { navItems, pagesInteres = [] } = Astro.props;
const waPhone = NAVIGATION.contact.phone.replace(/\D/g, "");
---

<footer class="bg-primary-800 text-white">
  <!-- Main grid -->
  <div class="max-w-350 mx-auto px-4 md:px-8 lg:px-12 py-12 lg:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">

      <!-- Col 1: Marca -->
      <div class="flex flex-col gap-4">
        <div class="brightness-0 invert opacity-90 scale-90 origin-left">
          <Logotipo />
        </div>
        <p class="text-xs text-primary-200 leading-relaxed max-w-xs">
          Soluciones tecnológicas que transforman negocios en operaciones controladas y rentables.
        </p>
        <SocialFooter variant="light" />
      </div>

      <!-- Col 2: Contáctanos -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-semibold text-white/60 uppercase tracking-wider">
          Contáctanos
        </h3>
        <ul class="flex flex-col gap-3">
          <li>
            <a
              href={`tel:${NAVIGATION.contact.phone.replace(/\s/g, "")}`}
              class="flex items-center gap-2 text-xs text-primary-200 hover:text-white transition-colors duration-200"
            >
              <Icon name="phone" size="14" class="text-primary-400 flex-shrink-0" />
              {NAVIGATION.contact.phone}
            </a>
          </li>
          <li>
            <a
              href={`https://api.whatsapp.com/send/?phone=${waPhone}&text=${encodeURIComponent("Hola, quiero una demo del software")}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-xs text-primary-200 hover:text-white transition-colors duration-200"
            >
              <Icon name="whatsapp" size="14" class="text-primary-400 flex-shrink-0" />
              WhatsApp
            </a>
          </li>
          <li>
            <a
              href={`mailto:${NAVIGATION.contact.email}`}
              class="flex items-center gap-2 text-xs text-primary-200 hover:text-white transition-colors duration-200"
            >
              <Icon name="mail" size="14" class="text-primary-400 flex-shrink-0" />
              {NAVIGATION.contact.email}
            </a>
          </li>
          <li>
            <span class="flex items-center gap-2 text-xs text-primary-200">
              <Icon name="map-pin" size="14" class="text-primary-400 flex-shrink-0" />
              Lima, Perú
            </span>
          </li>
        </ul>
      </div>

      <!-- Col 3: Navegación (anclas H2) -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-semibold text-white/60 uppercase tracking-wider">
          Contenido
        </h3>
        <ul class="flex flex-col gap-2">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="flex items-center gap-1.5 text-xs text-primary-200 hover:text-white transition-colors duration-200"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-2.5 w-2.5 text-primary-400 flex-shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Col 4: Te podría interesar -->
      {
        pagesInteres.length > 0 && (
          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-white/60 uppercase tracking-wider">
              Te podría interesar
            </h3>
            <ul class="flex flex-col gap-3">
              {pagesInteres.map((page) => (
                <li>
                  <a
                    href={page.href}
                    class="group flex flex-col gap-0.5"
                  >
                    <span class="text-xs font-medium text-primary-100 group-hover:text-white transition-colors duration-200">
                      {page.title}
                    </span>
                    {page.tagline && (
                      <span class="text-xs text-primary-400 group-hover:text-primary-300 transition-colors duration-200 leading-snug">
                        {page.tagline}
                      </span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-primary-700">
    <div class="max-w-350 mx-auto px-4 md:px-8 lg:px-12 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-primary-400">
        &copy; {new Date().getFullYear()} BCP Consulting E.I.R.L. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-4">
        {
          NAVIGATION.footer.map((link) => (
            <a
              href={link.path}
              class="text-xs text-primary-400 hover:text-white transition-colors duration-200"
            >
              {link.title}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
