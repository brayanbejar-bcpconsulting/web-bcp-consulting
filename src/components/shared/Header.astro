---
import { NAVIGATION } from "@utils/navigation";
import { Logotipo, Button } from "@components";
import NavMobile from "./NavMobile.astro";
---

<header class="site-header" data-site-header>
  <div class="header-container">
    <div class="flex items-center gap-8">
      <div class="scale-75 origin-left md:scale-100">
        <Logotipo />
      </div>
      <nav
        class="hidden md:flex items-center gap-6"
        aria-label="Navegación principal"
      >
        {
          NAVIGATION.main.map((item) =>
            item.children ? (
              <div class="relative group">
                <Button
                  href={item.path}
                  variant="underline"
                  size="none"
                  class="flex items-center gap-1"
                >
                  {item.title}
                  <svg
                    class="w-3 h-3 transition-transform group-hover:rotate-180"
                    viewBox="0 0 12 12"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M3 4.5l3 3 3-3" />
                  </svg>
                </Button>
                <div class="absolute top-full left-0 pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                  <div class="bg-white rounded-xl shadow-xl border border-neutral-100 p-2 min-w-55 flex flex-col gap-1 relative before:absolute before:-top-2 before:left-4 before:w-4 before:h-4 before:bg-white before:border-l before:border-t before:border-neutral-100 before:rotate-45">
                    {item.children.map((child) => (
                      <a
                        href={child.path}
                        class="px-3 py-2 text-sm text-neutral-600 hover:text-primary-600 font-medium hover:bg-primary-50 rounded-lg transition-colors relative z-10"
                      >
                        {child.title}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <Button href={item.path} variant="underline" size="none">
                {item.title}
              </Button>
            ),
          )
        }
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <!-- Botón toggle tema claro/oscuro -->
      <button
        id="theme-toggle"
        type="button"
        aria-label="Cambiar tema"
        class="theme-toggle"
      >
        <!-- Ícono sol (visible en modo oscuro → click para pasar a claro) -->
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <!-- Ícono luna (visible en modo claro → click para pasar a oscuro) -->
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <!-- CTA solo escritorio -->
      <div class="hidden md:block">
        <Button href="/contacto" variant="whatsapp" icon="whatsapp">
          Agenda una reunión
        </Button>
      </div>
      <!-- CTA móvil -->
      <div class="md:hidden">
        <Button href="/contacto" variant="whatsapp" size="sm" icon="whatsapp">
          Reunión
        </Button>
      </div>
      <NavMobile />
    </div>
  </div>
</header>

<style>
  @reference "../../styles/global.css";

  .site-header {
    /*
      Por defecto: absolute, flota sobre el hero sin ocupar espacio en el flujo.
      El hero no necesita compensar nada.
    */
    @apply absolute top-0 left-0 right-0 z-50
           border-b border-primary-700/50
           transition-colors duration-300;
    /* Sin fondo en el hero para que la imagen se vea completa */
    background: transparent;
  }

  /*
    Estado sticky: se activa con JS al salir del hero.
    - translate-y empieza en -100% (fuera de pantalla) y va a 0 (slide down).
    - La transición de transform da el efecto de entrada desde arriba.
  */
  .site-header.is-sticky {
    @apply fixed bg-primary-500/90 backdrop-blur-md;
    animation: header-slide-down 0.35s ease-out forwards;
  }

  /* ── Toggle de tema ── */
  .theme-toggle {
    @apply flex items-center justify-center w-9 h-9 rounded-full
           text-white/80 hover:text-white
           hover:bg-white/10
           transition-colors duration-200
           cursor-pointer;
  }

  .theme-toggle svg {
    @apply w-5 h-5 pointer-events-none;
  }

  /* En modo claro: mostrar luna, ocultar sol */
  :root:not(.dark) .theme-toggle .icon-sun  { display: none; }
  :root:not(.dark) .theme-toggle .icon-moon { display: block; }

  /* En modo oscuro: mostrar sol, ocultar luna */
  html.dark .theme-toggle .icon-sun  { display: block; }
  html.dark .theme-toggle .icon-moon { display: none; }

  @keyframes header-slide-down {
    from { transform: translateY(-100%); }
    to   { transform: translateY(0); }
  }

  .header-container {
    @apply max-w-350 mx-auto flex items-center justify-between px-4 sm:px-6 lg:px-8 py-2 lg:p-4;
  }
</style>

<script>
  const initStickyHeader = () => {
    const header = document.querySelector<HTMLElement>("[data-site-header]");
    if (!header) return;

    /*
      Usamos un sentinel: un div invisible al final del hero.
      Cuando sale del viewport → header se vuelve fixed (is-sticky).
      Cuando entra de nuevo  → header vuelve a absolute (sin fondo).
      
      Esto es más preciso que escuchar scroll porque usa IntersectionObserver,
      que no bloquea el hilo principal.
    */
    const sentinel = document.querySelector<HTMLElement>("[data-hero-sentinel]");

    if (!sentinel) {
      // Fallback: si no hay hero en esta página, el header arranca sticky directamente
      header.classList.add("is-sticky");
      return;
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          // El sentinel es visible → estamos en el hero → absolute, sin fondo
          header.classList.remove("is-sticky");
        } else {
          // El sentinel salió → estamos fuera del hero → fixed con slide-down
          header.classList.add("is-sticky");
        }
      },
      {
        // Activar cuando el sentinel esté al 100% fuera del viewport
        threshold: 0,
        // Un margen negativo del alto del header evita el flash en el punto exacto
        rootMargin: "0px 0px 0px 0px",
      }
    );

    observer.observe(sentinel);
  };

  initStickyHeader();
  document.addEventListener("astro:after-swap", initStickyHeader);

  /* ── Theme toggle ── */
  function applyTheme(theme: 'dark' | 'light') {
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    try { localStorage.setItem('theme', theme); } catch (e) {}
  }

  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      applyTheme(isDark ? 'light' : 'dark');
    });
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>