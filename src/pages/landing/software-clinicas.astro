---
import LandingLayout from "@layouts/LandingLayout.astro";
import {
  HeroClinicas,
  ProblemasClinicas,
  FuncionalidadesMVPClinicas,
  FuncionalidadesOpcionalesClinicas,
  BeneficiosClinicas,
  FaqClinicas,
  CtaClinicas,
} from "@components/sections/landing/software-clinicas";
import { SITE_INFO } from "@utils/site-config";

const navItems = [
  { label: "Problemas", href: "#problemas" },
  { label: "Funcionalidades", href: "#funcionalidades" },
  { label: "Módulos Avanzados", href: "#evolucion" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Preguntas Frecuentes", href: "#faq" },
  { label: "Contacto", href: "#contacto" },
];

const pagesInteres = [
  {
    title: "Software para Restaurantes",
    href: "/landing/software-restaurantes",
    tagline: "Control total de ventas, inventarios y operación gastronómica",
  },
  {
    title: "Software de Inventarios",
    href: "/landing/software-inventarios/",
    tagline: "Control multialmacén, kardex automatizado y alertas de reposición",
  },
  {
    title: "Software de RRHH",
    href: "/landing/software-rrhh/",
    tagline: "Planillas, asistencia, contratos y evaluaciones automatizadas",
  },
];
// ── JSON-LD: Service ─────────────────────────────────────────────
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Software para Clínicas y Centros Médicos',
  description: 'Plataforma integral para clínicas: historia clínica electrónica, agenda médica, facturación SUNAT y gestión de pacientes.',
  provider: {
    '@type': 'Organization',
    '@id': 'https://bcpconsulting.pe/#organization',
    name: 'BCP Consulting E.I.R.L.',
    url: 'https://bcpconsulting.pe',
    telephone: '+51929772711',
    email: 'soporte@bcpconsulting.pe',
    taxID: '20612012475',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Lima',
      addressCountry: 'PE',
    },
  },
  areaServed: { '@type': 'Country', name: 'Peru' },
  serviceType: 'Healthcare Software Development',
  url: `${SITE_INFO.url}/landing/software-clinicas/`,
});
---

<LandingLayout
  title="Software para Clínicas y Centros Médicos en Perú | BCP Consulting"
  description="Plataforma integral para clínicas: historia clínica electrónica, agenda médica, facturación SUNAT y gestión de pacientes. Digitaliza tu centro médico con soporte local en Perú."
  navItems={navItems}
  pagesInteres={pagesInteres}
  ctaLabel="Solicitar Demo"
  ctaHref="#contacto"
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={serviceSchema} />
  </Fragment>
  <HeroClinicas />
  <ProblemasClinicas />
  <FuncionalidadesMVPClinicas />
  <FuncionalidadesOpcionalesClinicas />
  <BeneficiosClinicas />
  <FaqClinicas />
  <CtaClinicas />
</LandingLayout>
