---
import LandingLayout from "@layouts/LandingLayout.astro";
import {
  HeroConstructoras,
  ProblemasConstructoras,
  FuncionalidadesMVPConstructoras,
  FuncionalidadesOpcionalesConstructoras,
  BeneficiosConstructoras,
  FaqConstructoras,
  CtaConstructoras,
} from "@components/sections/landing/software-constructoras";
import { SITE_INFO } from "@utils/site-config";

const navItems = [
  { label: "Problemas", href: "#problemas" },
  { label: "Funcionalidades", href: "#funcionalidades" },
  { label: "Módulos Avanzados", href: "#evolucion" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Preguntas Frecuentes", href: "#faq" },
  { label: "Contacto", href: "#contacto" },
];

const pagesInteres = [
  {
    title: "Software de Inventarios",
    href: "/landing/software-inventarios",
    tagline: "Control multialmacén, kardex automatizado y alertas de reposición",
  },
  {
    title: "Software de RRHH",
    href: "/landing/software-rrhh",
    tagline: "Planillas, asistencia, contratos y evaluaciones automatizadas",
  },
  {
    title: "Software para Clínicas",
    href: "/landing/software-clinicas",
    tagline: "Historia clínica electrónica, agenda médica y facturación SUNAT",
  },
];
// ── JSON-LD: Service ─────────────────────────────────────────────
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Software para Constructoras',
  description: 'Plataforma de gestión integral para constructoras: control presupuestal, avance de obra, materiales y subcontratistas en tiempo real.',
  provider: {
    '@type': 'Organization',
    '@id': 'https://bcpconsulting.pe/#organization',
    name: 'BCP Consulting E.I.R.L.',
    url: 'https://bcpconsulting.pe',
    telephone: '+51929772711',
    email: 'soporte@bcpconsulting.pe',
    taxID: '20612012475',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Lima',
      addressCountry: 'PE',
    },
  },
  areaServed: { '@type': 'Country', name: 'Peru' },
  serviceType: 'Construction Management Software Development',
  url: `${SITE_INFO.url}/landing/software-constructoras/`,
});
---

<LandingLayout
  title="Software para Constructoras e Inmobiliarias en Perú | BCP Consulting"
  description="Plataforma de gestión integral para constructoras: control presupuestal, avance de obra, materiales y subcontratistas en tiempo real. Reduce sobrecostos. Soporte en Perú."
  navItems={navItems}
  pagesInteres={pagesInteres}
  ctaLabel="Solicitar Demo"
  ctaHref="#contacto"
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={serviceSchema} />
  </Fragment>
  <HeroConstructoras />
  <ProblemasConstructoras />
  <FuncionalidadesMVPConstructoras />
  <FuncionalidadesOpcionalesConstructoras />
  <BeneficiosConstructoras />
  <FaqConstructoras />
  <CtaConstructoras />
</LandingLayout>
