---
import LandingLayout from "@layouts/LandingLayout.astro";
import {
  HeroFinanciero,
  ProblemasFinanciero,
  FuncionalidadesMVPFinanciero,
  FuncionalidadesOpcionalesFinanciero,
  BeneficiosFinanciero,
  FaqFinanciero,
  CtaFinanciero,
} from "@components/sections/landing/software-financiero";

const navItems = [
  { label: "Problemas", href: "#problemas" },
  { label: "Funcionalidades", href: "#funcionalidades" },
  { label: "Módulos Avanzados", href: "#evolucion" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Preguntas Frecuentes", href: "#faq" },
  { label: "Contacto", href: "#contacto" },
];

const pagesInteres = [
  { label: "Software de Gestión de RRHH", href: "/landing/software-rrhh/" },
  { label: "Software de Control de Inventarios", href: "/landing/software-inventarios/" },
  { label: "Software para Logística y Transporte", href: "/landing/software-logistica/" },
];
---

<LandingLayout
  title="Software Financiero para Empresas y Cajas Municipales en Perú | BCP Consulting"
  description="Sistema financiero para gestión de créditos, control de cartera, evaluación de riesgo crediticio y reportes regulatorios. Adaptado para empresas y Cajas Municipales en Perú."
  navItems={navItems}
  pagesInteres={pagesInteres}
>
  <HeroFinanciero />
  <ProblemasFinanciero />
  <FuncionalidadesMVPFinanciero />
  <FuncionalidadesOpcionalesFinanciero />
  <BeneficiosFinanciero />
  <FaqFinanciero />
  <CtaFinanciero />
</LandingLayout>
