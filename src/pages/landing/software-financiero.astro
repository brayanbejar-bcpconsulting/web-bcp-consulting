---
import LandingLayout from "@layouts/LandingLayout.astro";
import {
  HeroFinanciero,
  ProblemasFinanciero,
  FuncionalidadesMVPFinanciero,
  FuncionalidadesOpcionalesFinanciero,
  BeneficiosFinanciero,
  FaqFinanciero,
  CtaFinanciero,
} from "@components/sections/landing/software-financiero";
import { SITE_INFO } from "@utils/site-config";

const navItems = [
  { label: "Problemas", href: "#problemas" },
  { label: "Funcionalidades", href: "#funcionalidades" },
  { label: "Módulos Avanzados", href: "#evolucion" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Preguntas Frecuentes", href: "#faq" },
  { label: "Contacto", href: "#contacto" },
];

const pagesInteres = [
  {
    title: "Software de Gestión de RRHH",
    href: "/landing/software-rrhh/",
    tagline: "Planillas, asistencia, contratos y evaluaciones automatizadas",
  },
  {
    title: "Software de Inventarios",
    href: "/landing/software-inventarios/",
    tagline: "Control multialmacén, kardex automatizado y alertas de reposición",
  },
  {
    title: "Software para Logística",
    href: "/landing/software-logistica/",
    tagline: "Gestión de flotas, rutas, órdenes de transporte y reportes operativos",
  },
];
// ── JSON-LD: Service ─────────────────────────────────────────────
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Software Financiero para Empresas y Cajas Municipales',
  description: 'Sistema financiero para gestión de créditos, control de cartera, evaluación de riesgo crediticio y reportes regulatorios.',
  provider: {
    '@type': 'Organization',
    '@id': 'https://bcpconsulting.pe/#organization',
    name: 'BCP Consulting E.I.R.L.',
    url: 'https://bcpconsulting.pe',
    telephone: '+51929772711',
    email: 'soporte@bcpconsulting.pe',
    taxID: '20612012475',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Lima',
      addressCountry: 'PE',
    },
  },
  areaServed: { '@type': 'Country', name: 'Peru' },
  serviceType: 'Financial Software Development',
  url: `${SITE_INFO.url}/landing/software-financiero/`,
});
---

<LandingLayout
  title="Software Financiero para Empresas y Cajas Municipales en Perú | BCP Consulting"
  description="Sistema financiero para gestión de créditos, control de cartera, evaluación de riesgo crediticio y reportes regulatorios. Adaptado para empresas y Cajas Municipales en Perú."
  navItems={navItems}
  pagesInteres={pagesInteres}
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={serviceSchema} />
  </Fragment>
  <HeroFinanciero />
  <ProblemasFinanciero />
  <FuncionalidadesMVPFinanciero />
  <FuncionalidadesOpcionalesFinanciero />
  <BeneficiosFinanciero />
  <FaqFinanciero />
  <CtaFinanciero />
</LandingLayout>
