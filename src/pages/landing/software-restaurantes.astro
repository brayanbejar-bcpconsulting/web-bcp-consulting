---
import LandingLayout from "@layouts/LandingLayout.astro";
import {
  HeroRestaurantes,
  ProblemasRestaurantes,
  FuncionalidadesMVP,
  FuncionalidadesOpcionales,
  BeneficiosRestaurantes,
  FaqRestaurantes,
  CtaRestaurantes
} from "@components/sections/landing/software-restaurantes";
import { SITE_INFO } from "@utils/site-config";

const navItems = [
  { label: "Problemas", href: "#problemas" },
  { label: "Funcionalidades", href: "#funcionalidades" },
  { label: "Módulos Avanzados", href: "#evolucion" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Preguntas Frecuentes", href: "#faq" },
  { label: "Contacto", href: "#contacto" },
];

const pagesInteres = [
  {
    title: "Software de Inventarios",
    href: "/landing/software-inventarios/",
    tagline: "Control multialmacén, kardex automatizado y alertas de reposición",
  },
  {
    title: "Software de E-commerce",
    href: "/landing/software-ecommerce/",
    tagline: "Tienda online, pasarela de pagos y gestión de pedidos",
  },
  {
    title: "Software para Clínicas",
    href: "/landing/software-clinicas",
    tagline: "Administra citas, pacientes y facturación.",
  },
];
// ── JSON-LD: Service ─────────────────────────────────────────────
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Software para Restaurantes',
  description: 'Software para restaurantes en Perú que controla mermas, inventarios, caja y personal. Decisiones basadas en datos reales.',
  provider: {
    '@type': 'Organization',
    '@id': 'https://bcpconsulting.pe/#organization',
    name: 'BCP Consulting E.I.R.L.',
    url: 'https://bcpconsulting.pe',
    telephone: '+51929772711',
    email: 'soporte@bcpconsulting.pe',
    taxID: '20612012475',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Lima',
      addressCountry: 'PE',
    },
  },
  areaServed: { '@type': 'Country', name: 'Peru' },
  serviceType: 'Restaurant Management Software Development',
  url: `${SITE_INFO.url}/landing/software-restaurantes/`,
});
---

<LandingLayout
  title="Software para Restaurantes en Perú | Control y Rentabilidad | BCP Consulting"
  description="Software para restaurantes en Perú que controla mermas, inventarios, caja y personal. Toma decisiones basadas en datos reales. Solicita tu demo gratuita."
  navItems={navItems}
  pagesInteres={pagesInteres}
  ctaLabel="Solicitar Demo Gratis"
  ctaHref="#contacto"
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={serviceSchema} />
  </Fragment>
  <HeroRestaurantes />
  <ProblemasRestaurantes />
  <FuncionalidadesMVP />
  <FuncionalidadesOpcionales />
  <BeneficiosRestaurantes />
  <FaqRestaurantes />
  <CtaRestaurantes />
</LandingLayout>
