---
import LandingLayout from "@layouts/LandingLayout.astro";
import {
  HeroRRHH,
  ProblemasRRHH,
  FuncionalidadesMVPRRHH,
  FuncionalidadesOpcionalesRRHH,
  BeneficiosRRHH,
  FaqRRHH,
  CtaRRHH,
} from "@components/sections/landing/software-rrhh";
import { SITE_INFO } from "@utils/site-config";

const navItems = [
  { label: "Problemas", href: "#problemas" },
  { label: "Funcionalidades", href: "#funcionalidades" },
  { label: "Módulos Avanzados", href: "#evolucion" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Preguntas Frecuentes", href: "#faq" },
  { label: "Contacto", href: "#contacto" },
];

const pagesInteres = [
  {
    title: "Software para Clínicas",
    href: "/landing/software-clinicas",
    tagline: "Historia clínica electrónica, agenda médica y facturación SUNAT",
  },
  {
    title: "Software para Restaurantes",
    href: "/landing/software-restaurantes",
    tagline: "Control integral de ventas, inventarios y operación gastronómica",
  },
  {
    title: "Software de Inventarios",
    href: "/landing/software-inventarios/",
    tagline: "Control multialmacén, kardex automatizado y alertas de reposición",
  },
];
// ── JSON-LD: Service ─────────────────────────────────────────────
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Software de Gestión de RRHH',
  description: 'Sistema para automatizar recursos humanos: control de asistencia, planillas, gestión documentaria y evaluación de desempeño. Cumplimiento MINTRA.',
  provider: {
    '@type': 'Organization',
    '@id': 'https://bcpconsulting.pe/#organization',
    name: 'BCP Consulting E.I.R.L.',
    url: 'https://bcpconsulting.pe',
    telephone: '+51929772711',
    email: 'soporte@bcpconsulting.pe',
    taxID: '20612012475',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Lima',
      addressCountry: 'PE',
    },
  },
  areaServed: { '@type': 'Country', name: 'Peru' },
  serviceType: 'HR Software Development',
  url: `${SITE_INFO.url}/landing/software-rrhh/`,
});
---

<LandingLayout
  title="Software de Gestión de RRHH para Empresas en Perú | BCP Consulting"
  description="Sistema corporativo para automatizar recursos humanos: control de asistencia, planillas, gestión documentaria y evaluación de desempeño. Cumplimiento MINTRA. Soporte en Perú."
  navItems={navItems}
  pagesInteres={pagesInteres}
  ctaLabel="Solicitar Demo"
  ctaHref="#contacto"
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={serviceSchema} />
  </Fragment>
  <HeroRRHH />
  <ProblemasRRHH />
  <FuncionalidadesMVPRRHH />
  <FuncionalidadesOpcionalesRRHH />
  <BeneficiosRRHH />
  <FaqRRHH />
  <CtaRRHH />
</LandingLayout>
