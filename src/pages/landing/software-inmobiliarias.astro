---
import LandingLayout from "@layouts/LandingLayout.astro";
import {
  HeroInmobiliarias,
  ProblemasInmobiliarias,
  FuncionalidadesMVPInmobiliarias,
  FuncionalidadesOpcionalesInmobiliarias,
  BeneficiosInmobiliarias,
  FaqInmobiliarias,
  CtaInmobiliarias,
} from "@components/sections/landing/software-inmobiliarias";

const navItems = [
  { label: "Problemas", href: "#problemas" },
  { label: "Funcionalidades", href: "#funcionalidades" },
  { label: "Módulos Avanzados", href: "#evolucion" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Preguntas Frecuentes", href: "#faq" },
  { label: "Contacto", href: "#contacto" },
];

const pagesInteres = [
  { label: "Software para Constructoras", href: "/landing/software-constructoras/" },
  { label: "Software de Control de Inventarios", href: "/landing/software-inventarios/" },
  { label: "Software de Gestión de RRHH", href: "/landing/software-rrhh/" },
];
---

<LandingLayout
  title="Software para Inmobiliarias y CRM Inmobiliario en Perú | BCP Consulting"
  description="CRM y software integral para inmobiliarias: gestión de prospectos, pipeline de ventas, disponibilidad de unidades y seguimiento comercial por asesor. Soporte en Perú."
  navItems={navItems}
  pagesInteres={pagesInteres}
>
  <HeroInmobiliarias />
  <ProblemasInmobiliarias />
  <FuncionalidadesMVPInmobiliarias />
  <FuncionalidadesOpcionalesInmobiliarias />
  <BeneficiosInmobiliarias />
  <FaqInmobiliarias />
  <CtaInmobiliarias />
</LandingLayout>
