---
import LandingLayout from "@layouts/LandingLayout.astro";
import {
  HeroEducativa,
  ProblemasEducativa,
  FuncionalidadesMVPEducativa,
  FuncionalidadesOpcionalesEducativa,
  BeneficiosEducativa,
  FaqEducativa,
  CtaEducativa,
} from "@components/sections/landing/software-educativa";
import { SITE_INFO } from "@utils/site-config";

const navItems = [
  { label: "Problemas", href: "#problemas" },
  { label: "Funcionalidades", href: "#funcionalidades" },
  { label: "Módulos Avanzados", href: "#evolucion" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Preguntas Frecuentes", href: "#faq" },
  { label: "Contacto", href: "#contacto" },
];

const pagesInteres = [
  {
    title: "Software de Gestión de RRHH",
    href: "/landing/software-rrhh/",
    tagline: "Planillas, asistencia, contratos y evaluaciones automatizadas",
  },
  {
    title: "Software Financiero",
    href: "/landing/software-financiero/",
    tagline: "Gestión de créditos, cartera, riesgo crediticio y reportes regulatorios",
  },
  {
    title: "Software para Logística",
    href: "/landing/software-logistica/",
    tagline: "Gestión de flotas, rutas, órdenes de transporte y reportes operativos",
  },
];
// ── JSON-LD: Service ─────────────────────────────────────────────
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Software para Colegios e Instituciones Educativas',
  description: 'Plataforma integral para colegios: gestión académica, comunicación con padres, control de matrículas y pagos, y reportes directivos.',
  provider: {
    '@type': 'Organization',
    '@id': 'https://bcpconsulting.pe/#organization',
    name: 'BCP Consulting E.I.R.L.',
    url: 'https://bcpconsulting.pe',
    telephone: '+51929772711',
    email: 'soporte@bcpconsulting.pe',
    taxID: '20612012475',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Lima',
      addressCountry: 'PE',
    },
  },
  areaServed: { '@type': 'Country', name: 'Peru' },
  serviceType: 'Educational Software Development',
  url: `${SITE_INFO.url}/landing/software-educativa/`,
});
---

<LandingLayout
  title="Software para Colegios e Instituciones Educativas en Perú | BCP Consulting"
  description="Plataforma integral para colegios: gestión académica, comunicación con padres, control de matrículas y pagos, y reportes directivos. Adaptada al sistema educativo peruano."
  navItems={navItems}
  pagesInteres={pagesInteres}
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={serviceSchema} />
  </Fragment>
  <HeroEducativa />
  <ProblemasEducativa />
  <FuncionalidadesMVPEducativa />
  <FuncionalidadesOpcionalesEducativa />
  <BeneficiosEducativa />
  <FaqEducativa />
  <CtaEducativa />
</LandingLayout>
