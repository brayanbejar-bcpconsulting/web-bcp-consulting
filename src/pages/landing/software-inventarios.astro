---
import LandingLayout from "@layouts/LandingLayout.astro";
import {
  HeroInventarios,
  ProblemasInventarios,
  FuncionalidadesMVPInventarios,
  FuncionalidadesOpcionalesInventarios,
  BeneficiosInventarios,
  FaqInventarios,
  CtaInventarios,
} from "@components/sections/landing/software-inventarios";
import { SITE_INFO } from "@utils/site-config";

const navItems = [
  { label: "Problemas", href: "#problemas" },
  { label: "Funcionalidades", href: "#funcionalidades" },
  { label: "Módulos Avanzados", href: "#evolucion" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Preguntas Frecuentes", href: "#faq" },
  { label: "Contacto", href: "#contacto" },
];

const pagesInteres = [
  {
    title: "Software de RRHH",
    href: "/landing/software-rrhh",
    tagline: "Planillas, asistencia, contratos y evaluaciones automatizadas",
  },
  {
    title: "Software para Clínicas",
    href: "/landing/software-clinicas",
    tagline: "Historia clínica electrónica, agenda médica y facturación SUNAT",
  },
  {
    title: "Software para Restaurantes",
    href: "/landing/software-restaurantes",
    tagline: "Control integral de ventas, inventarios y operación gastronómica",
  },
];
// ── JSON-LD: Service ─────────────────────────────────────────────
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Software de Control de Inventarios',
  description: 'Sistema avanzado de control de inventarios: gestión multialmacén, kardex automatizado, alertas de reposición y trazabilidad por lotes.',
  provider: {
    '@type': 'Organization',
    '@id': 'https://bcpconsulting.pe/#organization',
    name: 'BCP Consulting E.I.R.L.',
    url: 'https://bcpconsulting.pe',
    telephone: '+51929772711',
    email: 'soporte@bcpconsulting.pe',
    taxID: '20612012475',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Lima',
      addressCountry: 'PE',
    },
  },
  areaServed: { '@type': 'Country', name: 'Peru' },
  serviceType: 'Inventory Management Software Development',
  url: `${SITE_INFO.url}/landing/software-inventarios/`,
});
---

<LandingLayout
  title="Software de Control de Inventarios para Empresas en Perú | BCP Consulting"
  description="Sistema avanzado de control de inventarios: gestión multialmacén, kardex automatizado, alertas de reposición y trazabilidad por lotes. Precisión total. Soporte en Perú."
  navItems={navItems}
  pagesInteres={pagesInteres}
  ctaLabel="Solicitar Demo"
  ctaHref="#contacto"
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={serviceSchema} />
  </Fragment>
  <HeroInventarios />
  <ProblemasInventarios />
  <FuncionalidadesMVPInventarios />
  <FuncionalidadesOpcionalesInventarios />
  <BeneficiosInventarios />
  <FaqInventarios />
  <CtaInventarios />
</LandingLayout>
