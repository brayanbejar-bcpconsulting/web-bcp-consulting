---
import { getCollection } from "astro:content";
import MainLayout from "@layouts/MainLayout.astro";
import { MainContainer, Breadcrumbs, Icon } from "@components";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.date.toLocaleDateString("es-PE", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  image: post.data.coverImage,
  author: {
    "@type": "Person",
    name: post.data.author,
  },
  datePublished: post.data.date.toISOString(),
};

const LABELS: Record<string, string> = {
  "inteligencia-artificial": "Inteligencia Artificial",
  "desarrollo-web": "Desarrollo Web",
  "software-empresarial": "Software Empresarial",
  "apps-moviles": "Apps Móviles",
  noticia: "Noticia",
  guia: "Guía",
  "caso-de-estudio": "Caso de Estudio",
  opinion: "Opinión",
  ranking: "Ranking",
};
---

<MainLayout
  title={`${post.data.title} | Blog BCP Consulting`}
  description={post.data.description}
  image={post.data.coverImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <article class="pt-32 pb-20 px-[5%]">
    <div class="max-w-200 mx-auto">
      <div class="mb-8">
        <Breadcrumbs
          items={[
            { label: "Inicio", href: "/" },
            { label: "Blog", href: "/blog" },
            {
              label: LABELS[post.data.category],
              href: `/blog/categoria/${post.data.category}`,
            },
            { label: "Artículo" },
          ]}
        />
      </div>

      <header class="mb-10 text-center">
        <div class="flex items-center justify-center gap-4 mb-6">
          <a
            href={`/blog/categoria/${post.data.category}`}
            class="bg-secondary-100 text-secondary-700 px-3 py-1 rounded-full text-sm font-bold uppercase tracking-wider hover:bg-secondary-200 transition-colors"
          >
            {LABELS[post.data.category]}
          </a>
          <span
            class="text-neutral-500 text-sm font-medium flex items-center gap-1"
          >
            <Icon name="calendar" size="14" />
            {formattedDate}
          </span>
        </div>
        <h1
          class="text-4xl md:text-5xl font-black text-primary-950 mb-6 text-balance leading-tight"
        >
          {post.data.title}
        </h1>
        <p class="text-xl text-neutral-600 max-w-3xl mx-auto leading-relaxed">
          {post.data.description}
        </p>
      </header>
    </div>

    <div
      class="max-w-4xl mx-auto mb-16 rounded-3xl overflow-hidden shadow-2xl shadow-primary-900/10"
    >
      <img
        src={post.data.coverImage}
        alt={post.data.title}
        class="w-full h-auto aspect-video object-cover"
        loading="eager"
      />
    </div>

    <div class="max-w-200 mx-auto">
      <div
        class="flex items-center justify-between py-6 border-y border-neutral-200 mb-10"
      >
        <div class="flex items-center gap-4">
          <div
            class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-xl"
          >
            {post.data.author.charAt(0)}
          </div>
          <div>
            <p class="font-bold text-primary-900">{post.data.author}</p>
            <p class="text-sm text-neutral-500">Autor / Especialista</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          {/* Share buttons logic could go here */}
          <span class="text-sm font-medium text-neutral-400">Compartir:</span>
          <button
            class="p-2 text-neutral-400 hover:text-primary-600 bg-neutral-100 hover:bg-primary-50 rounded-full transition-colors"
            aria-label="Compartir en LinkedIn"
          >
            <Icon name="linkedin" size="20" />
          </button>
          <button
            class="p-2 text-neutral-400 hover:text-secondary-500 bg-neutral-100 hover:bg-secondary-50 rounded-full transition-colors"
            aria-label="Compartir en Twitter/X"
          >
            <Icon name="twitter" size="20" />
          </button>
        </div>
      </div>

      <div
        class="prose prose-lg prose-neutral prose-headings:font-bold prose-headings:text-primary-900 prose-a:text-secondary-600 hover:prose-a:text-secondary-700 max-w-none"
      >
        <Content />
      </div>
    </div>
  </article>
</MainLayout>
