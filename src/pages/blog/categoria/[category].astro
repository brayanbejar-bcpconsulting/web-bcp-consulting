---
import { getCollection } from "astro:content";
import MainLayout from "@layouts/MainLayout.astro";
import { MainContainer, HeroPage, BlogCard, Icon } from "@components";
import { CATEGORY_LABELS } from "@utils/blog";
import { getBreadcrumbSchema } from "@utils/seo";
import { SITE_INFO } from "@utils/site-config";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const published = posts.filter((p) => !p.data.draft);
  const categories = [...new Set(published.map((p) => p.data.category))];

  return categories.map((category) => ({
    params: { category },
    props: {
      posts: published.filter((p) => p.data.category === category),
    },
  }));
}

const { category } = Astro.params;
const { posts } = Astro.props;

const title = CATEGORY_LABELS[category] ?? category;

const canonicalUrl = `${SITE_INFO.url}/blog/categoria/${category}/`;

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Inicio', url: SITE_INFO.url + '/' },
  { name: 'Blog', url: SITE_INFO.url + '/blog/' },
  { name: title, url: canonicalUrl },
]);

const sortedPosts = [...posts].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<MainLayout
  title={`Artículos sobre ${title}`}
  description={`Descubre los mejores artículos, noticias y guías sobre ${title} en el blog de BCP Consulting.`}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <HeroPage
    title={`Explora: ${title}`}
    description={`Todo lo que necesitas saber sobre ${title} y cómo impacta en las empresas modernas.`}
    bgClass="hero-page--complementary"
    breadcrumbs={[
      { label: "Inicio", href: "/" },
      { label: "Blog", href: "/blog" },
      { label: title },
    ]}
  />

  <MainContainer bgColor="bg-theme-page">
    <div
      class="mb-12 flex justify-between items-center border-b border-neutral-200 pb-4"
    >
      <h2 class="text-2xl font-bold text-primary-900 flex items-center gap-2">
        <Icon name="tag" size="24" class="text-secondary-500" />
        {sortedPosts.length} Artículos Publicados
      </h2>
      <a
        href="/blog"
        class="text-sm font-bold text-neutral-500 hover:text-primary-600 transition-colors uppercase tracking-widest flex items-center gap-1"
      >
        <Icon name="arrow-left" size="14" /> Volver al Blog
      </a>
    </div>

    {
      sortedPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map((post) => (
            <div class="h-full">
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                category={post.data.category}
                type={post.data.type}
                date={post.data.date}
                author={post.data.author}
                coverImage={post.data.coverImage}
                slug={post.slug}
                class="h-full"
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 px-4">
          <div class="w-16 h-16 bg-neutral-100 rounded-full flex items-center justify-center mx-auto mb-4 text-neutral-400">
            <Icon name="archive" size="32" />
          </div>
          <h3 class="text-xl font-bold text-primary-900 mb-2">
            Aún no hay artículos acá
          </h3>
          <p class="text-neutral-500 max-w-sm mx-auto">
            Pronto publicaremos contenido increíble en esta categoría. Ojea las
            demás secciones del blog.
          </p>
          <a
            href="/blog"
            class="mt-6 inline-block bg-primary-900 text-white font-semibold px-6 py-2.5 rounded-full hover:bg-primary-800 transition-colors shadow-lg"
          >
            Ver todos los artículos
          </a>
        </div>
      )
    }
  </MainContainer>
</MainLayout>
