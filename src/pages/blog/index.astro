---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseHead from "../../components/shared/BaseHead.astro";

const PAGE_SIZE = 10;

// Obtener posts
const allPosts = await getCollection("blog");

// Filtrar drafts y ordenar por fecha
const posts: CollectionEntry<"blog">[] = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Paginación
const pageParam = Astro.url.searchParams.get("page");
const currentPage = pageParam ? Number(pageParam) : 1;

const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
const safePage = Math.min(Math.max(currentPage, 1), totalPages);

const start = (safePage - 1) * PAGE_SIZE;
const paginatedPosts = posts.slice(start, start + PAGE_SIZE);

// Canonical limpio (sin query params)
const canonical = new URL("/blog", Astro.site!).toString();
---

<html lang="es">
  <head>
    <BaseHead
      title="Blog"
      description="Artículos sobre desarrollo de software, consultoría tecnológica y buenas prácticas."
      canonical={canonical}
    />
  </head>

  <body>
    <main class="mx-auto w-full max-w-5xl px-4 py-10">
      <header class="mb-8">
        <h1>Blog</h1>
        <p class="mt-3 opacity-80">
          Contenido para ayudarte a tomar mejores decisiones en software.
        </p>
      </header>

      <section class="grid gap-6">
        {paginatedPosts.map((p) => (
          <a
            class="rounded-2xl border border-border p-6 hover:shadow-sm transition"
            href={`/blog/${p.slug}`}
          >
            <p class="text-sm opacity-70">
              {p.data.date.toLocaleDateString("es-PE")}
            </p>

            <h2 class="mt-2">{p.data.title}</h2>

            <p class="mt-2 opacity-80">
              {p.data.description}
            </p>
          </a>
        ))}
      </section>

      {/* Navegación */}
      <nav class="mt-10 flex items-center justify-between">
        <a
          class={`rounded-xl border px-4 py-2 ${
            safePage <= 1 ? "pointer-events-none opacity-50" : ""
          }`}
          href={`/blog?page=${safePage - 1}`}
        >
          Anterior
        </a>

        <span class="text-sm opacity-70">
          Página {safePage} de {totalPages}
        </span>

        <a
          class={`rounded-xl border px-4 py-2 ${
            safePage >= totalPages ? "pointer-events-none opacity-50" : ""
          }`}
          href={`/blog?page=${safePage + 1}`}
        >
          Siguiente
        </a>
      </nav>
    </main>
  </body>
</html>
