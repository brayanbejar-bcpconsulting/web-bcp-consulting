        <div class="mt-8 text-center">
          <a href="#casos" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-secondary-100 dark:bg-secondary-900/30 border border-secondary-300 dark:border-secondary-700 text-secondary-700 dark:text-secondary-300 text-sm font-semibold hover:bg-secondary-200 dark:hover:bg-secondary-900/50 transition-colors min-h-11">
