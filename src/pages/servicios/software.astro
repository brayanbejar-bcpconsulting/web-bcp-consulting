                    <div><p class="text-[10px] text-white/40 uppercase tracking-wide mb-0.5">Tiempo de entrega</p><p class="text-xs font-semibold text-white">{c.tiempo}</p></div>
                    {c.url && <a href={c.url} target="_blank" rel="noopener noreferrer" class="ml-auto text-xs font-semibold text-complementary-300 hover:underline">Ver proyecto →</a>}
                  </div>
                </div>
                <div class="lg:border-l border-t lg:border-t-0 border-white/10 p-5 md:p-6 bg-white/3 flex flex-col gap-3">
