      </div>
    </section>

  </main>
</MainLayout>

<script>
  // ── FAQ acordeón accesible ─────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>(".pilar-faq-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      const panelId = btn.getAttribute("aria-controls")!;
      const panel = document.getElementById(panelId);
      const icon = btn.querySelector<SVGElement>(".pilar-faq-icon");
      btn.setAttribute("aria-expanded", String(!expanded));
      if (panel) panel.hidden = expanded;
      if (icon) icon.style.transform = expanded ? "" : "rotate(180deg)";
    });
    btn.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") { e.preventDefault(); btn.click(); }
    });
  });

  // ── Formulario contacto ────────────────────────────────────────────────
  const pcForm = document.getElementById("pilar-contact-form") as HTMLFormElement | null;
  const pcStatus = document.getElementById("pc-form-status");
  pcForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (pcStatus) {
      pcStatus.classList.remove("hidden");
      pcStatus.textContent = "✓ Mensaje recibido. Te contactamos en menos de 24 h.";
    }
    setTimeout(() => pcForm?.reset(), 800);
  });
</script>
