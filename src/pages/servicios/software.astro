---
import MainLayout from "@layouts/MainLayout.astro";
import { HeroPage, Button } from "@components";
import { SERVICES } from "@data/services";
import { NAVIGATION } from "@utils/navigation";
import bgSoftware from '@assets/images/pages/services/software/bg-image-software.jpg';

const service = SERVICES.find((s) => s.id === "software")!;

const waPhone = NAVIGATION.contact.phone.replace(/\D/g, "");
const waMsg = encodeURIComponent("Hola BCP Consulting, vengo desde https://bcpconsulting.pe/servicios/software. Quisiera asesorarme sobre software a medida para mi empresa.");

// ── Tabla AEO ──────────────────────────────────────────────────────────────
const tiposSoftware = [
  { tipo: "ERP / Gestión Empresarial", objetivo: "Centralizar finanzas, RRHH, compras y operaciones", modulos: "Contabilidad, nómina, compras, inventario, reportes", tiempo: "3–6 meses", integraciones: "SUNAT, bancos, sistemas contables", recomendado: "Empresa con +10 empleados y múltiples áreas desconectadas" },
  { tipo: "CRM / Pipeline de Ventas", objetivo: "Gestionar leads, clientes y seguimiento comercial", modulos: "Pipeline, cotizaciones, historial, automatización de correos", tiempo: "4–10 semanas", integraciones: "WhatsApp, email, Google Workspace, Calendly", recomendado: "Equipos de ventas con proceso comercial repetitivo" },
  { tipo: "Inventarios y Logística", objetivo: "Controlar stock, almacenes, despachos y proveedores", modulos: "Entradas/salidas, trazabilidad, rutas, alertas de stock mínimo", tiempo: "6–12 semanas", integraciones: "Transportistas, SUNAT, ERP, e-commerce", recomendado: "Almacenes, distribuidoras, logística de última milla" },
  { tipo: "Automatización e Integraciones", objetivo: "Conectar sistemas y eliminar tareas manuales repetitivas", modulos: "Flujos automáticos, webhooks, notificaciones, reglas de negocio", tiempo: "2–8 semanas", integraciones: "REST APIs, n8n, bases de datos", recomendado: "Empresa con múltiples herramientas aisladas" },
  { tipo: "SaaS / Producto Digital", objetivo: "Lanzar software como servicio vendible a terceros", modulos: "Multi-tenant, pagos recurrentes, onboarding, panel admin, métricas", tiempo: "3–6 meses (MVP)", integraciones: "Stripe / Culqi, OAuth, monitoreo, CDN", recomendado: "Startups o empresas que quieren monetizar software propio" },
  { tipo: "Software Sectorial a Medida", objetivo: "Solución vertical adaptada al flujo de la industria", modulos: "Variable: clínicas, restaurantes, constructoras, educación", tiempo: "6–16 semanas", integraciones: "SUNAT, POS, laboratorios, sistemas de fidelización", recomendado: "Sector con procesos únicos que productos genéricos no cubren" },
];

// ── 7 Fases ────────────────────────────────────────────────────────────────
const fases = [
  { numero: "01", nombre: "Descubrimiento", duracion: "1–2 sem", desc: "Documentamos requerimientos, mapa de procesos actuales e informe de factibilidad técnica.", entregables: ["Documento de requerimientos (BRD)", "Mapa de procesos actuales", "Informe de factibilidad técnica"] },
  { numero: "02", nombre: "Alcance y Backlog", duracion: "1 sem", desc: "Priorizamos funcionalidades con criterios de valor/esfuerzo. Definimos MVP y fases de entrega.", entregables: ["Product backlog priorizado", "Roadmap MVP → Completo", "Estimación de tiempos y costos por módulo"] },
  { numero: "03", nombre: "Diseño UX/UI", duracion: "1–3 sem", desc: "Wireframes, prototipo interactivo en Figma y design system antes de codificar.", entregables: ["Wireframes de pantallas principales", "Prototipo interactivo en Figma", "Design system / guía de estilo"] },
  { numero: "04", nombre: "Desarrollo", duracion: "Variable", desc: "Sprints de 1–2 semanas con demo funcional al cierre de cada uno. Control de versiones Git.", entregables: ["Código fuente (Git)", "Demo por sprint", "Documentación técnica de APIs"] },
  { numero: "05", nombre: "QA y Pruebas", duracion: "1–2 sem", desc: "Pruebas funcionales, de carga, seguridad OWASP y usabilidad. Cero bugs críticos antes del deploy.", entregables: ["Reporte de pruebas funcionales", "Informe de seguridad", "Lista de bugs resueltos"] },
  { numero: "06", nombre: "Despliegue (Deploy)", duracion: "2–5 días", desc: "Pipeline CI/CD, dominio, HTTPS, monitoreo activo y backups automáticos.", entregables: ["Sistema en producción (URL final)", "Panel de monitoreo configurado", "Manual de administrador"] },
  { numero: "07", nombre: "Soporte y Evolución", duracion: "Continuo", desc: "Soporte post-lanzamiento, correcciones, mejoras y evolución según crecimiento del negocio.", entregables: ["SLA de respuesta definido (según plan)", "Actualizaciones de seguridad", "Reportes mensuales de rendimiento"] },
];

// ── Casos de estudio ───────────────────────────────────────────────────────
const casos = [
  { cliente: "Izajes Massimo", sector: "Industrial · Logística de izajes", contexto: "Empresa con gestión dispersa en hojas de cálculo y WhatsApp. Sin visibilidad de equipos ni proyectos activos.", problema: "Reportes de estado tardaban 2–3 días. Cero trazabilidad de equipos en campo.", solucion: "Plataforma web de gestión operativa: control de equipos, asignación de personal, seguimiento de proyectos y reportes automáticos.", stack: "React · Node.js · PostgreSQL · AWS", tiempo: "12 semanas", kpi: ["Reportes generados al instante (antes: 2–3 días)", "–60% en llamadas de coordinación interna", "Control centralizado de +40 equipos activos"], url: "https://izajesmassimo.com/" },
  { cliente: "Aquaia SAC", sector: "Servicios acuáticos · RRHH", contexto: "Empresa con múltiples proyectos simultáneos y administración en Excel.", problema: "Imposible hacer seguimiento de proyectos e historial de clientes sin herramienta unificada.", solucion: "Sistema CRM + gestión de proyectos + panel administrativo + reportes por cliente con acceso por roles.", stack: "Vue.js · NestJS · MongoDB · Firebase", tiempo: "10 semanas", kpi: ["Visibilidad completa del pipeline de proyectos", "Historial de cliente accesible en segundos", "Eliminación total de hojas de cálculo"], url: "https://aquaiasac.com/" },
  { cliente: "Market Dollar", sector: "Fintech · Casa de cambio digital", contexto: "Startup con procesos manuales y sin panel de control en tiempo real.", problema: "Riesgo operativo por falta de trazabilidad en transacciones y ausencia de controles por rol.", solucion: "Plataforma fintech con panel de transacciones en tiempo real, gestión de tipo de cambio, roles de acceso y reportes financieros.", stack: "Next.js · Spring Boot · PostgreSQL · Cloudflare", tiempo: "14 semanas", kpi: ["Trazabilidad del 100% de transacciones desde el primer día", "Cierre diario reducido de 2 h a 15 min", "Cumplimiento de controles para auditoría"], url: null },
];

// ── Seguridad por defecto ──────────────────────────────────────────────────
const seguridadItems = [
  { titulo: "Autenticación y roles", desc: "JWT/OAuth2, roles granulares, 2FA opcional y sesiones seguras." },
  { titulo: "Cifrado TLS 1.3 + AES-256", desc: "HTTPS obligatorio. Datos sensibles cifrados en base de datos." },
  { titulo: "Backups automáticos diarios", desc: "Retención configurable. Restauración probada en staging." },
  { titulo: "Logging y auditoría", desc: "Registro de acciones críticas por usuario con trazabilidad completa." },
  { titulo: "CI/CD y ambientes separados", desc: "Dev → Staging → Producción. Nunca se despliega sin pruebas." },
  { titulo: "WAF + protección OWASP Top 10", desc: "Cloudflare o equivalente. Protección ante ataques comunes." },
  { titulo: "Monitoreo y alertas 24/7", desc: "Uptime monitoring con alertas ante caídas o errores críticos." },
];
const stackTecnologias = [
  { categoria: "Frontend", techs: ["React", "Next.js", "Angular", "Vue.js", "TypeScript", "React Native"] },
  { categoria: "Backend", techs: ["Node.js", "NestJS", "Spring Boot", "Java", "Python / FastAPI"] },
  { categoria: "Base de datos", techs: ["PostgreSQL", "MongoDB", "MySQL", "Redis"] },
  { categoria: "Infraestructura", techs: ["AWS", "Google Cloud", "Azure", "Firebase", "Cloudflare"] },
  { categoria: "DevOps", techs: ["Docker", "GitHub Actions", "CI/CD pipelines", "Nginx", "PM2"] },
];

// ── Rangos de inversión ────────────────────────────────────────────────────
const rangos = [
  { tipo: "MVP / Módulo base", desde: "S/. 8,000", rango: "S/. 8,000 – S/. 25,000", tiempo: "4–8 semanas", alcance: "1–3 módulos, 1 flujo principal, roles básicos", ideal: "Startups, validación de concepto, módulo de un área puntual", color: "border-blue-500/30 bg-blue-500/5", numColor: "text-blue-600 dark:text-blue-400" },
  { tipo: "Sistema completo", desde: "S/. 25,000", rango: "S/. 25,000 – S/. 70,000", tiempo: "2–4 meses", alcance: "4–8 módulos, dashboards, integraciones básicas", ideal: "PYMES, sistemas de gestión interna, CRM/ERP", color: "border-complementary-500/30 bg-complementary-500/5", numColor: "text-complementary-600 dark:text-complementary-400" },
  { tipo: "Plataforma / SaaS avanzado", desde: "S/. 70,000+", rango: "S/. 70,000+", tiempo: "3–6 meses", alcance: "Multi-tenant, pagos, onboarding, analíticas, API pública", ideal: "SaaS, fintech, plataformas educativas, sistemas sectoriales", color: "border-green-500/30 bg-green-500/5", numColor: "text-green-600 dark:text-green-400" },
];
const factoresPrecio = [
  "Número de módulos y pantallas",
  "Integraciones con sistemas externos (SUNAT, pagos, APIs)",
  "Complejidad de reglas de negocio y flujos",
  "Nivel de personalización del diseño UX/UI",
  "Migración de datos desde sistemas anteriores",
  "Requisitos de rendimiento y escalabilidad",
  "Soporte y mantenimiento post-lanzamiento",
];

// ── Testimonios ────────────────────────────────────────────────────────────
const testimonios = [
  { nombre: "Carlos Meléndez", rol: "Gerente de Operaciones", empresa: "Sector logístico", quote: "El sistema que desarrolló BCP Consulting redujo en un 40% los tiempos de gestión de inventario. Ahora tenemos control en tiempo real y menos errores en las entregas.", resultado: "–40% tiempo de gestión de inventario" },
  { nombre: "Javier López", rol: "Director Académico", empresa: "Plataforma educativa online", quote: "Nos diseñaron una plataforma con aulas virtuales. Los alumnos pueden conectarse desde cualquier dispositivo y nuestras inscripciones aumentaron un 30%.", resultado: "+30% inscripciones" },
  { nombre: "Ana Rodríguez", rol: "Fundadora", empresa: "E-commerce B2C", quote: "El equipo entendió nuestras necesidades y en pocas semanas ya estábamos vendiendo con pagos totalmente integrados.", resultado: "Ventas online activas desde el primer mes" },
  { nombre: "Pedro Salas", rol: "CEO", empresa: "Empresa de servicios B2B", quote: "Pasamos de gestionar todo en WhatsApp y Excel a tener un sistema centralizado. El equipo de BCP fue transparente en cada sprint y cumplió los plazos.", resultado: "100% procesos centralizados, cero Excel" },
];

// ── FAQs completas (12) ────────────────────────────────────────────────────
const faqs = [
  { id: "faq-propiedad", q: "¿El código fuente es mío al terminar el proyecto?", a: "Sí, al 100%. Entregamos el repositorio completo con historial de commits. Tienes plena propiedad intelectual: puedes modificarlo, transferirlo o alojarlo donde quieras sin depender de BCP Consulting." },
  { id: "faq-cambios", q: "¿Puedo pedir cambios durante el desarrollo?", a: "Sí. Trabajamos en sprints de 1–2 semanas con revisiones al finalizar cada uno. Los cambios menores dentro del alcance acordado no tienen costo adicional. Cambios de alcance significativos se evalúan con un adenda y nueva estimación." },
  { id: "faq-seguridad", q: "¿Qué tan seguro es el software que desarrollan?", a: "Aplicamos seguridad desde el diseño: JWT/OAuth2 con roles, HTTPS/TLS 1.3, cifrado AES-256 en reposo, WAF (Cloudflare), backups automáticos diarios, registro de auditoría y revisión OWASP Top 10 antes de cada deploy." },
  { id: "faq-integraciones", q: "¿Se puede integrar con mis sistemas actuales (ERP, contabilidad, SUNAT)?", a: "Sí. Integramos con ERPs (SAP, Odoo), contabilidad (Concar, Contasis), facturación SUNAT, pasarelas de pago (Culqi, Izipay, Stripe) y cualquier sistema que exponga API o base de datos accesible." },
  { id: "faq-plazo", q: "¿En cuánto tiempo estará listo el sistema?", a: "Un MVP con 2–3 módulos puede estar listo en 4–8 semanas. Sistemas complejos toman 2–6 meses. Entregamos cronograma detallado con hitos semanales desde el inicio." },
  { id: "faq-precio", q: "¿Cuánto cuesta desarrollar software a medida?", a: "MVP: S/. 8,000–25,000. Sistema completo: S/. 25,000–70,000. Plataforma SaaS: S/. 70,000+. El costo varía según módulos, integraciones y personalización. Ofrecemos pagos fraccionados por etapas." },
  { id: "faq-soporte", q: "¿Ofrecen soporte después del lanzamiento?", a: "Sí. Los primeros 30 días son gratuitos. Luego ofrecemos planes mensuales que incluyen correcciones, actualizaciones de seguridad, monitoreo y mejoras menores." },
  { id: "faq-sla", q: "¿Qué SLA ofrecen en producción?", a: "SLA estándar: 99.5% de disponibilidad mensual. Bugs críticos (P0): respuesta máxima de 4 h hábiles. No críticos: 24–48 h. Todo incluido en los planes de mantenimiento activo." },
  { id: "faq-inicio", q: "¿Cuánto tiempo toma iniciar una vez acepto la propuesta?", a: "El kickoff ocurre en los 5 días hábiles siguientes a la firma del contrato y pago del primer hito. Se definen alcance final, accesos, herramientas de colaboración y calendario de sprints." },
  { id: "faq-fraccionado", q: "¿Hay pagos fraccionados?", a: "Sí. El esquema habitual es 30% al inicio, 40% en etapa media (con entrega parcial funcional) y 30% al cierre. Para proyectos grandes podemos acordar más hitos de pago por fases." },
  { id: "faq-hosting", q: "¿Incluye el hosting?", a: "No por defecto, pero lo configuramos y asesoramos en la elección. Los costos de hosting dependen del proveedor cloud (AWS, GCP, Azure) y el nivel de tráfico. Te recomendamos la arquitectura más eficiente según tu presupuesto." },
  { id: "faq-produccion", q: "¿Qué pasa si el sistema falla en producción?", a: "Todos los proyectos cuentan con monitoreo activo de uptime. Ante fallas críticas, respondemos en máx. 4 h laborables. Usamos ambientes separados (staging y prod) para minimizar riesgos en actualizaciones." },
];

// ── Tabla de contenidos ────────────────────────────────────────────────────
const toc = [
  { label: "Tipos de software", href: "#tipos-software" },
  { label: "Proceso 7 fases", href: "#proceso" },
  { label: "Casos reales", href: "#casos" },
  { label: "Seguridad y stack", href: "#seguridad" },
  { label: "Estimación de costos", href: "#estimacion" },
  { label: "Testimonios", href: "#testimonios" },
  { label: "FAQ", href: "#faq" },
  { label: "Cotizar", href: "#cotizar" },
];

// ── Schema JSON-LD ─────────────────────────────────────────────────────────
const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
});

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Desarrollo de Software a Medida en Perú",
  description: "Desarrollamos sistemas de software web a medida: ERP, CRM, SaaS, Logística, Automatización e Integraciones para pymes, startups y grandes empresas en Perú y Latinoamérica.",
  provider: {
    "@type": "Organization",
    name: "BCP Consulting E.I.R.L.",
    url: "https://bcpconsulting.pe",
    telephone: "+51929772711",
    email: "soporte@bcpconsulting.pe",
    taxID: "20612012475",
    sameAs: ["https://www.linkedin.com/company/bcp-consulting-sac"],
  },
  areaServed: { "@type": "Country", name: "Peru" },
  serviceType: "Custom Software Development",
  url: "https://bcpconsulting.pe/servicios/software",
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "PEN",
    lowPrice: "8000",
    highPrice: "70000",
    offerCount: "3",
  },
});

const organizationSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "BCP Consulting E.I.R.L.",
  url: "https://bcpconsulting.pe",
  telephone: "+51929772711",
  email: "soporte@bcpconsulting.pe",
  taxID: "20612012475",
  address: { "@type": "PostalAddress", addressCountry: "PE", addressRegion: "Lima" },
  areaServed: { "@type": "Country", name: "Peru" },
  sameAs: ["https://www.linkedin.com/company/bcp-consulting-sac"],
});
---

<MainLayout
  title="Desarrollo de Software a Medida en Perú"
  description="ERP, CRM, SaaS y sistemas web a medida para empresas en Perú. +10 años de experiencia, sprints ágiles y código 100% tuyo. Cotiza desde S/. 8,000."
>
  <Fragment slot="head">
    <link rel="canonical" href="https://bcpconsulting.pe/servicios/software" />
    <script type="application/ld+json" set:html={faqSchema} />
    <script type="application/ld+json" set:html={serviceSchema} />
    <script type="application/ld+json" set:html={organizationSchema} />
    <meta property="og:url" content="https://bcpconsulting.pe/servicios/software" />
    <meta property="og:type" content="website" />
    <style>
      :where(section[id]) { scroll-margin-top: 5rem; }
      @media (prefers-reduced-motion: no-preference) {
        html { scroll-behavior: smooth; }
      }
      /* Acordeones mobile */
      .toc-details[open] .toc-chevron { transform: rotate(180deg); }
      .pilar-details[open] .pilar-chevron { transform: rotate(180deg); }
    </style>
  </Fragment>

  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <HeroPage
    title="Desarrollo de software a medida para automatizar procesos y centralizar tu operación"
    description="Creamos sistemas web empresariales (ERP, CRM, SaaS, Logística) adaptados a tu negocio, con arquitectura escalable, seguridad de nivel bancario y soporte continuo desde Perú."
    breadcrumbs={[
      { label: "Inicio", href: "/" },
      { label: "Servicios", href: "/servicios" },
      { label: "Software a Medida" },
    ]}
    image={bgSoftware}
    imageAlt="Equipo de desarrollo de software a medida en Perú — BCP Consulting"
  />

  <main id="main-content">

    <!-- ── Tabla de contenidos ──────────────────────────────────────────── -->
    <section aria-label="Tabla de contenidos" class="bg-theme-surface border-b border-theme-border">
      <div class="max-w-350 mx-auto px-[5%] py-4">
        <!-- Desktop: chips en línea -->
        <nav aria-label="Navegación de secciones" class="hidden md:flex flex-wrap gap-2 items-center">
          <span class="text-xs font-semibold text-theme-muted uppercase tracking-wide mr-2">Contenido:</span>
          {toc.map((item) => (
            <a
              href={item.href}
              class="inline-block px-3 py-1.5 rounded-full text-xs font-semibold bg-theme-page border border-theme-border text-theme-muted hover:border-secondary-400 hover:text-secondary-600 dark:hover:text-secondary-400 transition-colors"
            >
              {item.label}
            </a>
          ))}
        </nav>
        <!-- Mobile: colapsable -->
        <details class="toc-details md:hidden">
          <summary class="flex items-center justify-between gap-2 cursor-pointer text-sm font-semibold text-theme-heading list-none select-none py-1">
            <span>Tabla de contenidos</span>
            <svg class="toc-chevron w-4 h-4 text-theme-muted transition-transform duration-200 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <nav aria-label="Navegación de secciones (móvil)" class="flex flex-col gap-1 mt-3 pl-1">
            {toc.map((item) => (
              <a href={item.href} class="text-sm text-secondary-600 dark:text-secondary-400 hover:underline py-0.5">
                → {item.label}
              </a>
            ))}
          </nav>
        </details>
      </div>
    </section>

    <!-- ── Definición AEO ───────────────────────────────────────────────── -->
    <section
      id="definicion"
      aria-labelledby="definicion-heading"
      class="py-10 bg-theme-page"
    >
      <div class="max-w-350 mx-auto px-[5%]">
        <div class="max-w-3xl p-5 rounded-2xl bg-secondary-50 dark:bg-white/5 border border-secondary-200 dark:border-white/10">
          <p class="text-xs font-semibold uppercase tracking-wide text-secondary-600 dark:text-secondary-400 mb-1">Definición — ¿Qué es el software a medida?</p>
          <p class="text-sm text-theme-muted leading-relaxed">
            <strong class="text-theme-heading" id="definicion-heading">Software a medida</strong> es un sistema desarrollado específicamente para los flujos y requerimientos
            de una organización, a diferencia del software empaquetado (como SAP o Salesforce genérico). Permite automatizar
            procesos únicos, integrarse con sistemas existentes y escalar según el crecimiento del negocio.
            Su costo refleja el alcance funcional, no un precio de catálogo.
          </p>
        </div>
      </div>
    </section>

    <!-- ── Tipos de software (tabla AEO) ───────────────────────────────── -->
    <section
      id="tipos-software"
      aria-labelledby="tipos-heading"
      class="py-16 lg:py-20 bg-primary-800"
      style="scroll-margin-top: 5rem"
    >
      <div class="max-w-350 mx-auto px-[5%]">
        <header class="max-w-3xl mx-auto text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-complementary-300 mb-2">Tabla comparativa — AEO</p>
          <h2 id="tipos-heading" class="text-2xl md:text-3xl font-extrabold text-white leading-tight">¿Qué tipo de sistema necesitas?</h2>
          <p class="mt-3 text-sm text-white/70 leading-relaxed">
            Cada tipo de software tiene un propósito diferente. Esta tabla te ayuda a identificar
            cuál se ajusta mejor a tu operación y objetivos de negocio.
          </p>
        </header>
        <!-- Tabla AEO semántica (desktop) -->
        <div class="overflow-x-auto rounded-2xl border border-white/10">
          <table class="w-full text-sm text-white/85 border-collapse">
            <caption class="sr-only">Comparativa de tipos de software a medida: objetivo, módulos, tiempo estimado, integraciones y cuándo elegirlo</caption>
            <thead class="bg-white/10 text-xs uppercase tracking-wide text-white/60">
              <tr>
                <th scope="col" class="px-4 py-3 text-left font-semibold min-w-37.5">Tipo de sistema</th>
                <th scope="col" class="px-4 py-3 text-left font-semibold min-w-45">Objetivo principal</th>
                <th scope="col" class="px-4 py-3 text-left font-semibold min-w-50">Módulos típicos</th>
                <th scope="col" class="px-4 py-3 text-left font-semibold min-w-30">Tiempo est.</th>
                <th scope="col" class="px-4 py-3 text-left font-semibold min-w-45">Integraciones</th>
                <th scope="col" class="px-4 py-3 text-left font-semibold min-w-50">Recomendado si…</th>
              </tr>
            </thead>
            <tbody>
              {tiposSoftware.map((f, i) => (
                <tr class={`border-t border-white/10 ${i % 2 === 0 ? "bg-white/3" : "bg-transparent"} hover:bg-white/8 transition-colors`}>
                  <td class="px-4 py-3 font-semibold text-complementary-300 align-top">{f.tipo}</td>
                  <td class="px-4 py-3 text-white/75 align-top">{f.objetivo}</td>
                  <td class="px-4 py-3 text-white/70 align-top text-xs leading-relaxed">{f.modulos}</td>
