            <li class="relative flex gap-4 md:gap-6 pb-8 last:pb-0">
              {i < fases.length - 1 && (
                <div class="absolute left-6 md:left-7 top-14 bottom-0 w-px bg-theme-border" aria-hidden="true"></div>
              )}
              <div class="shrink-0 w-12 h-12 md:w-14 md:h-14 rounded-2xl border-2 border-secondary-300/40 bg-secondary-500/5 flex items-center justify-center z-10">
