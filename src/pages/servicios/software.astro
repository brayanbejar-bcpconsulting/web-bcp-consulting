                <div class="pt-2 border-t border-theme-border"><dt class="font-semibold text-theme-muted/70 uppercase tracking-wide text-[10px]">Ideal para</dt><dd class="text-theme-muted italic">{r.ideal}</dd></div>
              </dl>
