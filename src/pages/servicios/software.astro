          <a href={`https://api.whatsapp.com/send/?phone=${waPhone}&text=${waMsg}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-green-500 hover:bg-green-400 text-white text-sm font-semibold transition-colors min-h-11">Quiero algo similar →</a>
