---
import MainLayout from "@layouts/MainLayout.astro";
import { HeroPage, MainContainer, HeadingSection, Button } from "@components";
import { SERVICES } from "@data/services";

const service = SERVICES.find((s) => s.id === "apps-moviles")!;

const appTypes = [
  {
    name: "Gimnasios y Fitness",
    desc: "Reserva de clases, seguimiento de rutinas y control de membresías en tiempo real.",
  },
  {
    name: "Restaurantes y Delivery",
    desc: "Pedidos online, menú digital interactivo y seguimiento de entregas en vivo.",
  },
  {
    name: "E-commerce",
    desc: "Catálogo completo, carrito de compras y pasarela de pagos totalmente segura.",
  },
  {
    name: "Academias y Educación",
    desc: "Cursos online, evaluaciones automáticas y comunicación directa con padres.",
  },
  {
    name: "Clínicas y Salud",
    desc: "Telemedicina, gestión de citas médicas y monitoreo continuo de pacientes.",
  },
  {
    name: "Transporte y Logística",
    desc: "Rastreo GPS en tiempo real, gestión de flotas y optimización de rutas.",
  },
];

import bgAppsMobiles from '@images/pages/services/apps-mobiles/bg-image-apps-mobile.jpg';
---

<MainLayout
  title={`${service.title} para Android e iOS`}
  description={`Desarrollo de aplicaciones móviles nativas para Android e iOS en Perú. ${service.tagline}. Apps de alto rendimiento y diseño UX premium.`}
>
  <HeroPage
    title={service.title}
    description={service.description}
    bgClass="hero-page--secondary"
    breadcrumbs={[
      { label: "Inicio", href: "/" },
      { label: "Servicios", href: "/servicios" },
      { label: service.title },
    ]}
    image={bgAppsMobiles}
    imageAlt="Aplicaciones móviles para negocios y empresas que necesitan automatizar los procesos."
  />

  <MainContainer bgColor="bg-neutral-50" id="features-apps">
    <HeadingSection
      tagline={service.tagline}
      title="¿Qué Incluye el Desarrollo de tu App?"
      description="Desde el diseño UX/UI hasta la publicación en stores, cubrimos cada etapa del desarrollo de tu aplicación."
      badgeVariant="secondary"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        service.features.map((f) => (
          <div class="p-6 rounded-xl bg-white border border-neutral-200 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
            <h3 class="text-primary-700 font-bold text-lg mb-2">{f.title}</h3>
            <p class="text-neutral-600 text-sm leading-relaxed">
              {f.description}
            </p>
          </div>
        ))
      }
    </div>
  </MainContainer>

  <MainContainer bgColor="bg-white" id="sectores-apps">
    <HeadingSection
      tagline="Apps por Sector"
      title="Apps Móviles Diseñadas para tu Industria"
      description="Desarrollamos apps innovadoras para Android e iOS, diseñadas para fidelizar clientes y generar nuevas oportunidades de negocio."
      badgeVariant="complementary"
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        appTypes.map((t) => (
          <div class="p-6 rounded-xl bg-neutral-50 border border-neutral-200 hover:border-secondary-300 hover:shadow-md transition-all duration-300">
            <h3 class="text-primary-700 font-bold text-base mb-1">{t.name}</h3>
            <p class="text-neutral-600 text-sm">{t.desc}</p>
          </div>
        ))
      }
    </div>
  </MainContainer>

  <section
    class="py-20 px-[5%]"
    style="background: linear-gradient(135deg, var(--color-primary-800), var(--color-secondary-700));"
  >
    <div class="max-w-200 mx-auto text-center flex flex-col items-center gap-6">
      <h2
        class="text-white font-extrabold text-balance"
        style="font-size: clamp(1.75rem, 3vw + 0.5rem, 2.8rem);"
      >
        Lleva tu Empresa al Bolsillo de tus Clientes
      </h2>
      <p class="text-white/80 text-lg max-w-xl leading-relaxed">
        Escríbenos y cuéntanos tu idea. Diseñamos apps nativas de alto impacto
        visual con rendimiento excepcional.
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-4 mt-2">
        <Button
          href="https://api.whatsapp.com/send/?phone=51929772711&text=Hola%2C%20necesito%20una%20aplicaci%C3%B3n%20m%C3%B3vil%20para%20mi%20negocio"
          target="_blank"
          variant="whatsapp"
          size="lg"
          icon="whatsapp"
        >
          Cotizar mi App
        </Button>
        <Button href="/contacto" variant="secondary" size="lg">
          Formulario de contacto
        </Button>
      </div>
    </div>
  </section>
</MainLayout>
