---
import MainLayout from "@layouts/MainLayout.astro";
import { HeroPage, MainContainer, HeadingSection, Button } from "@components";
import { SERVICES } from "@data/services";
import { getBreadcrumbSchema } from "@utils/seo";
import { SITE_INFO } from "@utils/site-config";

const service = SERVICES.find((s) => s.id === "apps-moviles")!;

const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Inicio", url: SITE_INFO.url + "/" },
  { name: "Servicios", url: SITE_INFO.url + "/servicios" },
  { name: service.title, url: SITE_INFO.url + "/servicios/apps-moviles" },
]);

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Desarrollo de Aplicaciones Móviles en Perú",
  description:
    "Desarrollamos aplicaciones móviles nativas para Android e iOS: apps de negocio, delivery, salud, educación y más. Diseño UX/UI premium y publicación en stores incluida.",
  provider: {
    "@type": "Organization",
    "@id": `${SITE_INFO.url}/#organization`,
    name: SITE_INFO.title,
    url: SITE_INFO.url,
    taxID: "20612012475",
  },
  areaServed: { "@type": "Country", name: "Perú" },
  serviceType: "Mobile App Development",
  url: `${SITE_INFO.url}/servicios/apps-moviles`,
};

const appTypes = [
  {
    name: "Gimnasios y Fitness",
    desc: "Reserva de clases, seguimiento de rutinas y control de membresías en tiempo real.",
  },
  {
    name: "Restaurantes y Delivery",
    desc: "Pedidos online, menú digital interactivo y seguimiento de entregas en vivo.",
  },
  {
    name: "E-commerce",
    desc: "Catálogo completo, carrito de compras y pasarela de pagos totalmente segura.",
  },
  {
    name: "Academias y Educación",
    desc: "Cursos online, evaluaciones automáticas y comunicación directa con padres.",
  },
  {
    name: "Clínicas y Salud",
    desc: "Telemedicina, gestión de citas médicas y monitoreo continuo de pacientes.",
  },
  {
    name: "Transporte y Logística",
    desc: "Rastreo GPS en tiempo real, gestión de flotas y optimización de rutas.",
  },
];


const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Cuánto cuesta desarrollar una aplicación móvil en Perú?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "El costo depende de la plataforma (Android, iOS o ambas), la complejidad de las funcionalidades y las integraciones requeridas. Una app de gestión básica puede partir desde S/ 8,000, mientras que una app con funcionalidades avanzadas, pagos en línea o integraciones de terceros puede superar los S/ 30,000. Solicitanos una cotización personalizada.",
      },
    },
    {
      "@type": "Question",
      name: "¿Cuánto tiempo tarda el desarrollo de una app móvil?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Una app con funcionalidades básicas toma entre 8 y 16 semanas. Las apps con módulos complejos, integraciones o múltiples roles de usuario pueden tomar entre 4 y 8 meses. Entregamos un cronograma detallado tras el análisis de requerimientos.",
      },
    },
    {
      "@type": "Question",
      name: "¿Desarrollan apps nativas o híbridas?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Desarrollamos apps nativas para Android (Kotlin/Java) e iOS (Swift), y también apps multiplataforma con Flutter o React Native cuando el proyecto lo justifica. Recomendamos la tecnología más adecuada según el presupuesto, el rendimiento requerido y los plazos del cliente.",
      },
    },
    {
      "@type": "Question",
      name: "¿Incluyen la publicación en Google Play y App Store?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí. El proceso de publicación en Google Play Store y Apple App Store está incluido en nuestros proyectos. Te orientamos en la creación de cuentas de desarrollador si aún no las tienes y gestionamos todo el proceso de envío y aprobación.",
      },
    },
    {
      "@type": "Question",
      name: "¿Qué soporte ofrecen después de lanzar la app?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ofrecemos planes de mantenimiento post-lanzamiento que incluyen corrección de bugs, actualizaciones de compatibilidad con nuevas versiones de Android e iOS, y soporte técnico. También podemos implementar nuevas funcionalidades de forma incremental.",
      },
    },
  ],
};
import bgAppsMobiles from '@images/pages/services/apps-mobiles/bg-image-apps-mobile.jpg';
---

<MainLayout
  title={`${service.title} para Android e iOS`}
  description={`Desarrollo de aplicaciones móviles nativas para Android e iOS en Perú. ${service.tagline}. Apps de alto rendimiento y diseño UX premium.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>
  <HeroPage
    title={service.title}
    description={service.description}
    bgClass="hero-page--secondary"
    breadcrumbs={[
      { label: "Inicio", href: "/" },
      { label: "Servicios", href: "/servicios" },
      { label: service.title },
    ]}
    image={bgAppsMobiles}
    imageAlt="Aplicaciones móviles para negocios y empresas que necesitan automatizar los procesos."
  />

  <MainContainer bgColor="bg-theme-surface" id="features-apps">
    <HeadingSection
      tagline={service.tagline}
      title="¿Qué Incluye el Desarrollo de tu App?"
      description="Desde el diseño UX/UI hasta la publicación en stores, cubrimos cada etapa del desarrollo de tu aplicación."
      badgeVariant="secondary"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        service.features.map((f) => (
          <div class="p-6 rounded-xl bg-theme-card border border-theme-border hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
            <h3 class="text-theme-heading font-bold text-lg mb-2">{f.title}</h3>
            <p class="text-theme-muted text-sm leading-relaxed">
              {f.description}
            </p>
          </div>
        ))
      }
    </div>
  </MainContainer>

  <MainContainer bgColor="bg-theme-page" id="sectores-apps">
    <HeadingSection
      tagline="Apps por Sector"
      title="Apps Móviles Diseñadas para tu Industria"
      description="Desarrollamos apps innovadoras para Android e iOS, diseñadas para fidelizar clientes y generar nuevas oportunidades de negocio."
      badgeVariant="complementary"
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        appTypes.map((t) => (
          <div class="p-6 rounded-xl bg-theme-card border border-theme-border hover:border-secondary-300 hover:shadow-md transition-all duration-300">
            <h3 class="text-theme-heading font-bold text-base mb-1">{t.name}</h3>
            <p class="text-theme-muted text-sm">{t.desc}</p>
          </div>
        ))
      }
    </div>
  </MainContainer>

  <section
    class="py-20 px-[5%]"
    style="background: linear-gradient(135deg, var(--color-primary-800), var(--color-secondary-700));"
  >
    <div class="max-w-200 mx-auto text-center flex flex-col items-center gap-6">
      <h2
        class="text-white font-extrabold text-balance"
        style="font-size: clamp(1.75rem, 3vw + 0.5rem, 2.8rem);"
      >
        Lleva tu Empresa al Bolsillo de tus Clientes
      </h2>
      <p class="text-white/80 text-lg max-w-xl leading-relaxed">
        Escríbenos y cuéntanos tu idea. Diseñamos apps nativas de alto impacto
        visual con rendimiento excepcional.
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-4 mt-2">
        <Button
          href="https://api.whatsapp.com/send/?phone=51929772711&text=Hola%2C%20necesito%20una%20aplicaci%C3%B3n%20m%C3%B3vil%20para%20mi%20negocio"
          target="_blank"
          variant="whatsapp"
          size="lg"
          icon="whatsapp"
        >
          Cotizar mi App
        </Button>
        <Button href="/contacto" variant="secondary" size="lg">
          Formulario de contacto
        </Button>
      </div>
    </div>
  </section>
</MainLayout>
