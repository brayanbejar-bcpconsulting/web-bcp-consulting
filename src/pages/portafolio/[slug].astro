---
import { getCollection } from "astro:content";
import MainLayout from "@layouts/MainLayout.astro";
import { Button, MainContainer } from "@components";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import Icon from "@components/ui/Icon.astro";
import { getBreadcrumbSchema } from "@utils/seo";
import { SITE_INFO } from "@utils/site-config";

export async function getStaticPaths() {
  const allProjects = await getCollection("projects");
  return allProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const { data } = project;
const siteOrigin = Astro.url.origin;

// ── JSON-LD ───────────────────────────────────────────────────────────────────────────
const schemaType =
  data.category === "app" || data.category === "software"
    ? "SoftwareApplication"
    : "CreativeWork";

const schema = {
  "@context": "https://schema.org",
  "@type": schemaType,
  name: data.title,
  description: data.tagline ?? data.description,
  image: data.coverImage ? (data.coverImage.startsWith("http") ? data.coverImage : `${siteOrigin}${data.coverImage}`) : undefined,
  url: data.url,
  ...(data.playStoreUrl && { downloadUrl: data.playStoreUrl }),
  ...(data.appStoreUrl && {
    downloadUrl: data.appStoreUrl,
    installUrl: data.appStoreUrl,
  }),
  ...(data.features && {
    featureList: data.features.map((f) => f.title).join(", "),
  }),
  ...(data.gallery && {
    screenshot: data.gallery,
  }),
  ...(data.videoUrl && {
    video: {
      "@type": "VideoObject",
      name: `Demostración de ${data.title}`,
      embedUrl: data.videoUrl,
    },
  }),
  creator: {
    "@type": "Organization",
    name: "BCP Consulting",
    url: "https://bcpconsulting.pe",
  },
};

// ── Metadata bar items ───────────────────────────────────────────────────────────────────
const metaItems = [
  { icon: "user",           label: "Cliente",   value: data.client          },
  { icon: "handshake",      label: "Rol",        value: data.role            },
  { icon: "clock-check",    label: "Duración",   value: data.duration        },
  { icon: "calendar-check", label: "Año",        value: String(data.year)    },
];

const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Inicio",     url: SITE_INFO.url + "/" },
  { name: "Portafolio", url: SITE_INFO.url + "/portafolio/" },
  { name: data.title,   url: Astro.url.href },
]);
---

<MainLayout
  title={`Caso de Éxito: ${data.title}`}
  description={data.tagline ?? data.description}
  image={data.coverImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- ══ HERO ══════════════════════════════════════════════════════════ -->
  <header class="project-hero">
    <div class="project-hero__bg" aria-hidden="true">
      <img
        src={data.coverImage}
        alt=""
        role="presentation"
        loading="eager"
        fetchpriority="high"
      />
      <div class="project-hero__overlay"></div>
    </div>

    <div class="project-hero__content max-w-200 mx-auto px-[5%]">
      <nav aria-label="Miga de pan">
        <Breadcrumbs
          items={[
            { label: "Inicio",     href: "/" },
            { label: "Portafolio", href: "/portafolio" },
            { label: data.title },
          ]}
        />
      </nav>

      <h1 class="text-white font-extrabold text-balance mb-4 mt-4 drop-shadow-lg">
        {data.title}
      </h1>

      <p class="text-white/90 text-xl max-w-2xl drop-shadow">
        {data.tagline ?? data.description}
      </p>
    </div>
  </header>

  <!-- ══ METADATA BAR ══════════════════════════════════════════════════ -->
  <div class="meta-bar" role="complementary" aria-label="Ficha técnica del proyecto">
    <div class="meta-bar__inner max-w-200 mx-auto px-[5%]">
      <dl class="meta-bar__list">
        {metaItems.map((item) => (
          <div class="meta-bar__item">
            <Icon name={item.icon} size={16} aria-hidden="true" class="meta-bar__icon" />
            <dt class="sr-only">{item.label}</dt>
            <dd>
              <span class="meta-bar__label">{item.label}</span>
              <span class="meta-bar__value">{item.value}</span>
            </dd>
          </div>
        ))}

        <div class="meta-bar__item meta-bar__item--cta">
          {data.url && (
            <a
              href={data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="meta-bar__link"
              aria-label={`Visitar el sitio web oficial de ${data.title} (abre en nueva pestaña)`}
            >
              <Icon name="link-chain" size={15} aria-hidden="true" />
              Ver en vivo
            </a>
          )}
          {data.playStoreUrl && (
            <a
              href={data.playStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="meta-bar__link"
              aria-label={`Descargar ${data.title} en Google Play (abre en nueva pestaña)`}
            >
              <Icon name="google-play" size={15} aria-hidden="true" />
              Google Play
            </a>
          )}
          {data.appStoreUrl && (
            <a
              href={data.appStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="meta-bar__link"
              aria-label={`Descargar ${data.title} en App Store (abre en nueva pestaña)`}
            >
              <Icon name="apple" size={15} aria-hidden="true" />
              App Store
            </a>
          )}
        </div>
      </dl>
    </div>
  </div>

  <!-- ══ CONTENIDO PRINCIPAL ═══════════════════════════════════════════ -->
  <MainContainer bgColor="bg-theme-page">
    <article
      class="project-article prose prose-base prose-neutral
             prose-headings:font-bold 
             prose-a:text-secondary-600 hover:prose-a:text-secondary-700
             dark:prose-invert max-w-none"
      aria-label={`Contenido del proyecto ${data.title}`}
    >
      <Content />
    </article>
  </MainContainer>

  <!-- ══ CTA FINAL ═════════════════════════════════════════════════════ -->
  <section class="project-cta" aria-labelledby="cta-heading">
    <div class="project-cta__inner">
      <p class="project-cta__eyebrow" aria-hidden="true">¿Tienes un reto similar?</p>
      <h2 id="cta-heading" class="project-cta__heading">
        Construyamos el sistema que tu empresa necesita
      </h2>
      <p class="project-cta__body">
        Conversemos sobre los problemas de tu negocio y diseñemos juntos una
        solución tecnológica a medida.
      </p>
      <div class="project-cta__actions">
        <Button
          href="/contacto"
          size="lg"
          variant="secondary"
          icon="arrow-right"
          iconSide="right"
        >
          Cotizar mi proyecto
        </Button>
        <Button href="/portafolio" size="lg" variant="outline">
          Ver más proyectos
        </Button>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  @reference "../../styles/global.css";

  /* ── Hero ── */
  .project-hero {
    @apply relative pt-40 pb-24 md:pt-48 md:pb-32 overflow-hidden;
  }
  .project-hero__bg {
    @apply absolute inset-0 z-0;
  }
  .project-hero__bg img {
    @apply w-full h-full object-cover;
  }
  .project-hero__overlay {
    @apply absolute inset-0 bg-linear-to-t from-primary-950/90 to-primary-900/60 mix-blend-multiply;
  }
  .project-hero__content {
    @apply relative z-10;
  }

  /* ── Metadata bar ── */
  .meta-bar {
    @apply bg-theme-card border-b border-theme-border;
  }
  .meta-bar__inner {
    @apply py-3;
  }
  .meta-bar__list {
    @apply flex flex-wrap items-center gap-x-6 gap-y-2;
  }
  .meta-bar__item {
    @apply flex items-center gap-2;
  }
  .meta-bar__icon {
    @apply text-theme-muted shrink-0;
  }
  .meta-bar__item dd {
    @apply flex items-baseline gap-1.5;
  }
  .meta-bar__label {
    @apply text-xs text-theme-muted font-medium;
  }
  .meta-bar__value {
    @apply text-sm font-bold text-theme-heading;
  }
  .meta-bar__item--cta {
    @apply ml-auto flex items-center gap-4 flex-wrap;
  }
  .meta-bar__link {
    @apply inline-flex items-center gap-1.5 text-sm font-semibold
           text-secondary-600 hover:text-secondary-700
           dark:text-secondary-400 dark:hover:text-secondary-300
           transition-colors duration-200 underline underline-offset-4;
  }

  /* ── Artículo ── */
  .project-article {
    @apply max-w-5xl mx-auto;
  }

  /* ── CTA ── */
  .project-cta {
    @apply py-20 px-[5%] bg-theme-surface border-t border-theme-border text-center;
  }
  .project-cta__inner {
    @apply max-w-2xl mx-auto flex flex-col items-center gap-4;
  }
  .project-cta__eyebrow {
    @apply text-sm font-bold tracking-widest uppercase text-secondary-600
           dark:text-secondary-400;
  }
  .project-cta__heading {
    @apply font-black text-theme-heading text-balance;
  }
  .project-cta__body {
    @apply text-theme-muted text-lg;
  }
  .project-cta__actions {
    @apply flex flex-wrap items-center justify-center gap-4 mt-2;
  }
</style>
